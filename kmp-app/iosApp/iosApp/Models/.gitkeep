# MediaPipe pose landmarker model (iOS app bundle resource)
#
# File: pose_landmarker_full.task
# Same asset as Android app/src/main/assets/pose_landmarker_full.task
#
# Download:
# https://storage.googleapis.com/mediapipe-models/pose_landmarker/pose_landmarker_full/float16/latest/pose_landmarker_full.task
#
# Quick setup (Mac/Linux):
#   cd kmp-app && ./scripts/fetch-pose-landmarker-model.sh
#
# Xcode pre-build copies from Android assets when present; otherwise bridge stays unavailable.
