          "stateMessages": {
            "perfect": { "ar": "ممتاز - الساقين مستقيمتين", "en": "Great - legs are straight" },
            "warning": { "ar": "افرد ركبتيك", "en": "Straighten your knees" }
          }
        }
      ],
      "feedbackMessages": {
        "motivational": [
          { "ar": "استمر! أنت تفعلها!", "en": "Keep going! You're doing great!" },
          { "ar": "ممتاز! حافظ على الوضع!", "en": "Excellent! Hold that position!" },
          { "ar": "قوي! لا تستسلم!", "en": "Strong! Don't give up!" }
        ],
        "tips": [
          { "ar": "تنفس بانتظام ولا تحبس أنفاسك", "en": "Breathe steadily, don't hold your breath" },
          { "ar": "شد عضلات بطنك طوال التمرين", "en": "Keep your core engaged throughout" }
