            "warning": { "ar": "ارفع الوسط قليلاً", "en": "Raise your hips slightly" },
            "danger": { "ar": "وسطك منخفض جداً! قد يؤذي ظهرك", "en": "Hips too low! May hurt your back" }
          }
        },
        {
          "joint": "left_shoulder",
          "role": "secondary",
          "startPose": { "min": 70, "max": 110 },
          "range": {
            "perfect": { "min": 80, "max": 100 },
            "normal": { "min": 70, "max": 110 },
            "pad": { "min": 60, "max": 120 }
          },
          "stateMessages": {
