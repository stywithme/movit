{
  "name": {
    "ar": "تمرين البلانك",
    "en": "Plank"
  },
  "description": {
    "ar": "تمرين لتقوية عضلات البطن والجذع عن طريق الثبات في وضع معين",
    "en": "Core strengthening exercise by holding a stable position"
  },
  "instructions": {
    "ar": "ارتكز على ساعديك وأصابع قدميك، حافظ على استقامة الجسم من الرأس للكعب",
    "en": "Rest on your forearms and toes, keep your body straight from head to heels"
  },
  "category": {
    "code": "core",
    "name": {
      "ar": "تمارين الجذع",
      "en": "Core"
    }
  },
  "countingMethod": "hold",
  "muscles": ["abs", "core", "shoulders", "back"],
  "equipment": ["bodyweight"],
  "tags": ["isometric", "beginner-friendly", "no-equipment"],
  "repCountingConfig": {
    "duration": 30,
    "gracePeriodMs": 2500
  },
  "poseVariants": [
    {
      "name": {
        "ar": "زاوية جانبية",
        "en": "Side View"
      },
      "cameraPosition": "prone_side",
      "expectedFacingDirection": "auto_detect",
      "positionChecks": [
        {
          "id": "body_alignment",
          "type": "vertical_alignment",
          "landmarks": {
            "primary": "left_shoulder",
            "secondary": "left_hip"
          },
          "condition": {
            "operator": "approximately_equal",
            "threshold": 0.08
          },
          "activePhases": ["all"],
          "errorMessage": {
            "ar": "حافظ على استقامة جسمك من الكتف للورك",
            "en": "Keep your body aligned from shoulder to hip"
          },
          "severity": "warning",
          "cooldownMs": 2000,
          "minErrorFrames": 5
        },
        {
          "id": "hip_sag_check",
          "type": "vertical_comparison",
          "landmarks": {
            "primary": "left_hip",
            "secondary": "left_ankle"
          },
          "condition": {
            "operator": "approximately_equal",
            "threshold": 0.10
          },
          "activePhases": ["all"],
          "errorMessage": {
            "ar": "لا تدع وسطك ينحني - شد عضلات البطن",
            "en": "Don't let your hips sag - engage your core"
          },
          "severity": "error",
          "cooldownMs": 2000,
          "minErrorFrames": 4
        },
        {
          "id": "hip_pike_check",
          "type": "vertical_comparison",
          "landmarks": {
            "primary": "left_shoulder",
            "secondary": "left_hip"
          },
          "condition": {
            "operator": "should_not_exceed",
            "threshold": 0.08
          },
          "activePhases": ["all"],
          "errorMessage": {
            "ar": "لا ترفع مؤخرتك للأعلى - حافظ على خط مستقيم",
            "en": "Don't pike your hips up - maintain a straight line"
          },
          "severity": "warning",
          "cooldownMs": 2500,
          "minErrorFrames": 4
        }
      ],
      "trackedJoints": [
        {
          "joint": "left_hip",
          "role": "primary",
          "startPose": { "min": 150, "max": 180 },
          "range": {
