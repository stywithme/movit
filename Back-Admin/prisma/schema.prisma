// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ATTRIBUTES (Lookup Tables)
// ============================================

/// Attribute types (category, muscle, equipment, tag, counting_method, etc.)
model Attribute {
  id          String   @id @default(uuid())
  code        String   @unique
  name        Json     // { "ar": "...", "en": "..." }
  description String?
  sortOrder   Int      @default(0)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  values AttributeValue[]

  @@map("attributes")
}

/// Attribute values (legs, chest, beginner, left_knee, etc.)
model AttributeValue {
  id          String   @id @default(uuid())
  attributeId String
  code        String   @unique
  name        Json     // { "ar": "...", "en": "..." }
  description Json?    // { "ar": "...", "en": "..." }
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  // Relations to exercises
  exercisesAsCategory      Exercise[]          @relation("ExerciseCategory")
  exercisesAsCountingMethod Exercise[]         @relation("ExerciseCountingMethod")
  exerciseAttributes       ExerciseAttribute[]
  difficultyLevelsAsType   DifficultyLevel[]   @relation("DifficultyLevelType")
  cameraPositionJoints     CameraPositionJoint[] @relation("CameraPositionJoint")

  @@index([attributeId])
  @@map("attribute_values")
}

// ============================================
// EXERCISES
// ============================================

/// Main exercise entity
model Exercise {
  id               String    @id @default(uuid())
  categoryId       String
  countingMethodId String
  name             Json      // { "ar": "...", "en": "..." }
  description      Json?     // { "ar": "...", "en": "..." }
  instructions     Json?     // { "ar": "...", "en": "..." }
  slug             String    @unique
  status           String    @default("draft") // draft, published
  
  // Rep counting config (unified - no difficulty levels)
  // { "reps": 12, "minRepIntervalMs": 1500, "maxRepIntervalMs": 5000 }
  // or { "duration": 30, "gracePeriodMs": 2500 } for hold exercises
  repCountingConfig Json?
  
  publishedAt      DateTime?
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  category         AttributeValue      @relation("ExerciseCategory", fields: [categoryId], references: [id])
  countingMethod   AttributeValue      @relation("ExerciseCountingMethod", fields: [countingMethodId], references: [id])
  attributes       ExerciseAttribute[]
  media            ExerciseMedia[]
  poseVariants     PoseVariant[]
  workoutExercises WorkoutExercise[]

  @@index([categoryId])
  @@index([countingMethodId])
  @@index([status])
  @@index([deletedAt])
  @@map("exercises")
}

/// Exercise attributes (muscles, equipment, tags - many-to-many)
model ExerciseAttribute {
  id               String   @id @default(uuid())
  exerciseId       String
  attributeValueId String
  createdAt        DateTime @default(now())

  exercise       Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, attributeValueId])
  @@index([exerciseId])
  @@index([attributeValueId])
  @@map("exercise_attributes")
}

/// Exercise media (images, videos)
model ExerciseMedia {
  id         String   @id @default(uuid())
  exerciseId String
  type       String   // image, video
  url        String
  altText    String?
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("exercise_media")
}

// ============================================
// CAMERA POSITIONS
// ============================================

/// Camera positions (front, side, back, etc.)
model CameraPosition {
  id          String   @id @default(uuid())
  code        String   @unique
  schemaCode  String?  // exported/mobile: side_view, front_view, back_view
  name        Json     // { "ar": "...", "en": "..." }
  description Json?    // { "ar": "...", "en": "..." }
  imageUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  joints       CameraPositionJoint[]
  poseVariants PoseVariant[]

  @@map("camera_positions")
}

/// Joints required for each camera position
model CameraPositionJoint {
  id               String   @id @default(uuid())
  cameraPositionId String
  jointId          String
  createdAt        DateTime @default(now())

  cameraPosition CameraPosition @relation(fields: [cameraPositionId], references: [id], onDelete: Cascade)
  joint          AttributeValue @relation("CameraPositionJoint", fields: [jointId], references: [id])

  @@unique([cameraPositionId, jointId])
  @@index([cameraPositionId])
  @@index([jointId])
  @@map("camera_position_joints")
}

// ============================================
// POSE VARIANTS
// ============================================

/// Pose variants (different camera positions for an exercise)
model PoseVariant {
  id                      String   @id @default(uuid())
  exerciseId              String
  cameraPositionId        String
  name                    Json     // { "ar": "...", "en": "..." }
  description             Json?    // { "ar": "...", "en": "..." }
  referenceImageUrl       String?
  
  expectedFacingDirection String?  // 'facing_right' | 'facing_left' | 'facing_camera' | 'facing_away' | 'auto_detect'
  
  // CORE CONFIGURATION (Source of Truth)
  // Contains: Primary/Secondary joints, Start Pose, Up/Down Ranges per difficulty
  trackedJointsConfig     Json?    

  sortOrder               Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  exercise         Exercise          @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  cameraPosition   CameraPosition    @relation(fields: [cameraPositionId], references: [id])
  
  difficultyLevels DifficultyLevel[]
  positionChecks   PositionCheck[]   
  feedbackMessages FeedbackMessage[] 

  @@index([exerciseId])
  @@index([cameraPositionId])
  @@map("pose_variants")
}

/// Position-based validation checks (knee over toe, hip alignment, etc.)
model PositionCheck {
  id              String   @id @default(uuid())
  poseVariantId   String
  checkId         String   // Unique within variant (e.g., "knee_over_toe")
  
  type            String   // PositionCheckType enum as string
  landmarks       Json     // { "primary": "left_knee", "secondary": "left_foot_index", ... }
  condition       Json     // { "operator": "should_not_exceed", "thresholds": { ... } }
  activePhases    Json     // ["down", "bottom"]
  errorMessage    Json     // { "ar": "...", "en": "..." }
  
  severity        String   @default("warning") // 'error' | 'warning' | 'tip'
  cooldownMs      Int      @default(2000)
  minErrorFrames  Int      @default(3)
  sortOrder       Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  poseVariant PoseVariant @relation(fields: [poseVariantId], references: [id], onDelete: Cascade)

  @@unique([poseVariantId, checkId])
  @@index([poseVariantId])
  @@map("position_checks")
}

// ============================================
// DIFFICULTY LEVELS
// ============================================

/// Difficulty levels for each pose variant
model DifficultyLevel {
  id               String   @id @default(uuid())
  poseVariantId    String
  difficultyTypeId String
  name             Json     // { "ar": "...", "en": "..." }
  description      Json?    // { "ar": "...", "en": "..." }
  
  repCountingConfig Json?   // { "reps": 12, "duration": 30, ... }
  phases            Json?   // ["start", "down", "up"] - Just the list required by Android
  romConfig         Json?   // Optional: General ROM info if needed
  
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  poseVariant      PoseVariant       @relation(fields: [poseVariantId], references: [id], onDelete: Cascade)
  difficultyType   AttributeValue    @relation("DifficultyLevelType", fields: [difficultyTypeId], references: [id])

  @@index([poseVariantId])
  @@index([difficultyTypeId])
  @@map("difficulty_levels")
}

// ============================================
// FEEDBACK MESSAGES
// ============================================

/// Feedback messages (motivational, tips, common mistakes)
model FeedbackMessage {
  id            String   @id @default(uuid())
  poseVariantId String
  type          String   // motivational, common_mistake, tip
  message       Json     // { "ar": "...", "en": "...", "audioAr": "...", "audioEn": "..." }
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  poseVariant PoseVariant @relation(fields: [poseVariantId], references: [id], onDelete: Cascade)

  @@index([poseVariantId])
  @@index([type])
  @@map("feedback_messages")
}

// ============================================
// WORKOUTS (Super Sets / Circuits)
// ============================================

/// Workout - Super Set or Circuit training session
model Workout {
  id                     String    @id @default(uuid())
  name                   Json      // { "ar": "...", "en": "..." }
  description            Json?     // { "ar": "...", "en": "..." }
  slug                   String    @unique
  
  // Workout configuration
  type                   String    // circuit | super_set
  executionMode          String    // sequential | alternating
  rounds                 Int       @default(1)
  repsPerSwitch          Int?      // For alternating mode: reps before switching exercise
  restBetweenSwitchMs    Int?      // For alternating mode: rest between switches
  restBetweenExercisesMs Int?      // For sequential mode: rest between exercises
  restBetweenRoundsMs    Int       @default(60000)
  
  // Status & metadata
  status                 String    @default("draft") // draft, published
  publishedAt            DateTime?
  createdBy              String?
  updatedBy              String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  exercises WorkoutExercise[]

  @@index([status])
  @@index([type])
  @@index([deletedAt])
  @@map("workouts")
}

/// WorkoutExercise - Exercise within a workout with specific configuration
model WorkoutExercise {
  id             String   @id @default(uuid())
  workoutId      String
  exerciseId     String
  
  // Exercise configuration for this workout
  variantIndex   Int      @default(0)    // Which pose variant to use
  difficulty     String   @default("beginner") // beginner, normal, advanced
  targetReps     Int?                     // Target reps (for rep-based exercises)
  targetDuration Int?                     // Target duration in seconds (for hold exercises)
  notes          Json?                    // { "ar": "...", "en": "..." } - Optional notes
  
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([workoutId])
  @@index([exerciseId])
  @@map("workout_exercises")
}

// ============================================
// ADMIN USERS (for audit trail)
// ============================================

/// Admin users for the dashboard
model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("admin") // admin, super_admin
  isActive  Boolean   @default(true)
  resetToken String?
  resetTokenExpiry DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("admins")
}

// ============================================
// MOBILE APP USERS
// ============================================

/// Mobile app users
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String?   // Nullable for OAuth users
  name            String
  avatarUrl       String?
  
  // OAuth providers
  googleId        String?   @unique
  provider        String    @default("email") // email, google
  
  // Settings
  preferredLanguage String  @default("en") // en, ar
  voiceFeedback     Boolean @default(true)
  notifications     Boolean @default(true)
  
  // Subscription
  isPro           Boolean   @default(false)
  subscriptionExpiry DateTime?
  
  // Stats
  totalWorkouts   Int       @default(0)
  totalMinutes    Int       @default(0)
  
  // Password reset
  resetToken      String?
  resetTokenExpiry DateTime?
  
  // Status
  isActive        Boolean   @default(true)
  emailVerified   Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // Refresh tokens for secure logout
  refreshTokens   RefreshToken[]

  @@index([email])
  @@index([googleId])
  @@map("users")
}

/// Refresh tokens for JWT authentication
model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  token       String   @unique
  deviceInfo  String?  // Device name/info for session management
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}
