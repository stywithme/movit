{
  "name": {
    "ar": "البلانك الجانبي",
    "en": "Side Plank"
  },
  "description": {
    "ar": "تمرين ثبات لتقوية عضلات الجذع الجانبية والكتف",
    "en": "Isometric exercise to strengthen obliques and shoulder"
  },
  "instructions": {
    "ar": "استلقِ على جانبك، ثم ارفع جسمك على ساعدك وحافظ على خط مستقيم من الرأس للقدمين",
    "en": "Lie on your side, lift body on forearm and maintain straight line from head to feet"
  },
  "category": {
    "code": "core",
    "name": {
      "ar": "تمارين الجذع",
      "en": "Core"
    }
  },
  "countingMethod": "hold",
