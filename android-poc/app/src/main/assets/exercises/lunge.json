            "advanced": { "min": 88, "max": 95 }
          },
          "movingSegment": {
            "from": "left_knee",
            "to": "left_hip",
            "invertArrow": true
          },
          "errorMessages": {
            "tooLow": {
              "ar": "لا تثني ركبتك كثيراً",
              "en": "Don't bend your knee too much"
            },
            "tooHigh": {
              "ar": "اثني ركبتك أكثر",
              "en": "Bend your knee more"
            }
          }
        },
        {
          "joint": "left_hip",
          "role": "secondary",
