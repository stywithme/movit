{
  "name": {
    "ar": "الاندفاع الأمامي",
    "en": "Forward Lunge"
  },
  "description": {
    "ar": "تمرين لتقوية عضلات الأرجل والتوازن",
    "en": "Exercise to strengthen leg muscles and improve balance"
  },
  "instructions": {
    "ar": "قف بشكل مستقيم، ثم اخطو للأمام واثني ركبتك حتى 90 درجة",
    "en": "Stand straight, step forward and bend your knee to 90 degrees"
  },
  "category": {
    "code": "legs",
    "name": {
      "ar": "تمارين الأرجل",
      "en": "Legs"
    }
  },
  "countingMethod": "up_down",
  "muscles": ["quadriceps", "glutes", "hamstrings", "calves"],
  "equipment": ["bodyweight", "dumbbell"],
  "tags": ["unilateral", "balance", "functional"],
  "poseVariants": [
    {
      "name": {
        "ar": "زاوية جانبية - الرجل اليسرى",
        "en": "Side View - Left Leg"
      },
      "cameraPosition": "side_view",
      "trackedJoints": [
        {
          "joint": "left_knee",
          "role": "primary",
          "startPose": {
            "min": 160,
            "max": 180
          },
          "upRange": {
            "beginner": { "min": 155, "max": 180 },
            "normal": { "min": 160, "max": 180 },
            "advanced": { "min": 165, "max": 180 }
