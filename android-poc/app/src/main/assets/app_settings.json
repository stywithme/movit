{
  "version": "1.1.0",
  "angleDetection": {
    "hysteresisDegrees": 5.0,
    "boundaryBufferDegrees": 3.0,
    "extremeErrorThresholdDegrees": 10.0
  },
  "movementDetection": {
    "smoothingWindowSize": 3,
    "angleChangeThresholdDegrees": 2.0
  },
  "defaults": {
    "minRepIntervalMs": 400,
    "maxRepIntervalMs": 5000,
    "minPhaseDurationMs": 100
  },
  "holdDefaults": {
    "defaultDurationSeconds": 30,
    "defaultGracePeriodMs": 3000
  },
  "smoothing": {
    "preset": "custom",
    "minCutoff": 3.0,
    "beta": 0.05,
    "useLegacyEMA": false,
    "legacyAlpha": 1.0
  },
  "visibility": {
    "angleCalculation": 0.6,
    "overlay": 0.5,
    "poseValidation": 0.6
  },
  "poseValidation": {
    "requiredValidFrames": 10,
    "minValidAngle": 15.0,
    "maxValidAngle": 175.0
  },
  "overlayOpacity": {
    "nonTracked": 0.1,
    "trackedCorrect": 0.30,
    "trackedError": 0.65
  }
}
