<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Top gradient (subtle) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#80040A01"
                android:centerColor="#00000000"
                android:endColor="#00000000"
                android:centerY="0.3" />
        </shape>
    </item>
    
    <!-- Bottom gradient (strong) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#E6040A01"
                android:centerColor="#99040A01"
                android:endColor="#00000000"
                android:centerY="0.5" />
        </shape>
    </item>
    
</layer-list>
