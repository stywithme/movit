<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base dark scrim across the entire image -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#4D000000" />
        </shape>
    </item>

    <!-- Left-side gradient — stronger where metrics sit -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#99000000"
                android:centerColor="#33000000"
                android:endColor="#00000000"
                android:centerX="0.35" />
        </shape>
    </item>

    <!-- Top gradient for exercise name readability -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#80000000"
                android:endColor="#00000000"
                android:centerY="0.2" />
        </shape>
    </item>

    <!-- Subtle bottom gradient for swipe hint -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#66000000"
                android:endColor="#00000000"
                android:centerY="0.15" />
        </shape>
    </item>

</layer-list>
