<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardExercise"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#2A2A2A"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Exercise Icon -->
        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🏋️"
            android:textSize="32sp"
            android:gravity="center"
            android:background="@drawable/circle_background"
            android:layout_gravity="center_horizontal" />

        <!-- Exercise Name (English) -->
        <TextView
            android:id="@+id/tvExerciseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Squat"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginTop="12dp" />

        <!-- Exercise Name (Arabic) -->
        <TextView
            android:id="@+id/tvExerciseNameAr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="القرفصاء"
            android:textColor="#00E676"
            android:textSize="14sp"
            android:textAlignment="center"
            android:layout_marginTop="4dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#3A3A3A"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Category -->
        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Legs"
            android:textColor="#888888"
            android:textSize="12sp"
            android:drawableStart="@drawable/ic_category"
            android:drawablePadding="8dp"
            app:drawableTint="#888888" />

        <!-- Muscles -->
        <TextView
            android:id="@+id/tvMuscles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Glutes, Hamstrings"
            android:textColor="#888888"
            android:textSize="12sp"
            android:drawableStart="@drawable/ic_muscle"
            android:drawablePadding="8dp"
            android:layout_marginTop="4dp"
            app:drawableTint="#888888" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
