<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Header: screen title + short subtitle + profile avatar -->
    <LinearLayout
        style="@style/Widget.WayToFix.Header.MainTab">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/TextAppearance.WayToFix.Headline2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reports_title"
                android:textColor="@color/text_primary" />

            <TextView
                style="@style/TextAppearance.WayToFix.Body2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/main_tab_header_reports_subtitle"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAvatar"
            style="@style/Widget.WayToFix.Avatar.Small"
            android:contentDescription="@string/cd_avatar"
            android:src="@drawable/ic_person" />
    </LinearLayout>

    <!-- Tabs: Overview | Exercises | Trends -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_base"
        android:background="@android:color/transparent"
        app:tabIndicatorColor="@color/primary"
        app:tabIndicatorFullWidth="false"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/primary"
        app:tabTextColor="@color/text_tertiary" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- ViewPager2 for tab content -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:id="@+id/layoutReportsState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                android:paddingBottom="@dimen/spacing_4xl"
                android:visibility="gone"
                tools:visibility="visible">

                <ProgressBar
                    android:id="@+id/progressReportsState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="@color/primary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvReportsStateTitle"
                    style="@style/TextAppearance.WayToFix.Headline3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_base"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    tools:text="@string/reports_state_empty_title" />

                <TextView
                    android:id="@+id/tvReportsStateMessage"
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    tools:text="@string/reports_state_empty_message" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReportsStateAction"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:text="@string/reports_state_retry"
                    android:textColor="@color/on_primary"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="@dimen/radius_full" />

            </LinearLayout>
        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
