<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:padding="@dimen/spacing_xl">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_xl">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_settings"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_md"
            android:text="@string/training_settings"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnCloseSettings"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="@color/text_hint" />

    </LinearLayout>

    <!-- Visual Indicator Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/visual_indicator"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_lg">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIndicatorLine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:text="@string/indicator_line"
            style="@style/Widget.WayToFix.Button.Secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIndicatorArc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="@string/indicator_arc"
            style="@style/Widget.WayToFix.Button.Secondary" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/surface_border"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Sound Settings Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_lg">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_feedback"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_feedback_desc"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchVoiceFeedback"
            style="@style/Widget.WayToFix.Switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/surface_border"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- MediaPipe Model Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/detection_model"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:text="@string/detection_model_desc"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_lg">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModelFull"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:text="@string/model_full"
            style="@style/Widget.WayToFix.Button.Secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModelHeavy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="@string/model_heavy"
            style="@style/Widget.WayToFix.Button.Secondary" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/dividerCamera"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/surface_border"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Camera Settings Section (only visible in camera mode) -->
    <LinearLayout
        android:id="@+id/cameraSectionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_lg">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_position"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvCurrentCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/front_camera"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSwitchCameraDialog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/switch_text"
            style="@style/Widget.WayToFix.Button.Secondary"
            app:icon="@drawable/ic_switch_camera"
            app:iconGravity="textStart"
            app:iconSize="24dp"
            app:iconTint="@color/text_primary" />

    </LinearLayout>

    <!-- Apply Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplySettings"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="@string/apply"
        style="@style/Widget.WayToFix.Button.Primary" />

</LinearLayout>
