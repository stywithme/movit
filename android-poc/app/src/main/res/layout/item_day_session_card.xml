<?xml version="1.0" encoding="utf-8"?>
<!-- A single session card within the day view.
     Can be collapsed (header only) or expanded (header + timeline items). -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardSession"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="1dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══ Session Header (always visible) ═══ -->
        <LinearLayout
            android:id="@+id/layoutSessionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_base"
            android:paddingVertical="16dp">

            <!-- Status indicator dot -->
            <View
                android:id="@+id/viewStatusDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_dot" />

            <!-- Session info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSessionName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Upper Body Strength" />

                <TextView
                    android:id="@+id/tvSessionMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    tools:text="6 exercises · ~25 min" />
            </LinearLayout>

            <!-- Session status badge -->
            <TextView
                android:id="@+id/tvSessionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_accent"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/on_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Completed"
                tools:visibility="visible" />

            <!-- Expand/collapse icon -->
            <ImageView
                android:id="@+id/ivExpandIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:src="@drawable/ic_expand_more"
                app:tint="@color/text_hint" />
        </LinearLayout>

        <!-- ═══ Expanded Content ═══ -->
        <LinearLayout
            android:id="@+id/layoutExpandedContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="@dimen/spacing_base"
                android:background="@color/divider" />

            <!-- Session edit bar (only in edit mode) -->
            <LinearLayout
                android:id="@+id/layoutSessionEditBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_base"
                android:paddingVertical="@dimen/spacing_sm"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRenameSession"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/ds_rename"
                    android:textColor="@color/primary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteSession"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/ds_delete"
                    android:textColor="@color/error"
                    android:textSize="13sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/btnMoveSessionUp"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Move up"
                    android:src="@drawable/ic_arrow_up"
                    app:tint="@color/text_secondary" />

                <ImageButton
                    android:id="@+id/btnMoveSessionDown"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Move down"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <!-- Timeline items container -->
            <LinearLayout
                android:id="@+id/layoutTimelineItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_base"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_base" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
