<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/listCard"
    style="@style/Widget.WayToFix.Card.List"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="@dimen/component_card_min_height"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_base">

        <FrameLayout
            android:id="@+id/listCardIconContainer"
            android:layout_width="@dimen/component_icon_container"
            android:layout_height="@dimen/component_icon_container"
            android:background="@drawable/bg_component_icon_container"
            android:foregroundGravity="center">

            <ImageView
                android:id="@+id/listCardIcon"
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:layout_gravity="center"
                android:contentDescription="@null"
                app:tint="@color/primary"
                tools:src="@drawable/ic_exercise" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_base"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/listCardTitle"
                style="@style/TextAppearance.WayToFix.Headline3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                tools:text="Card title" />

            <TextView
                android:id="@+id/listCardSubtitle"
                style="@style/TextAppearance.WayToFix.Body2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textColor="@color/text_secondary"
                tools:text="Supporting text goes here" />
        </LinearLayout>

        <ImageView
            android:id="@+id/listCardTrailingIcon"
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:layout_marginStart="@dimen/spacing_md"
            android:contentDescription="@null"
            android:src="@drawable/ic_arrow_forward"
            app:tint="@color/text_tertiary" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
