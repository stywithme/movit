<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_3xl"
            android:paddingBottom="100dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                android:paddingBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        style="@style/TextAppearance.WayToFix.Body1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        tools:text="@string/greeting_morning" />

                    <TextView
                        android:id="@+id/tvUserName"
                        style="@style/TextAppearance.WayToFix.Headline2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="Mahmoud" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="2dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/text_secondary"
                    android:contentDescription="@string/cd_profile" />

            </LinearLayout>

            <!-- Quick Stats Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_base">

                    <!-- This Week -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvWeeklyWorkouts"
                            style="@style/TextAppearance.WayToFix.Headline1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/primary"
                            tools:text="5" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/this_week"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/surface_border" />

                    <!-- Form Score -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFormScore"
                            style="@style/TextAppearance.WayToFix.Headline1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/success"
                            tools:text="87%" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/weekly_average"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/surface_border" />

                    <!-- Streak -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvStreak"
                            style="@style/TextAppearance.WayToFix.Headline1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/warning"
                            tools:text="12" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/streak"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- My Level Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMyLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="#1A1A2E"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_base">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.WayToFix.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Level"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvLevelName"
                            style="@style/TextAppearance.WayToFix.Headline2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@android:color/white"
                            android:layout_marginTop="2dp"
                            tools:text="Level 3 — Intermediate" />

                        <TextView
                            android:id="@+id/tvLevelScore"
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"
                            tools:text="Body Score: 52" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textColor="@android:color/white"
                        android:textSize="24sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Active Program Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardActiveProgram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <TextView
                        android:id="@+id/tvActiveProgramLabel"
                        style="@style/TextAppearance.WayToFix.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/active_program"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvActiveProgramName"
                        style="@style/TextAppearance.WayToFix.Headline3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        tools:text="Full Body 4-Week Challenge" />

                    <TextView
                        android:id="@+id/tvActiveProgramStats"
                        style="@style/TextAppearance.WayToFix.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        tools:text="4 weeks · 5 sessions" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewProgram"
                        style="@style/Widget.WayToFix.Button.Primary"
                        android:layout_width="180dp"
                        android:layout_height="44dp"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:text="@string/view_program" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Today's Plan -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTodayPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <TextView
                        android:id="@+id/tvTodayPlanLabel"
                        style="@style/TextAppearance.WayToFix.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/today_plan"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvTodayPlanTitle"
                        style="@style/TextAppearance.WayToFix.Headline3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        tools:text="Week 1 · Day 2" />

                    <TextView
                        android:id="@+id/tvTodayPlanSubtitle"
                        style="@style/TextAppearance.WayToFix.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/spacing_xs"
                        tools:text="Morning Session • 5 items" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartTodayPlan"
                        style="@style/Widget.WayToFix.Button.Primary"
                        android:layout_width="180dp"
                        android:layout_height="44dp"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:text="@string/start_session" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ======================= RECENT REPORTS SECTION ======================= -->
            <LinearLayout
                android:id="@+id/recentReportsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_xl">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal">

                    <TextView
                        style="@style/TextAppearance.WayToFix.Headline3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recent_reports"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvViewAllReports"
                        style="@style/TextAppearance.WayToFix.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/view_all"
                        android:textColor="@color/primary" />

                </LinearLayout>

                <!-- Reports RecyclerView (Horizontal) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentReports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_report_card"
                    tools:itemCount="3" />

                <!-- Empty State for Reports -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/emptyReportsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_base"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_xl">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_report"
                            app:tint="@color/text_hint"
                            android:contentDescription="@null" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/no_reports_yet"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/complete_workout_for_report"
                            android:textColor="@color/text_hint"
                            android:textAlignment="center" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ======================= WORKOUTS SECTION ======================= -->
            <LinearLayout
                android:id="@+id/workoutsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_xl">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal">

                    <TextView
                        style="@style/TextAppearance.WayToFix.Headline3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/workouts"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvViewAllWorkouts"
                        style="@style/TextAppearance.WayToFix.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/view_all"
                        android:textColor="@color/primary" />

                </LinearLayout>

                <!-- Workouts RecyclerView (Horizontal) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvWorkouts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_workout_card"
                    tools:itemCount="3" />

                <!-- Empty State for Workouts -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/emptyWorkoutsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_base"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_xl">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_workout"
                            app:tint="@color/text_hint"
                            android:contentDescription="@null" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/no_workouts_yet"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ======================= RECENT EXERCISES SECTION ======================= -->
            <LinearLayout
                android:id="@+id/recentExercisesSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_xl">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal">

                    <TextView
                        style="@style/TextAppearance.WayToFix.Headline3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/recent_exercises"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvViewAllExercises"
                        style="@style/TextAppearance.WayToFix.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/view_all"
                        android:textColor="@color/primary" />

                </LinearLayout>

                <!-- Exercises RecyclerView (Horizontal) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentExercises"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_exercise_card"
                    tools:itemCount="4" />

                <!-- Empty State for Exercises -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/emptyExercisesCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_base"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_xl">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_muscle"
                            app:tint="@color/text_hint"
                            android:contentDescription="@null" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/no_exercises_yet"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/start_exercise_hint"
                            android:textColor="@color/text_hint"
                            android:textAlignment="center" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ======================= QUICK ACTIONS ======================= -->
            <TextView
                style="@style/TextAppearance.WayToFix.Headline3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/quick_actions"
                android:textColor="@color/text_primary" />

            <!-- Body Scan CTA (prominent, full-width) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBodyScan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardBackgroundColor="#1B5E20"
                app:cardCornerRadius="@dimen/radius_base"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.WayToFix.Headline3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/body_scan_title"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/body_scan_subtitle"
                            android:textColor="#A5D6A7" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textColor="@android:color/white"
                        android:textSize="24sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal">

                <!-- Start Camera -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardStartCamera"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    app:cardBackgroundColor="@color/primary"
                    app:cardCornerRadius="@dimen/radius_base"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/on_primary"
                            android:contentDescription="@string/cd_camera" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/start_camera"
                            android:textColor="@color/on_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Analyze Video -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAnalyzeVideo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_sm"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_base"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_video"
                            app:tint="@color/text_secondary"
                            android:contentDescription="@string/cd_video" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/analyze_video"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Hidden views for backward compatibility -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardContinue"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:id="@+id/tvLastExercise" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                    <TextView android:id="@+id/tvLastProgress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnContinue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
