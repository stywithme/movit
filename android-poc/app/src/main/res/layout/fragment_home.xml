<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_3xl"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                android:paddingBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        style="@style/TextAppearance.WayToFix.Body1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        tools:text="@string/greeting_morning" />

                    <TextView
                        android:id="@+id/tvUserName"
                        style="@style/TextAppearance.WayToFix.Headline2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="Mahmoud" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="2dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/text_secondary"
                    android:contentDescription="@string/cd_profile" />

            </LinearLayout>

            <!-- Quick Stats Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_base">

                    <!-- This Week -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvWeeklyWorkouts"
                            style="@style/TextAppearance.WayToFix.Headline1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/primary"
                            tools:text="5" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/this_week"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/surface_border" />

                    <!-- Form Score -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFormScore"
                            style="@style/TextAppearance.WayToFix.Headline1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/success"
                            tools:text="87%" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/weekly_average"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/surface_border" />

                    <!-- Streak -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvStreak"
                            style="@style/TextAppearance.WayToFix.Headline1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/warning"
                            tools:text="12🔥" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/streak"
                            android:textColor="@color/text_tertiary" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Continue Training Section -->
            <TextView
                style="@style/TextAppearance.WayToFix.Headline3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/continue_training"
                android:textColor="@color/text_primary" />

            <!-- Last Workout Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardContinue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_base"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_base">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_circle_surface"
                        android:padding="12dp"
                        android:src="@drawable/ic_muscle"
                        app:tint="@color/primary"
                        android:contentDescription="@string/cd_exercise" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvLastExercise"
                            style="@style/TextAppearance.WayToFix.Body1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            tools:text="@string/sample_exercise_squats" />

                        <TextView
                            android:id="@+id/tvLastProgress"
                            style="@style/TextAppearance.WayToFix.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_tertiary"
                            tools:text="2/3 sets completed" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnContinue"
                        style="@style/Widget.WayToFix.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/start"
                        android:textSize="14sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Quick Actions -->
            <TextView
                style="@style/TextAppearance.WayToFix.Headline3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/quick_actions"
                android:textColor="@color/text_primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal">

                <!-- Start Camera -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardStartCamera"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    app:cardBackgroundColor="@color/primary"
                    app:cardCornerRadius="@dimen/radius_base"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/on_primary"
                            android:contentDescription="@string/cd_camera" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/start_camera"
                            android:textColor="@color/on_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Analyze Video -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAnalyzeVideo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_sm"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_base"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_video"
                            app:tint="@color/text_secondary"
                            android:contentDescription="@string/cd_video" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/analyze_video"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
