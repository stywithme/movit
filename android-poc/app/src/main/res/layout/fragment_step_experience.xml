<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.onboarding.steps.StepExperienceFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xl">

        <TextView
            style="@style/TextAppearance.WayToFix.Headline1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onb_experience_title" />

        <TextView
            style="@style/TextAppearance.WayToFix.Body2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/onb_experience_subtitle" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBeginner"
            style="@style/Widget.WayToFix.ChoiceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_base">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <TextView
                    style="@style/TextAppearance.WayToFix.Body1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onb_exp_beginner_title"
                    android:textStyle="bold" />

                <TextView
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xxs"
                    android:text="@string/onb_exp_beginner_desc" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIntermediate"
            style="@style/Widget.WayToFix.ChoiceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <TextView
                    style="@style/TextAppearance.WayToFix.Body1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onb_exp_intermediate_title"
                    android:textStyle="bold" />

                <TextView
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xxs"
                    android:text="@string/onb_exp_intermediate_desc" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAdvanced"
            style="@style/Widget.WayToFix.ChoiceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <TextView
                    style="@style/TextAppearance.WayToFix.Body1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onb_exp_advanced_title"
                    android:textStyle="bold" />

                <TextView
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xxs"
                    android:text="@string/onb_exp_advanced_desc" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/TextAppearance.WayToFix.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/onb_days_label" />

        <TextView
            android:id="@+id/tvDaysValue"
            style="@style/TextAppearance.WayToFix.Display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:textColor="@color/primary"
            tools:text="3 days / week" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:stepSize="1"
            android:valueFrom="1"
            android:valueTo="7"
            app:haloColor="@color/primary_light"
            app:thumbColor="@color/primary"
            app:tickColorInactive="@color/surface_border"
            app:trackColorActive="@color/primary"
            app:trackColorInactive="@color/surface_variant" />

    </LinearLayout>

</ScrollView>
