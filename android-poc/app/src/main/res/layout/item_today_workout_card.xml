<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardWorkout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_base"
    app:cardElevation="0dp"
    app:strokeColor="@color/surface_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Session Header (always visible, clickable to expand/collapse) -->
        <LinearLayout
            android:id="@+id/layoutWorkoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_base">

            <!-- Status indicator -->
            <View
                android:id="@+id/viewStatusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_dot"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <!-- Session info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWorkoutName"
                    style="@style/TextAppearance.WayToFix.Body1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    tools:text="Morning Workout" />

                <TextView
                    android:id="@+id/tvWorkoutMeta"
                    style="@style/TextAppearance.WayToFix.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_secondary"
                    tools:text="5 exercises · ~20 min" />
            </LinearLayout>

            <!-- Status badge / expand icon -->
            <TextView
                android:id="@+id/tvWorkoutStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_pill_background"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="2dp"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="✅ Done"
                tools:visibility="visible" />

            <ImageView
                android:id="@+id/ivExpandIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="@dimen/spacing_xs"
                android:contentDescription="@null"
                android:src="@drawable/ic_expand_more"
                app:tint="@color/text_hint" />
        </LinearLayout>

        <!-- Expandable Content -->
        <LinearLayout
            android:id="@+id/layoutWorkoutContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_base"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface_border" />

            <!-- Session items (first 4 + "more" indicator) -->
            <LinearLayout
                android:id="@+id/layoutWorkoutItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="vertical" />

            <!-- "+X more items" text -->
            <TextView
                android:id="@+id/tvMoreItems"
                style="@style/TextAppearance.WayToFix.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textColor="@color/text_hint"
                android:visibility="gone"
                tools:text="+2 more items"
                tools:visibility="visible" />

            <!-- Start / Continue / Completed button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWorkoutAction"
                style="@style/Widget.WayToFix.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_base"
                android:text="@string/pg_start_planned_workout" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
