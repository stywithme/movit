<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="224dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_base"
    app:cardElevation="0dp"
    app:strokeColor="@color/surface_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="172dp"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_surface">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/workouts"
                    android:src="@drawable/ic_workout"
                    app:tint="@color/primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvWorkoutType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_chip_accent"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:textColor="@color/on_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Beginner" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvWorkoutName"
            style="@style/TextAppearance.WayToFix.Headline3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            tools:text="Core Crusher Express" />

        <TextView
            android:id="@+id/tvWorkoutMeta"
            style="@style/TextAppearance.WayToFix.Body2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/text_secondary"
            tools:text="6 exercises · ~20 min" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>