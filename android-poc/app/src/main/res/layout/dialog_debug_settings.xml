<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:padding="16dp">

    <!-- Header & Info Toggle -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Debug Settings"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_centerVertical="true" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchDebugInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Info Panel"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="16dp" />

    <!-- Input Mode Selector -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Input Source"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/inputModeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layout_marginBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModeCamera"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Camera"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#88FFFFFF"
            android:textColor="@android:color/white"
            app:cornerRadius="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModeVideo"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Video"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#88FFFFFF"
            android:textColor="@android:color/white"
            app:cornerRadius="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModeImage"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Image"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#88FFFFFF"
            android:textColor="@android:color/white"
            app:cornerRadius="4dp" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickFile"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="Pick File"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:strokeColor="#88FFFFFF"
        app:cornerRadius="4dp"
        android:visibility="gone" />

    <!-- Tab Selector -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Test Mode"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabTextColor="#88FFFFFF"
        app:tabSelectedTextColor="@android:color/white"
        app:tabIndicatorColor="@android:color/white"
        app:tabIndicatorHeight="2dp"
        app:tabBackground="@android:color/transparent"
        android:background="@android:color/transparent">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Elbows" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Angle Lab" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Positions" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scene" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MLP" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Config Containers -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <!-- Joint Angles Config -->
        <LinearLayout
            android:id="@+id/jointAngleConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Joint:"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinnerJoint"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:backgroundTint="@android:color/white"
                android:popupBackground="#333333" />
        </LinearLayout>

        <!-- Position Check Config -->
        <LinearLayout
            android:id="@+id/positionCheckConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content" android:text="Type:" android:textColor="@android:color/white" android:textSize="12sp" />
                <Spinner android:id="@+id/spinnerCheckType" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:backgroundTint="@android:color/white" android:popupBackground="#333333" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content" android:text="Primary:" android:textColor="@android:color/white" android:textSize="12sp" />
                <Spinner android:id="@+id/spinnerPrimary" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:backgroundTint="@android:color/white" android:popupBackground="#333333" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content" android:text="Secondary:" android:textColor="@android:color/white" android:textSize="12sp" />
                <Spinner android:id="@+id/spinnerSecondary" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:backgroundTint="@android:color/white" android:popupBackground="#333333" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content" android:text="Operator:" android:textColor="@android:color/white" android:textSize="12sp" />
                <Spinner android:id="@+id/spinnerOperator" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:backgroundTint="@android:color/white" android:popupBackground="#333333" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content" android:text="Threshold:" android:textColor="@android:color/white" android:textSize="12sp" />
                <EditText android:id="@+id/etThreshold" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:text="0.05" android:textColor="@android:color/white" android:textSize="13sp" android:fontFamily="monospace" android:inputType="numberDecimal|numberSigned" android:background="@android:color/transparent" android:paddingStart="8dp" android:hint="0.05" android:textColorHint="#66FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Pose Scene Config (3 independent axes) -->
        <LinearLayout
            android:id="@+id/cameraDetectionConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Posture:"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinnerExpectedCamPos"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:backgroundTint="@android:color/white"
                    android:popupBackground="#333333" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Direction:"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinnerExpectedDirection"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:backgroundTint="@android:color/white"
                    android:popupBackground="#333333" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Region:"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinnerExpectedRegion"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:backgroundTint="@android:color/white"
                    android:popupBackground="#333333" />
            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>