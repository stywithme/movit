<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_base"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_base">

        <TextView
            android:id="@+id/tvReplaceName"
            style="@style/TextAppearance.WayToFix.Body1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:text="Push-ups" />

        <TextView
            android:id="@+id/tvReplaceHint"
            style="@style/TextAppearance.WayToFix.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:text="Same muscles, less strain" />

        <TextView
            android:id="@+id/tvReplaceBadge"
            style="@style/TextAppearance.WayToFix.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_chip_accent"
            android:textColor="@color/on_primary"
            android:text="@string/replace_recommended"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
