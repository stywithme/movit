<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardWorkout"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_xs"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_base"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:id="@+id/ivWorkoutImage"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/surface_variant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvWorkoutType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_accent"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs"
                android:text="@string/workout_type_circuit"
                android:textColor="@color/on_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="CIRCUIT" />

            <TextView
                android:id="@+id/tvWorkoutName"
                style="@style/TextAppearance.WayToFix.Body1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                tools:text="Full Body Blast" />

            <TextView
                android:id="@+id/tvWorkoutDescription"
                style="@style/TextAppearance.WayToFix.Body2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/text_secondary"
                tools:text="High intensity circuit to build strength." />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvExerciseCount"
                    style="@style/TextAppearance.WayToFix.Caption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_tertiary"
                    tools:text="6 exercises" />

                <TextView
                    android:id="@+id/tvDuration"
                    style="@style/TextAppearance.WayToFix.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary"
                    tools:text="35 min" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
