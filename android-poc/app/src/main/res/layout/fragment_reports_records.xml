<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="100dp">

        <!-- Personal Bests Section -->
        <TextView
            style="@style/TextAppearance.WayToFix.Headline3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reports_personal_records"
            android:textColor="@color/text_primary" />

        <!-- Best Form Score -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_base"
            app:cardElevation="0dp"
            app:strokeColor="@color/surface_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_base">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.WayToFix.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reports_best_form_score"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvBestFormScoreContext"
                        style="@style/TextAppearance.WayToFix.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_hint"
                        tools:text="Week 3, Bicep Curl" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvBestFormScore"
                    style="@style/TextAppearance.WayToFix.Headline2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/success"
                    tools:text="96%" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Longest Streak -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_base"
            app:cardElevation="0dp"
            app:strokeColor="@color/surface_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_base">

                <TextView
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/reports_longest_streak"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvLongestStreak"
                    style="@style/TextAppearance.WayToFix.Headline2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    tools:text="7" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Most Reps -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_base"
            app:cardElevation="0dp"
            app:strokeColor="@color/surface_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_base">

                <TextView
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/reports_most_reps"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvMostReps"
                    style="@style/TextAppearance.WayToFix.Headline2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    tools:text="15" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Program Grade -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_base"
            app:cardElevation="0dp"
            app:strokeColor="@color/surface_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_base">

                <TextView
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pg_grade_label"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvProgramGrade"
                    style="@style/TextAppearance.WayToFix.Headline2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    tools:text="B+" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
