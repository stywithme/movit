<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardHistory"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_base"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_base">

        <!-- Exercise Icon -->
        <ImageView
            android:id="@+id/ivExerciseIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_surface"
            android:padding="10dp"
            android:src="@drawable/ic_muscle"
            app:tint="@color/primary"
            android:contentDescription="@string/cd_exercise" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvExerciseName"
                style="@style/TextAppearance.WayToFix.Body1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                tools:text="Squats" />

            <TextView
                android:id="@+id/tvDate"
                style="@style/TextAppearance.WayToFix.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_tertiary"
                tools:text="Today, 10:30 AM" />

        </LinearLayout>

        <!-- Score -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvScore"
                style="@style/TextAppearance.WayToFix.Headline3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/success"
                tools:text="92%" />

            <TextView
                style="@style/TextAppearance.WayToFix.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/accuracy"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Arrow -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/text_tertiary"
            android:contentDescription="@string/cd_view_details" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
