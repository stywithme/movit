<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true"
    tools:context=".ui.ExerciseDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="#1E1E1E">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Exercise Details"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp" />

        </LinearLayout>

        <!-- Exercise Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="#2A2A2A"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Exercise Icon & Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:text="🏋️"
                        android:textSize="40sp"
                        android:gravity="center"
                        android:background="@drawable/circle_background" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/tvExerciseName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Squat"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvExerciseNameAr"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="القرفصاء"
                            android:textColor="#00E676"
                            android:textSize="16sp" />

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#3A3A3A"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <!-- Exercise Details -->
                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Legs"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:drawableStart="@drawable/ic_category"
                    android:drawablePadding="12dp"
                    app:drawableTint="#888888" />

                <TextView
                    android:id="@+id/tvMuscles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Glutes, Hamstrings"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:drawableStart="@drawable/ic_muscle"
                    android:drawablePadding="12dp"
                    android:layout_marginTop="8dp"
                    app:drawableTint="#888888" />

                <TextView
                    android:id="@+id/tvEquipment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bodyweight"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:drawableStart="@drawable/ic_equipment"
                    android:drawablePadding="12dp"
                    android:layout_marginTop="8dp"
                    app:drawableTint="#888888" />

                <TextView
                    android:id="@+id/tvCountingMethod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Up &amp; Down"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:drawableStart="@drawable/ic_counter"
                    android:drawablePadding="12dp"
                    android:layout_marginTop="8dp"
                    app:drawableTint="#888888" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Difficulty Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Difficulty Level"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBeginner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Beginner"
                android:textSize="12sp"
                app:cornerRadius="8dp"
                app:backgroundTint="#4CAF50"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNormal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Normal"
                android:textSize="12sp"
                app:cornerRadius="8dp"
                app:backgroundTint="#FF9800"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdvanced"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Advanced"
                android:textSize="12sp"
                app:cornerRadius="8dp"
                app:backgroundTint="#F44336"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- Target & Tolerance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tvTargetReps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Target: 12 reps"
                android:textColor="#00E676"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTolerance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tolerance: ±15°"
                android:textColor="#FFD700"
                android:textSize="14sp"
                android:textAlignment="textEnd" />

        </LinearLayout>

        <!-- Pose Variant Selection -->
        <LinearLayout
            android:id="@+id/variantSelector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Camera Position"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVariant1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Variant 1"
                    android:textSize="11sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVariant2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Variant 2"
                    android:textSize="11sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_marginStart="4dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- Tracked Joints Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tracked Joints"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp">

            <TextView
                android:id="@+id/tvTrackedJoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:padding="16dp"
                android:lineSpacingExtra="4dp" />

        </androidx.cardview.widget.CardView>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Visual Indicator Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Visual Indicator"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIndicatorLine"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📏 Line"
                android:textSize="14sp"
                android:textStyle="bold"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#00E676"
                app:strokeWidth="2dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIndicatorArc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⭕ Arc"
                android:textSize="14sp"
                android:textStyle="bold"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#2196F3"
                app:strokeWidth="2dp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartCamera"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_margin="16dp"
            android:text="@string/start_exercise"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:backgroundTint="#00E676" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
