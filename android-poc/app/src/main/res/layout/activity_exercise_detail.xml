<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="@dimen/spacing_2xl"
    tools:context=".ui.exercises.ExerciseDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/screen_padding_vertical"
        android:paddingBottom="@dimen/spacing_2xl">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/app_header_height"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_back"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_primary" />

            <TextView
                style="@style/TextAppearance.WayToFix.Headline3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:text="@string/exercise_detail_title"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Exercise Info Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.WayToFix.Card.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_component_icon_container">

                        <ImageView
                            android:layout_width="@dimen/icon_lg"
                            android:layout_height="@dimen/icon_lg"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_muscle"
                            app:tint="@color/primary" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_base"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvExerciseName"
                            style="@style/TextAppearance.WayToFix.Headline2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            tools:text="Squat" />

                        <TextView
                            android:id="@+id/tvExerciseNameAr"
                            style="@style/TextAppearance.WayToFix.Body1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:textColor="@color/primary"
                            tools:text="القرفصاء" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/border_thin"
                    android:layout_marginVertical="@dimen/spacing_base"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/tvCategory"
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_category"
                    android:drawablePadding="@dimen/spacing_md"
                    android:textColor="@color/text_secondary"
                    app:drawableTint="@color/text_tertiary"
                    tools:text="Legs" />

                <TextView
                    android:id="@+id/tvMuscles"
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:drawableStart="@drawable/ic_muscle"
                    android:drawablePadding="@dimen/spacing_md"
                    android:textColor="@color/text_secondary"
                    app:drawableTint="@color/text_tertiary"
                    tools:text="Glutes, Hamstrings" />

                <TextView
                    android:id="@+id/tvEquipment"
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:drawableStart="@drawable/ic_equipment"
                    android:drawablePadding="@dimen/spacing_md"
                    android:textColor="@color/text_secondary"
                    app:drawableTint="@color/text_tertiary"
                    tools:text="Bodyweight" />

                <TextView
                    android:id="@+id/tvCountingMethod"
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:drawableStart="@drawable/ic_counter"
                    android:drawablePadding="@dimen/spacing_md"
                    android:textColor="@color/text_secondary"
                    app:drawableTint="@color/text_tertiary"
                    tools:text="Up &amp; Down" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Difficulty Selection -->
        <TextView
            style="@style/TextAppearance.WayToFix.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/difficulty_level"
            android:textColor="@color/text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBeginner"
                style="@style/Widget.WayToFix.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_small"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:layout_weight="1"
                android:text="@string/display_mode_beginner" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNormal"
                style="@style/Widget.WayToFix.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_small"
                android:layout_marginHorizontal="@dimen/spacing_xs"
                android:layout_weight="1"
                android:text="@string/medium" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdvanced"
                style="@style/Widget.WayToFix.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_small"
                android:layout_marginStart="@dimen/spacing_xs"
                android:layout_weight="1"
                android:text="@string/display_mode_advanced" />
        </LinearLayout>

        <!-- Target & Tolerance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTargetReps"
                style="@style/TextAppearance.WayToFix.Body2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/primary"
                tools:text="Target: 12 reps" />

            <TextView
                android:id="@+id/tvTolerance"
                style="@style/TextAppearance.WayToFix.Body2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAlignment="textEnd"
                android:textColor="@color/text_tertiary"
                tools:text="Unified evaluation" />
        </LinearLayout>

        <!-- Pose Variant Selection -->
        <LinearLayout
            android:id="@+id/variantSelector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                style="@style/TextAppearance.WayToFix.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/camera_position"
                android:textColor="@color/text_secondary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVariant1"
                    style="@style/Widget.WayToFix.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:layout_weight="1"
                    android:visibility="gone"
                    tools:text="Front" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVariant2"
                    style="@style/Widget.WayToFix.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_weight="1"
                    android:visibility="gone"
                    tools:text="Side" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tracked Joints Info -->
        <TextView
            style="@style/TextAppearance.WayToFix.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/tracked_joints"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.WayToFix.Card.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvTrackedJoints"
                style="@style/TextAppearance.WayToFix.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="@dimen/spacing_xs"
                android:padding="@dimen/spacing_base"
                android:textColor="@color/text_secondary"
                tools:text="Loading..." />
        </com.google.android.material.card.MaterialCardView>

        <!-- Visual Indicator Selection -->
        <TextView
            style="@style/TextAppearance.WayToFix.Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/visual_indicator"
            android:textColor="@color/text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIndicatorLine"
                style="@style/Widget.WayToFix.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_small"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:text="@string/indicator_line"
                app:strokeColor="@color/primary"
                app:strokeWidth="@dimen/border_thick" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIndicatorArc"
                style="@style/Widget.WayToFix.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_small"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:text="@string/indicator_arc"
                app:strokeColor="@color/info"
                app:strokeWidth="@dimen/border_thick" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartCamera"
            style="@style/Widget.WayToFix.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/start_exercise" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
