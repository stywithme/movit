<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Section Title -->
    <TextView
        android:id="@+id/sectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        tools:text="📸 لحظات مميزة" />

    <!-- Moments Container -->
    <LinearLayout
        android:id="@+id/momentsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Best Moment Card -->
        <LinearLayout
            android:id="@+id/bestMomentCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_glass_card">

            <!-- Frame Image -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@color/surface">

                <ImageView
                    android:id="@+id/ivBestFrame"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/app_name" />

            </FrameLayout>

            <!-- Label -->
            <TextView
                android:id="@+id/tvBestLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/success"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="⭐ أفضل لحظة" />

            <!-- Rep Number -->
            <TextView
                android:id="@+id/tvBestRep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                tools:text="العدة #3" />

            <!-- Score -->
            <TextView
                android:id="@+id/tvBestScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/success"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="98%" />

            <!-- Message -->
            <TextView
                android:id="@+id/tvBestMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="شكل مثالي!" />

        </LinearLayout>

        <!-- Worst Moment Card -->
        <LinearLayout
            android:id="@+id/worstMomentCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_glass_card"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Frame Image -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@color/surface">

                <ImageView
                    android:id="@+id/ivWorstFrame"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/app_name" />

            </FrameLayout>

            <!-- Label -->
            <TextView
                android:id="@+id/tvWorstLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/warning"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="📉 لحظة للتحسين" />

            <!-- Rep Number -->
            <TextView
                android:id="@+id/tvWorstRep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                tools:text="العدة #11" />

            <!-- Score -->
            <TextView
                android:id="@+id/tvWorstScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/warning"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="68%" />

            <!-- Message -->
            <TextView
                android:id="@+id/tvWorstMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="الجذع مال للأمام" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
