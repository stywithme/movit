<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.onboarding.steps.StepAgeGenderFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xl">

        <TextView
            style="@style/TextAppearance.WayToFix.Headline1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onb_age_gender_title" />

        <TextView
            style="@style/TextAppearance.WayToFix.Body2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/onb_age_gender_subtitle" />

        <TextView
            style="@style/TextAppearance.WayToFix.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/onb_age_label" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.WayToFix.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardBackgroundColor="@color/surface"
            app:contentPadding="@dimen/spacing_sm">

            <NumberPicker
                android:id="@+id/agePicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:theme="@style/ThemeOverlay.WayToFix.NumberPicker" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/TextAppearance.WayToFix.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/onb_gender_label" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMale"
                style="@style/Widget.WayToFix.ChoiceCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:id="@+id/iconMale"
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:contentDescription="@string/onb_gender_male"
                        android:src="@drawable/ic_gender_male"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:id="@+id/labelMale"
                        style="@style/TextAppearance.WayToFix.Body1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/onb_gender_male" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="@dimen/spacing_md"
                android:layout_height="match_parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFemale"
                style="@style/Widget.WayToFix.ChoiceCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:id="@+id/iconFemale"
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:contentDescription="@string/onb_gender_female"
                        android:src="@drawable/ic_gender_female"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:id="@+id/labelFemale"
                        style="@style/TextAppearance.WayToFix.Body1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/onb_gender_female" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
