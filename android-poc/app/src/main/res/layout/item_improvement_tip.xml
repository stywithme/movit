<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#2D2D2D"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Priority Badge -->
        <TextView
            android:id="@+id/tvPriority"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_priority"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="#1"/>

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Depth - Go Lower"/>

                <!-- Next Focus Badge -->
                <TextView
                    android:id="@+id/tvNextFocus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_next_focus"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="Next Focus"
                    android:textColor="#9C27B0"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:visibility="visible"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#B0B0B0"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                tools:text="Try to bend your knees more until thighs are parallel to the ground. Practice box squats to learn proper depth."/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
