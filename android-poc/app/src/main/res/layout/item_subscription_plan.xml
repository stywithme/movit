<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="0dp"
    app:strokeColor="@color/primary"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_base">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPlanTitle"
                style="@style/TextAppearance.Movit.Headline3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                tools:text="Pro" />

            <TextView
                android:id="@+id/tvPlanBadge"
                style="@style/TextAppearance.Movit.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_accent"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs"
                android:text="@string/subscription_selected"
                android:textColor="@color/primary"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:baselineAligned="false"
            android:gravity="bottom"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPlanPrice"
                style="@style/TextAppearance.Movit.Headline2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                tools:text="99.00 KWD" />

            <TextView
                android:id="@+id/tvPlanPeriod"
                style="@style/TextAppearance.Movit.Body2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xs"
                android:paddingBottom="2dp"
                android:textColor="@color/text_secondary"
                tools:text="/mo" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPlanDesc"
            style="@style/TextAppearance.Movit.Body2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            tools:text="Everything you need for guided training."
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvPlanFeatures"
            style="@style/TextAppearance.Movit.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/text_hint"
            tools:text="✓ Advanced reports\n✓ Personalized programs" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
