<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingBottom="100dp">

            <!-- STATE 1: No Active Program — Empty State -->
            <LinearLayout
                android:id="@+id/layoutNoProgramState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <!-- Inflated programmatically: layout_train_empty_state.xml -->
            </LinearLayout>

            <!-- STATE 2: Active Program Dashboard -->
            <LinearLayout
                android:id="@+id/layoutActiveProgramState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- 1. The Journey Map -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal"
                    android:layout_marginBottom="@dimen/spacing_md">
                    
                    <TextView
                        android:id="@+id/tvJourneyLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 2"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold" />
                        
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_tertiary"
                        android:layout_marginHorizontal="4dp" />
                        
                    <TextView
                        android:id="@+id/tvJourneyProgram"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Strength Foundation"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:maxLines="1" />
                        
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_tertiary"
                        android:layout_marginHorizontal="4dp" />
                        
                    <TextView
                        android:id="@+id/tvJourneyPosition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="W3 • D4"
                        android:textSize="12sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 2. Dynamic Hero Header -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/surface_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvHeroTitle"
                            style="@style/TextAppearance.WayToFix.Headline2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            tools:text="Ready to train?" />

                        <TextView
                            android:id="@+id/tvHeroSubtitle"
                            style="@style/TextAppearance.WayToFix.Body1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/text_secondary"
                            tools:text="Finish your weekly goal and hit your 4-day streak." />

                        <!-- Micro-Feedback / Motivation -->
                        <LinearLayout
                            android:id="@+id/layoutMotivation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/glass_pill_background"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_motivation"
                                app:tint="@color/primary" />

                            <TextView
                                android:id="@+id/tvMotivation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                tools:text="You improved your form by 10% yesterday. Keep it up!" />
                        </LinearLayout>

                        <!-- 3. Smart CTA -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSmartAction"
                            style="@style/Widget.WayToFix.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="20dp"
                            android:text="Start Session 1 (20 min)"
                            android:textSize="15sp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. Interactive Session Cards (Today's Plan) -->
                <LinearLayout
                    android:id="@+id/layoutTodayPlan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="@dimen/spacing_xl">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                        style="@style/TextAppearance.WayToFix.Headline3"
                        android:text="Today's Plan"
                        android:textColor="@color/text_primary" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSessions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:clipToPadding="false"
                        android:paddingHorizontal="@dimen/screen_padding_horizontal"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_interactive_session_card" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>