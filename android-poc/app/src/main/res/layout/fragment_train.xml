<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Main tab header: title + short subtitle + profile avatar -->
            <LinearLayout
                style="@style/Widget.WayToFix.Header.MainTab">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.WayToFix.Headline2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_train"
                        android:textColor="@color/text_primary" />

                    <TextView
                        style="@style/TextAppearance.WayToFix.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/main_tab_header_train_subtitle"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivAvatar"
                    style="@style/Widget.WayToFix.Avatar.Small"
                    android:contentDescription="@string/cd_avatar"
                    android:src="@drawable/ic_person" />
            </LinearLayout>

            <!-- STATE 1: No Active Program — Browse Programs -->
            <LinearLayout
                android:id="@+id/layoutNoProgramState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal"
                    android:paddingBottom="@dimen/spacing_lg">

                    <TextView
                        style="@style/TextAppearance.WayToFix.Headline1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pg_browse_title"
                        android:textColor="@color/text_primary" />

                    <TextView
                        style="@style/TextAppearance.WayToFix.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/pg_browse_subtitle"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvProgramList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_program_browse_card" />

            </LinearLayout>

            <!-- STATE 2: Active Program Dashboard -->
            <LinearLayout
                android:id="@+id/layoutActiveProgramState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- SECTION 1: Program Identity Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProgramIdentity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/surface_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvProgramName"
                                style="@style/TextAppearance.WayToFix.Headline2"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                tools:text="Full Body 4-Week Challenge" />

                            <TextView
                                android:id="@+id/tvProgramDifficulty"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/glass_pill_background"
                                android:paddingHorizontal="@dimen/spacing_sm"
                                android:paddingVertical="2dp"
                                android:textColor="@color/primary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                tools:text="Beginner" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvProgramPosition"
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:textColor="@color/text_secondary"
                            tools:text="Week 2 of 4 · Day 3" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressProgram"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:indeterminate="false"
                            app:indicatorColor="@color/primary"
                            app:trackColor="@color/surface_variant"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="8dp"
                            tools:progress="35" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvDaysTrained"
                                style="@style/TextAppearance.WayToFix.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawablePadding="4dp"
                                android:gravity="center_vertical"
                                android:textColor="@color/text_secondary"
                                tools:text="12 days trained" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="12dp"
                                android:layout_marginHorizontal="@dimen/spacing_sm"
                                android:background="@color/surface_border" />

                            <TextView
                                android:id="@+id/tvStreak"
                                style="@style/TextAppearance.WayToFix.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawablePadding="4dp"
                                android:gravity="center_vertical"
                                android:textColor="@color/text_secondary"
                                tools:text="3 day streak" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvProgramGrade"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/glass_pill_background"
                                android:gravity="center"
                                android:textColor="@color/primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                tools:text="A" />

                            <View
                                android:layout_width="6dp"
                                android:layout_height="0dp" />

                            <TextView
                                android:id="@+id/tvProgressPercent"
                                style="@style/TextAppearance.WayToFix.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                tools:text="35%" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SECTION 2: Week Calendar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal">

                    <TextView
                        android:id="@+id/tvWeekTitle"
                        style="@style/TextAppearance.WayToFix.Headline3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="Week 2" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutWeekCalendar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_sm" />

                <LinearLayout
                    android:id="@+id/layoutWeekLabels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_sm" />

                <!-- SECTION 2b: Weekly Sparkline -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWeeklySparkline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_base"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/surface_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_base">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/TextAppearance.WayToFix.Caption"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/pg_form_score_trend"
                                android:textColor="@color/text_secondary"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvWeekComparison"
                                style="@style/TextAppearance.WayToFix.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/success"
                                tools:text="vs. Last Week: +5%" />
                        </LinearLayout>

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chartSparkline"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:layout_marginTop="@dimen/spacing_xs" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SECTION 3: Today -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal">

                    <TextView
                        android:id="@+id/tvTodayHeader"
                        style="@style/TextAppearance.WayToFix.Headline3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        tools:text="TODAY — Day 3" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutTodaySessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/screen_padding_horizontal" />

                <!-- Day Complete Banner -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDayComplete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/success_bg"
                    app:cardCornerRadius="@dimen/radius_base"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/success"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_base">

                        <TextView
                            android:id="@+id/tvDayCompleteTitle"
                            style="@style/TextAppearance.WayToFix.Headline3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pg_day_complete_title"
                            android:textColor="@color/success" />

                        <TextView
                            android:id="@+id/tvDayCompleteSubtitle"
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:textColor="@color/text_secondary"
                            tools:text="3/3 sessions completed · Total: 38 min" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnViewDaySummary"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pg_view_day_summary"
                            android:textColor="@color/success" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Rest Day Banner -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRestDay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_base"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/surface_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <TextView
                            style="@style/TextAppearance.WayToFix.Headline3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pg_rest_day_title"
                            android:textColor="@color/text_primary" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/pg_rest_day_message"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvRestDayTomorrow"
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:textColor="@color/text_primary"
                            tools:text="Tomorrow: Upper Body Focus · 4 exercises" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SECTION 4: Program Report Summary -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProgramReport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                    android:layout_marginTop="@dimen/spacing_xl"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/surface_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <TextView
                            style="@style/TextAppearance.WayToFix.Headline3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pg_report_title"
                            android:textColor="@color/text_primary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_base"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvReportDays"
                                    style="@style/TextAppearance.WayToFix.Headline2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/primary"
                                    tools:text="12" />
                                <TextView
                                    style="@style/TextAppearance.WayToFix.Caption"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/pg_report_days_label"
                                    android:textColor="@color/text_secondary" />
                            </LinearLayout>

                            <View android:layout_width="1dp" android:layout_height="match_parent"
                                android:layout_marginVertical="@dimen/spacing_xs" android:background="@color/surface_border" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvReportExercises"
                                    style="@style/TextAppearance.WayToFix.Headline2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/primary"
                                    tools:text="86" />
                                <TextView
                                    style="@style/TextAppearance.WayToFix.Caption"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/pg_report_exercises_label"
                                    android:textColor="@color/text_secondary" />
                            </LinearLayout>

                            <View android:layout_width="1dp" android:layout_height="match_parent"
                                android:layout_marginVertical="@dimen/spacing_xs" android:background="@color/surface_border" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvReportTime"
                                    style="@style/TextAppearance.WayToFix.Headline2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/primary"
                                    tools:text="6h" />
                                <TextView
                                    style="@style/TextAppearance.WayToFix.Caption"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/pg_report_time_label"
                                    android:textColor="@color/text_secondary" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvReportReps"
                                    style="@style/TextAppearance.WayToFix.Headline2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/primary"
                                    tools:text="420" />
                                <TextView
                                    style="@style/TextAppearance.WayToFix.Caption"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/pg_report_reps_label"
                                    android:textColor="@color/text_secondary" />
                            </LinearLayout>

                            <View android:layout_width="1dp" android:layout_height="match_parent"
                                android:layout_marginVertical="@dimen/spacing_xs" android:background="@color/surface_border" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvReportAccuracy"
                                    style="@style/TextAppearance.WayToFix.Headline2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/primary"
                                    tools:text="85%" />
                                <TextView
                                    style="@style/TextAppearance.WayToFix.Caption"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/pg_report_accuracy_label"
                                    android:textColor="@color/text_secondary" />
                            </LinearLayout>

                            <View android:layout_width="1dp" android:layout_height="match_parent"
                                android:layout_marginVertical="@dimen/spacing_xs" android:background="@color/surface_border" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvReportSets"
                                    style="@style/TextAppearance.WayToFix.Headline2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/primary"
                                    tools:text="156" />
                                <TextView
                                    style="@style/TextAppearance.WayToFix.Caption"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/pg_report_sets_label"
                                    android:textColor="@color/text_secondary" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvReportInsight"
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_base"
                            android:textColor="@color/text_secondary"
                            tools:text="Your form is improving!" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnViewFullReports"
                            style="@style/Widget.WayToFix.Button.Secondary"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/pg_view_full_reports" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Program Complete State -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProgramComplete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_xl">

                        <TextView
                            style="@style/TextAppearance.WayToFix.Headline2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pg_complete_title"
                            android:textColor="@color/primary" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center"
                            android:text="@string/pg_complete_subtitle"
                            android:textColor="@color/text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnViewJourney"
                            style="@style/Widget.WayToFix.Button.Secondary"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="@dimen/spacing_lg"
                            android:text="@string/pg_view_journey" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStartNext"
                            style="@style/Widget.WayToFix.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/pg_complete_whats_next" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Browse All Programs Link -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBrowseAllPrograms"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    android:text="@string/pg_browse_all_programs"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconGravity="end"
                    app:iconTint="@color/primary" />

            </LinearLayout>

        </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
