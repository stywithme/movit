<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/spacing_xl"
    android:paddingTop="@dimen/spacing_xl"
    android:paddingBottom="@dimen/spacing_lg"
    android:background="@color/surface">

    <!-- Celebration badge -->
    <TextView
        android:id="@+id/tvProgressionIcon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="48sp"
        android:layout_marginBottom="@dimen/spacing_base"
        tools:text="\uD83C\uDF1F" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvProgressionTitle"
        style="@style/TextAppearance.WayToFix.Headline3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="@dimen/spacing_xs"
        tools:text="Level Up!" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvProgressionSubtitle"
        style="@style/TextAppearance.WayToFix.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/progression_sheet_subtitle"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Changes container (cards built programmatically) -->
    <LinearLayout
        android:id="@+id/llProgressionChanges"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Got It button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProgressionGotIt"
        style="@style/Widget.WayToFix.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/progression_sheet_got_it" />

</LinearLayout>
