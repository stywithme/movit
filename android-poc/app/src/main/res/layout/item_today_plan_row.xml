<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tvPlanBullet"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        tools:text="●" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPlanTitle"
            style="@style/TextAppearance.WayToFix.Body1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            tools:text="Push-ups" />

        <TextView
            android:id="@+id/tvPlanSubtitle"
            style="@style/TextAppearance.WayToFix.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            tools:text="5 rounds · 10 reps" />

        <TextView
            android:id="@+id/tvPlanStatus"
            style="@style/TextAppearance.WayToFix.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/primary"
            android:visibility="gone"
            tools:text="Next" />
    </LinearLayout>

</LinearLayout>
