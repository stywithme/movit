<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardError"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/state_warning_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- State Icon -->
            <TextView
                android:id="@+id/tvStateIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                tools:text="⚠️" />

            <!-- Joint Name -->
            <TextView
                android:id="@+id/tvJointName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="@color/report_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="الركبة" />

            <!-- State Label -->
            <TextView
                android:id="@+id/tvStateLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/state_warning"
                android:textSize="14sp"
                tools:text="يحتاج تحسين" />

            <!-- Occurrence Count -->
            <TextView
                android:id="@+id/tvOccurrenceCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/report_text_secondary"
                android:textSize="14sp"
                tools:text="(3×)" />

        </LinearLayout>

        <!-- State Message -->
        <TextView
            android:id="@+id/tvStateMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/report_text_primary"
            android:textSize="15sp"
            tools:text="جيد، حاول النزول أكثر قليلاً" />

        <!-- Single Error Frame (when no comparison available) -->
        <LinearLayout
            android:id="@+id/llSingleError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <FrameLayout
                android:id="@+id/singleFrameContainer"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:foreground="?attr/selectableItemBackground"
                android:background="@drawable/rounded_corners_bg">

                <ImageView
                    android:id="@+id/ivSingleErrorFrame"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:background="#1A1A1A"
                    android:contentDescription="Error position" />

                <!-- Error Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="8dp"
                    android:background="#CCF44336"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="❌ Error"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <!-- Tap to expand hint -->
                <TextView
                    android:id="@+id/tvSingleExpandHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:background="#88000000"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="🔍 Tap to expand"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

            </FrameLayout>

            <!-- Angle info below single image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvSingleActualAngle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/state_warning"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="105°" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="→"
                    android:textColor="@color/report_text_secondary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvSingleExpectedRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/state_perfect"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="160° - 180°" />

            </LinearLayout>

        </LinearLayout>

        <!-- Comparison Section (when both frames available) -->
        <LinearLayout
            android:id="@+id/llComparison"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">

            <!-- Error Frame -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_corners_bg">

                    <ImageView
                        android:id="@+id/ivErrorFrame"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:background="#1A1A1A"
                        android:contentDescription="Error position" />

                    <!-- Error Badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_margin="4dp"
                        android:background="#99F44336"
                        android:padding="4dp"
                        android:text="❌"
                        android:textSize="12sp" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tvErrorAngle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/state_warning"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="105°" />

            </LinearLayout>

            <!-- VS Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="vs"
                android:textColor="@color/report_text_secondary"
                android:textSize="14sp"
                android:layout_marginHorizontal="8dp" />

            <!-- Correct Frame -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/rounded_corners_bg">

                    <ImageView
                        android:id="@+id/ivCorrectFrame"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:background="#1A1A1A"
                        android:contentDescription="Correct position" />

                    <!-- Correct Badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_margin="4dp"
                        android:background="#994CAF50"
                        android:padding="4dp"
                        android:text="✓"
                        android:textSize="12sp" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tvCorrectAngle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/state_perfect"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="75°" />

            </LinearLayout>

        </LinearLayout>

        <!-- Affected Reps -->
        <TextView
            android:id="@+id/tvAffectedReps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/report_text_secondary"
            android:textSize="13sp"
            tools:text="Reps: #3, #6, #10" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#22FFFFFF" />

        <!-- Solution Tip -->
        <TextView
            android:id="@+id/tvSolutionTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/report_text_primary"
            android:textSize="14sp"
            tools:text="💡 ادفع من كعبيك للصعود" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
