<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Full Screen Image -->
    <ImageView
        android:id="@+id/ivFullScreenImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@string/app_name"
        tools:background="@color/surface_variant" />

    <!-- Placeholder when no image -->
    <LinearLayout
        android:id="@+id/placeholderContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_person_placeholder"
            android:alpha="0.3" />

    </LinearLayout>

    <!-- Gradient Overlay (bottom fade) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_report_overlay" />

    <!-- Top Info (Exercise name + Page type) -->
    <LinearLayout
        android:id="@+id/topInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="80dp">

        <!-- Page Type Badge (Session / Rep #) -->
        <TextView
            android:id="@+id/tvPageType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            tools:text="REP #2" />

        <!-- Exercise Name -->
        <TextView
            android:id="@+id/tvExerciseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            tools:text="Squats" />

    </LinearLayout>

    <!-- Bottom Content Overlay - scrollable with max height constraint -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:fillViewport="false"
        android:scrollbars="none"
        android:overScrollMode="never">
        
    <LinearLayout
        android:id="@+id/bottomOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="120dp"
        android:paddingTop="16dp">

        <!-- Primary Stats Row -->
        <LinearLayout
            android:id="@+id/primaryStatsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp">

            <!-- Stat 1 -->
            <LinearLayout
                android:id="@+id/stat1Container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvStat1Value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    tools:text="89%" />

                <TextView
                    android:id="@+id/tvStat1Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    tools:text="Quality" />

            </LinearLayout>

            <!-- Stat 2 -->
            <LinearLayout
                android:id="@+id/stat2Container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvStat2Value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    tools:text="00:45" />

                <TextView
                    android:id="@+id/tvStat2Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    tools:text="Duration" />

            </LinearLayout>

            <!-- Stat 3 -->
            <LinearLayout
                android:id="@+id/stat3Container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvStat3Value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    tools:text="4" />

                <TextView
                    android:id="@+id/tvStat3Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    tools:text="Reps" />

            </LinearLayout>

        </LinearLayout>

        <!-- Message / Insight -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            tools:text="🟢 Excellent form! Try adding weight next time." />

        <!-- Secondary Metrics (dynamic) -->
        <LinearLayout
            android:id="@+id/secondaryMetricsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Metrics will be added programmatically -->

        </LinearLayout>

    </LinearLayout>
    
    </ScrollView>

    <!-- Page Indicator Dots -->
    <LinearLayout
        android:id="@+id/pageIndicatorContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="90dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Dots will be added programmatically -->

    </LinearLayout>

    <!-- Swipe Hint -->
    <TextView
        android:id="@+id/tvSwipeHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="70dp"
        android:layout_marginTop="8dp"
        android:text="← Swipe for reps"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:visibility="gone" />

</FrameLayout>
