<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_workout"
        android:alpha="0.5"
        android:layout_marginBottom="24dp"
        android:contentDescription="@null" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/programs_no_active_title"
        android:textAppearance="@style/TextAppearance.WayToFix.Headline2"
        android:textAlignment="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start your journey by choosing a program from the Explore tab."
        android:textAppearance="@style/TextAppearance.WayToFix.Body1"
        android:textColor="@color/text_secondary"
        android:textAlignment="center"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoToExplore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Go to Explore"
        android:paddingVertical="12dp"
        style="@style/Widget.WayToFix.Button.Primary" />

</LinearLayout>