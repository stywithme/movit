<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".ui.TrainingActivity">

    <!-- ==================== LAYER 0: Media Background ==================== -->
    
    <!-- Camera Preview (hidden in video mode) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillStart" />

    <!-- Video TextureView (hidden in camera mode) -->
    <TextureView
        android:id="@+id/videoTextureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- ==================== LAYER 1: Skeleton Overlay ==================== -->
    
    <com.trainingvalidator.poc.overlay.SkeletonOverlayView
        android:id="@+id/skeletonOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ==================== LAYER 2: Vignette Alert Overlay ==================== -->
    
    <com.trainingvalidator.poc.ui.components.VignetteOverlayView
        android:id="@+id/vignetteOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ==================== LAYER 3: Glass HUD System ==================== -->

    <!-- TOP DECK: Glass Pill Navigation -->
    <LinearLayout
        android:id="@+id/topDeck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="@drawable/glass_deck_background"
        android:elevation="8dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Close Button -->
        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"
            app:tint="@android:color/white" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF"
            android:layout_marginHorizontal="12dp" />

        <!-- Exercise Name -->
        <TextView
            android:id="@+id/tvExerciseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exercise"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxWidth="180dp"
            android:ellipsize="end"
            android:singleLine="true" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#33FFFFFF"
            android:layout_marginHorizontal="12dp" />

        <!-- Phase Label -->
        <TextView
            android:id="@+id/tvPhase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready"
            android:textColor="#00E676"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- FPS Debug (top right) -->
    <TextView
        android:id="@+id/tvFps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FPS: --"
        android:textColor="#66FFFFFF"
        android:textSize="10sp"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ==================== HERO ELEMENT: Rep Counter / Timer ==================== -->
    
    <FrameLayout
        android:id="@+id/heroCounterContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topDeck"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <!-- Large Hero Number -->
        <TextView
            android:id="@+id/tvRepCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="100sp"
            android:fontFamily="sans-serif-thin"
            android:shadowColor="#66000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="8" />

    </FrameLayout>

    <!-- Progress Label (below hero number) -->
    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 / 12"
        android:textColor="#80FFFFFF"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/heroCounterContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- ==================== GLASSMORPHIC MESSAGE AREA ==================== -->
    
    <com.trainingvalidator.poc.ui.components.GlassmorphicMessageView
        android:id="@+id/glassmorphicMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvProgress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ==================== SETUP POSE PANEL (Glass Style) ==================== -->
    
    <LinearLayout
        android:id="@+id/setupPosePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/glass_deck_background"
        android:elevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomDeck">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_position"
                android:contentDescription="Position"
                app:tint="#00E676" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setup Position"
                android:textColor="#00E676"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvPoseRequirements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading requirements..."
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current Status:"
            android:textColor="#66FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvPoseStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting for pose..."
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- ==================== COUNTDOWN OVERLAY ==================== -->
    
    <FrameLayout
        android:id="@+id/countdownPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Get Ready!"
                android:textColor="#CCFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textColor="#00E676"
                android:textSize="140sp"
                android:fontFamily="sans-serif-thin" />

        </LinearLayout>

    </FrameLayout>

    <!-- ==================== TRAINING PANEL (Legacy - now integrated into Hero) ==================== -->
    
    <LinearLayout
        android:id="@+id/trainingPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Legacy Error Text (hidden - using GlassmorphicMessage instead) -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ==================== COMPLETED PANEL ==================== -->
    
    <LinearLayout
        android:id="@+id/completedPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="#EE121212"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_celebration"
            android:contentDescription="Celebration" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Workout Complete!"
            android:textColor="#00E676"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <!-- Summary Card (Glassmorphic) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="#33FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Total Reps -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Reps"
                        android:textColor="#99FFFFFF"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvSummaryReps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="@android:color/white"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-light" />

                </LinearLayout>

                <!-- Correct -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Correct"
                        android:textColor="#99FFFFFF"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvSummaryCorrect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10 correct"
                        android:textColor="#00E676"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Accuracy -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Accuracy"
                        android:textColor="#99FFFFFF"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvSummaryAccuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="83%"
                        android:textColor="#FFD700"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-light" />

                </LinearLayout>

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Duration"
                        android:textColor="#99FFFFFF"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvSummaryDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01:30"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Button Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp">

            <!-- Save Results Button (Video mode only) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveResults"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Save"
                android:textSize="16sp"
                android:visibility="gone"
                app:cornerRadius="28dp"
                app:backgroundTint="#2196F3"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart" />

            <!-- Finish Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinish"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Done"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                app:backgroundTint="#00E676" />

        </LinearLayout>

    </LinearLayout>

    <!-- ==================== VIDEO CONTROLS (Glass Style) ==================== -->
    
    <LinearLayout
        android:id="@+id/videoControlsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/glass_deck_background"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomDeck">

        <!-- Seek Bar -->
        <SeekBar
            android:id="@+id/videoSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#00E676"
            android:thumbTint="#00E676"
            android:max="100" />

        <!-- Time Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvVideoCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvVideoDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- REMOVED: Rewind/Forward buttons - use SeekBar instead -->

    </LinearLayout>

    <!-- ==================== BOTTOM CONTROL DECK ==================== -->
    
    <LinearLayout
        android:id="@+id/bottomDeck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:background="@drawable/glass_deck_background"
        android:elevation="8dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Switch Camera Button -->
        <ImageButton
            android:id="@+id/btnSwitchCamera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_switch_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Switch Camera"
            app:tint="@android:color/white" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#33FFFFFF"
            android:layout_marginHorizontal="16dp" />

        <!-- Play/Pause Button (Glassmorphic Icon Button) -->
        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/glass_pill_background"
            android:padding="14dp"
            android:contentDescription="Play/Pause"
            android:scaleType="fitCenter"
            app:tint="@android:color/white" />

        <!-- Progress Indicator (for camera mode) -->
        <LinearLayout
            android:id="@+id/progressContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="100dp"
                android:layout_height="4dp"
                android:progressTint="#00E676"
                android:progressBackgroundTint="#33FFFFFF"
                android:max="100" />

            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Legacy panels kept for compatibility -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
