<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="ltr"
    android:background="@color/background"
    tools:context=".ui.TrainingActivity">

    <!-- ==================== LAYER 0: Media Background ==================== -->
    
    <!-- Camera Preview (hidden in video mode) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillStart" />

    <!-- Video TextureView (hidden in camera mode) -->
    <TextureView
        android:id="@+id/videoTextureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- ==================== LAYER 1: Skeleton Overlay ==================== -->
    
    <com.trainingvalidator.poc.overlay.SkeletonOverlayView
        android:id="@+id/skeletonOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ==================== LAYER 2: Vignette Alert Overlay ==================== -->
    
    <com.trainingvalidator.poc.ui.components.VignetteOverlayView
        android:id="@+id/vignetteOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ==================== LAYER 3: NEW TOP BAR ==================== -->

    <!-- Top Bar Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_base"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Finish Button (Left) -->
        <LinearLayout
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_finish_button"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_sm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_close"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xs"
                android:text="@string/finish"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Center Title -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvCurrentExerciseLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_exercise"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvExerciseName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exercise"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxWidth="200dp"
                android:ellipsize="end"
                android:singleLine="true" />

        </LinearLayout>

        <!-- Settings Button (Right) -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_settings_button"
            android:src="@drawable/ic_settings"
            android:scaleType="center"
            android:padding="8dp"
            android:contentDescription="@string/settings"
            app:tint="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ==================== CIRCULAR REP COUNTER (Top Right) ==================== -->
    
    <FrameLayout
        android:id="@+id/heroCounterContainer"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginEnd="@dimen/spacing_base"
        android:background="@drawable/bg_circular_counter"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Large Rep Number -->
            <TextView
                android:id="@+id/tvRepCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@android:color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- REPS Label -->
            <TextView
                android:id="@+id/tvRepsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reps"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

        </LinearLayout>

    </FrameLayout>

    <!-- Progress Label (hidden - kept for compatibility) -->
    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 / 12"
        android:textColor="#80FFFFFF"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/heroCounterContainer"
        app:layout_constraintEnd_toEndOf="@id/heroCounterContainer"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="@dimen/spacing_base" />

    <!-- Phase Label (hidden - kept for compatibility) -->
    <TextView
        android:id="@+id/tvPhase"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textColor="@color/primary"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- FPS Debug (top right - hidden by default) -->
    <TextView
        android:id="@+id/tvFps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FPS: --"
        android:textColor="#66FFFFFF"
        android:textSize="10sp"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ==================== GLASSMORPHIC MESSAGE AREA (Same row as Rep Counter) ==================== -->
    
    <com.trainingvalidator.poc.ui.components.GlassmorphicMessageView
        android:id="@+id/glassmorphicMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_base"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:layout_marginTop="@dimen/spacing_sm"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/heroCounterContainer" />

    <!-- ==================== SETUP POSE PANEL (Glass Style) ==================== -->
    
    <LinearLayout
        android:id="@+id/setupPosePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl"
        android:layout_marginHorizontal="@dimen/spacing_base"
        android:layout_marginBottom="@dimen/spacing_base"
        android:background="@drawable/glass_deck_background"
        android:elevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomStatsBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_position"
                android:contentDescription="Position"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setup_position"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="@dimen/spacing_sm" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvPoseRequirements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/loading"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="@dimen/spacing_md"
            android:lineSpacingExtra="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF"
            android:layout_marginTop="@dimen/spacing_base"
            android:layout_marginBottom="@dimen/spacing_base" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/current_status"
            android:textColor="#66FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvPoseStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/waiting_for_pose"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginTop="@dimen/spacing_sm"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- ==================== COUNTDOWN OVERLAY ==================== -->
    
    <FrameLayout
        android:id="@+id/countdownPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/get_ready"
                android:textColor="#CCFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textColor="@color/primary"
                android:textSize="140sp"
                android:fontFamily="sans-serif-thin" />

        </LinearLayout>

    </FrameLayout>

    <!-- ==================== TRAINING PANEL (Legacy - kept for compatibility) ==================== -->
    
    <LinearLayout
        android:id="@+id/trainingPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Legacy Error Text (hidden) -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ==================== COMPLETED PANEL ==================== -->
    
    <LinearLayout
        android:id="@+id/completedPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_2xl"
        android:background="@color/background"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_celebration"
            android:contentDescription="Celebration" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/workout_complete"
            android:textColor="@color/primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/spacing_base" />

        <!-- Summary Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_2xl"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <!-- Total Reps -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/total_reps"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvSummaryReps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-light" />

                </LinearLayout>

                <!-- Correct -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_base">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/correct"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvSummaryCorrect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10 correct"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Accuracy -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_base">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/accuracy"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvSummaryAccuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="83%"
                        android:textColor="@color/pro_gold"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-light" />

                </LinearLayout>

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_base">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/duration"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvSummaryDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01:30"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Button Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/spacing_2xl">

            <!-- Save Results Button (Video mode only) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveResults"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:text="@string/save"
                android:textSize="16sp"
                android:visibility="gone"
                style="@style/Widget.WayToFix.Button.Secondary"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart" />

            <!-- Finish Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinish"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:text="@string/done"
                android:textSize="18sp"
                android:textStyle="bold"
                style="@style/Widget.WayToFix.Button.Primary" />

        </LinearLayout>

    </LinearLayout>

    <!-- ==================== VIDEO CONTROLS (Glass Style) ==================== -->
    
    <LinearLayout
        android:id="@+id/videoControlsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_base"
        android:layout_marginHorizontal="@dimen/spacing_base"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:background="@drawable/glass_deck_background"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomStatsBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Seek Bar -->
        <SeekBar
            android:id="@+id/videoSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/primary"
            android:thumbTint="@color/primary"
            android:max="100" />

        <!-- Time Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvVideoCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvVideoDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ==================== BOTTOM CONTROL BAR (Stats + Controls in one row) ==================== -->
    
    <LinearLayout
        android:id="@+id/bottomStatsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_base"
        android:paddingVertical="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_lg"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- TIME Card (Left - takes remaining space) -->
        <LinearLayout
            android:id="@+id/cardTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_md"
            android:background="@drawable/bg_stat_card_dark"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tvTimeElapsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Stop/Play Button (Center - fixed width) -->
        <FrameLayout
            android:id="@+id/btnPlayPause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/glass_pill_background"
            android:contentDescription="Stop">

            <View
                android:id="@+id/stopIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_stop_button" />

        </FrameLayout>

        <!-- FORM Card (Right - takes remaining space) -->
        <LinearLayout
            android:id="@+id/cardForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_md"
            android:background="@drawable/bg_stat_card_dark"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/form"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tvFormStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/good"
                android:textColor="@color/primary"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvAlternatingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/pro_gold"
        android:textSize="12sp"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/tvSessionSetIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Alternating: Variant" />

    <TextView
        android:id="@+id/tvSessionSetIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomStatsBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Set 1 of 3" />
    
    <!-- Hidden Switch Camera Button (moved to Settings dialog) -->
    <ImageButton
        android:id="@+id/btnSwitchCamera"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Hidden SET Card (for workouts - kept for compatibility) -->
    <LinearLayout
        android:id="@+id/cardSet"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvSetProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1/4"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Hidden bottomControlDeck (kept for compatibility) -->
    <FrameLayout
        android:id="@+id/bottomControlDeck"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ==================== LEGACY PANELS (Hidden - kept for compatibility) ==================== -->
    
    <!-- Legacy topDeck (alias for compatibility) -->
    <LinearLayout
        android:id="@+id/topDeck"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Legacy bottomDeck (alias for compatibility) -->
    <LinearLayout
        android:id="@+id/bottomDeck"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Progress Container (hidden - kept for compatibility) -->
    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="100dp"
            android:layout_height="4dp"
            android:progressTint="@color/primary"
            android:progressBackgroundTint="#33FFFFFF"
            android:max="100" />

        <TextView
            android:id="@+id/tvProgressPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- ==================== SESSION MODE: Pre-Exercise Overlay ==================== -->

    <LinearLayout
        android:id="@+id/sessionPreExercisePanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_2xl"
        android:background="#CC000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvSessionExerciseLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            tools:text="NEXT EXERCISE · 2/5" />

        <TextView
            android:id="@+id/tvSessionExerciseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/spacing_sm"
            tools:text="Push-ups" />

        <TextView
            android:id="@+id/tvSessionAlternatingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/pro_gold"
            android:textSize="14sp"
            android:layout_marginTop="@dimen/spacing_xs"
            android:visibility="gone"
            tools:text="Alternating: Variant" />

        <TextView
            android:id="@+id/tvSessionSetInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="18sp"
            android:layout_marginTop="@dimen/spacing_sm"
            tools:text="Set 1 of 3 · 12 reps" />

        <TextView
            android:id="@+id/tvSessionWeightInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/pro_gold"
            android:textSize="16sp"
            android:layout_marginTop="@dimen/spacing_xs"
            android:visibility="gone"
            tools:text="Weight: 10 kg" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSessionStartSet"
            style="@style/Widget.WayToFix.Button.Primary"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:layout_marginTop="@dimen/spacing_2xl"
            android:text="@string/session_start_set"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ==================== SESSION MODE: Rest Overlay ==================== -->

    <LinearLayout
        android:id="@+id/sessionRestPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_2xl"
        android:background="#CC000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvSessionRestTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="16sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            tools:text="REST BETWEEN SETS" />

        <TextView
            android:id="@+id/tvSessionRestCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textSize="72sp"
            android:fontFamily="sans-serif-thin"
            android:layout_marginTop="@dimen/spacing_base"
            tools:text="00:30" />

        <TextView
            android:id="@+id/tvSessionRestNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center"
            tools:text="Next: Squats · Set 1/3 · 12 reps" />

        <TextView
            android:id="@+id/tvSessionRestTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#99FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            tools:text="Rest helps your muscles prepare for the next round" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSessionAddTime"
                style="@style/Widget.WayToFix.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/add_20s"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSessionSkipRest"
                style="@style/Widget.WayToFix.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:text="@string/skip"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSessionEditRest"
                style="@style/Widget.WayToFix.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:text="@string/edit_rest"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ==================== SESSION MODE: Complete Overlay ==================== -->

    <LinearLayout
        android:id="@+id/sessionCompletePanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_2xl"
        android:background="@color/background"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_celebration"
            android:contentDescription="Session Complete" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/session_complete"
            android:textColor="@color/primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/spacing_base" />

        <TextView
            android:id="@+id/tvSessionCompleteSets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginTop="@dimen/spacing_lg"
            tools:text="Sets: 12/14" />

        <TextView
            android:id="@+id/tvSessionCompleteReps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginTop="@dimen/spacing_xs"
            tools:text="Total Reps: 156" />

        <TextView
            android:id="@+id/tvSessionCompleteDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginTop="@dimen/spacing_xs"
            tools:text="Duration: 18:34" />

        <TextView
            android:id="@+id/tvSessionCompleteAccuracy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginTop="@dimen/spacing_xs"
            tools:text="Average Accuracy: 87%" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSessionDone"
            style="@style/Widget.WayToFix.Button.Primary"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:layout_marginTop="@dimen/spacing_2xl"
            android:text="@string/done"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
