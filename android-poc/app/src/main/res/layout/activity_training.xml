<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".ui.TrainingActivity">

    <!-- Camera Preview (hidden in video mode) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillStart" />

    <!-- Video TextureView (hidden in camera mode) -->
    <TextureView
        android:id="@+id/videoTextureView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Skeleton Overlay -->
    <com.trainingvalidator.poc.overlay.SkeletonOverlayView
        android:id="@+id/skeletonOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Panel - Exercise Info -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/gradient_top"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Close Button -->
        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"
            app:tint="@android:color/white" />

        <!-- Exercise Name -->
        <TextView
            android:id="@+id/tvExerciseName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Exercise"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center" />

        <!-- FPS -->
        <TextView
            android:id="@+id/tvFps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FPS: --"
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ==================== SETUP POSE PANEL ==================== -->
    <LinearLayout
        android:id="@+id/setupPosePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#CC000000"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Setup Position"
            android:textColor="#00E676"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPoseRequirements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading requirements..."
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#3A3A3A"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current Status:"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvPoseStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting for pose..."
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- ==================== COUNTDOWN PANEL ==================== -->
    <LinearLayout
        android:id="@+id/countdownPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#88000000"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Get Ready!"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textColor="#00E676"
            android:textSize="120sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ==================== TRAINING PANEL ==================== -->
    <LinearLayout
        android:id="@+id/trainingPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topPanel"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp">

        <!-- Rep Count -->
        <TextView
            android:id="@+id/tvRepCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="80sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <!-- Progress -->
        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 12"
            android:textColor="#00E676"
            android:textSize="16sp" />

        <!-- Phase Label -->
        <TextView
            android:id="@+id/tvPhase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready"
            android:textColor="@android:color/holo_blue_light"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Error Message Panel -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@android:color/holo_red_light"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="#CC000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ==================== COMPLETED PANEL ==================== -->
    <LinearLayout
        android:id="@+id/completedPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="#EE121212"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Workout Complete!"
            android:textColor="#00E676"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <!-- Summary Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="#2A2A2A"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Total Reps -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Reps"
                        android:textColor="#888888"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvSummaryReps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="@android:color/white"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Correct -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Correct"
                        android:textColor="#888888"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvSummaryCorrect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10 correct"
                        android:textColor="#00E676"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Accuracy -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Accuracy"
                        android:textColor="#888888"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvSummaryAccuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="83%"
                        android:textColor="#FFD700"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Duration"
                        android:textColor="#888888"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvSummaryDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01:30"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Button Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp">

            <!-- Save Results Button (Video mode only) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveResults"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Save"
                android:textSize="16sp"
                android:visibility="gone"
                app:cornerRadius="12dp"
                app:backgroundTint="#2196F3"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart" />

            <!-- Finish Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinish"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Done"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:backgroundTint="#00E676" />

        </LinearLayout>

    </LinearLayout>

    <!-- ==================== VIDEO CONTROLS (hidden in camera mode) ==================== -->
    <LinearLayout
        android:id="@+id/videoControlsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#CC000000"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel">

        <!-- Seek Bar -->
        <SeekBar
            android:id="@+id/videoSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#00E676"
            android:thumbTint="#00E676"
            android:max="100" />

        <!-- Time Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvVideoCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@android:color/white"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvVideoDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@android:color/white"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Playback Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <!-- Rewind 10s Button -->
            <ImageButton
                android:id="@+id/btnVideoRewind"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_media_rew"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Rewind 10s"
                app:tint="@android:color/white" />

            <!-- Play/Pause Button -->
            <ImageButton
                android:id="@+id/btnVideoPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_media_play"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginHorizontal="24dp"
                android:contentDescription="Play/Pause"
                app:tint="@android:color/white" />

            <!-- Forward 10s Button -->
            <ImageButton
                android:id="@+id/btnVideoForward"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_media_ff"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Forward 10s"
                app:tint="@android:color/white" />

        </LinearLayout>

    </LinearLayout>

    <!-- ==================== BOTTOM CONTROL PANEL ==================== -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="24dp"
        android:background="@drawable/gradient_bottom"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Switch Camera Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSwitchCamera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_switch_camera"
            app:iconSize="24dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:cornerRadius="28dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Pause/Resume Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPauseResume"
            android:layout_width="120dp"
            android:layout_height="56dp"
            android:text="Pause"
            android:textSize="16sp"
            android:visibility="gone"
            app:cornerRadius="28dp"
            app:backgroundTint="#FF9800" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Placeholder for symmetry -->
        <View
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:visibility="invisible" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
