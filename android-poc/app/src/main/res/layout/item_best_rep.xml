<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#1A3A2F"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Large Frame Image - Click to expand -->
        <FrameLayout
            android:id="@+id/frameContainer"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ivFrame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:background="#1A1A1A"
                android:visibility="gone"
                tools:visibility="visible"/>

            <!-- Placeholder when no frame -->
            <LinearLayout
                android:id="@+id/placeholderFrame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#2A4A3A"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏆"
                    android:textSize="48sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Best Performance"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Best Badge -->
            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="#CC4CAF50"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="🏆 Best Rep"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <!-- Score Badge -->
            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="8dp"
                android:background="#CC000000"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="#4CAF50"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Score: 95%"/>

            <!-- Tap to expand hint -->
            <TextView
                android:id="@+id/tvExpandHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:background="#88000000"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="🔍 Tap to expand"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:visibility="gone"/>

        </FrameLayout>

        <!-- Details Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Rep Number & Duration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvRepNumber"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Rep #3"/>

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#B0B0B0"
                    android:textSize="14sp"
                    tools:text="⏱ 2.1s"/>
            </LinearLayout>

            <!-- Reason/Message -->
            <TextView
                android:id="@+id/tvReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#A5D6A7"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                tools:text="✓ Excellent form! All joints in perfect position throughout the movement."/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
