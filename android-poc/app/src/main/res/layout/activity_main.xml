<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".ui.MainActivity">

    <!-- Camera Preview - Using FILL_START to match Google's implementation -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillStart" />

    <!-- Skeleton Overlay -->
    <com.trainingvalidator.poc.overlay.SkeletonOverlayView
        android:id="@+id/skeletonOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Info Panel -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/gradient_top"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Initializing..."
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFraming"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adjust your position"
            android:textColor="#FF9800"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvFps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FPS: --"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" | "
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvModelType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Model: --"
                android:textColor="@android:color/holo_green_light"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Angles Debug Panel (Scrollable) -->
    <ScrollView
        android:id="@+id/anglesPanel"
        android:layout_width="180dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/panel_background"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/topPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintHeight_max="300dp">

        <TextView
            android:id="@+id/tvAngles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Angles:\n--"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:fontFamily="monospace" />

    </ScrollView>

    <!-- Bottom Control Panel -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="24dp"
        android:background="@drawable/gradient_bottom"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Switch Camera Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSwitchCamera"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_switch_camera"
            app:iconSize="28dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:cornerRadius="30dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />
            
        <!-- Switch Model Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSwitchModel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Model: Full"
            android:textSize="12sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@android:color/white"
            app:strokeColor="@android:color/white" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Toggle Angles Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleAngles"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Hide Angles"
            android:textSize="12sp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <Space
            android:layout_width="8dp"
            android:layout_height="wrap_content" />

        <!-- Start Training Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartTraining"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Train"
            android:textSize="12sp"
            android:tag="btnStartTraining"
            app:backgroundTint="@android:color/holo_green_dark" />

    </LinearLayout>

    <!-- Permission Denied View -->
    <LinearLayout
        android:id="@+id/permissionView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@android:color/black"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/camera_permission_required"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textAlignment="center"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrantPermission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/grant_permission"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
