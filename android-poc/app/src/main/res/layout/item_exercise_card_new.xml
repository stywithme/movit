<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardExercise"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_xs"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/radius_base"
    app:cardElevation="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Placeholder for exercise image -->
        <View
            android:id="@+id/ivExerciseImage"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@color/surface_variant" />

        <!-- Bookmark icon -->
        <ImageView
            android:id="@+id/ivBookmark"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="@dimen/spacing_sm"
            android:background="@drawable/bg_circle_surface"
            android:padding="6dp"
            android:src="@drawable/ic_bookmark"
            app:tint="@color/text_tertiary"
            android:contentDescription="@string/cd_bookmark" />

        <!-- Content overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:padding="@dimen/spacing_sm"
            android:layout_marginTop="80dp">

            <TextView
                android:id="@+id/tvExerciseName"
                style="@style/TextAppearance.WayToFix.Body1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                tools:text="Squats" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_muscle"
                    app:tint="@color/primary"
                android:contentDescription="@string/cd_category" />

                <TextView
                    android:id="@+id/tvCategory"
                    style="@style/TextAppearance.WayToFix.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/text_tertiary"
                    tools:text="Legs &amp; Glutes" />

            </LinearLayout>

            <!-- Difficulty indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:gravity="center_vertical">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/dot_difficulty" />

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/dot_difficulty" />

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/dot_inactive" />

                <TextView
                    android:id="@+id/tvDifficulty"
                    style="@style/TextAppearance.WayToFix.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    tools:text="MEDIUM" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>
