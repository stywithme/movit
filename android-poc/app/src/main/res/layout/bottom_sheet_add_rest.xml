<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <TextView
        style="@style/TextAppearance.WayToFix.Headline3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add_rest_title"
        android:textColor="@color/text_primary" />

    <TextView
        style="@style/TextAppearance.WayToFix.Body2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:text="@string/add_rest_subtitle"
        android:textColor="@color/text_secondary" />

    <EditText
        android:id="@+id/inputRestSeconds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:hint="@string/rest_seconds_hint"
        android:inputType="number"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRest30"
            style="@style/Widget.WayToFix.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="30s" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRest45"
            style="@style/Widget.WayToFix.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:text="45s" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRest60"
            style="@style/Widget.WayToFix.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:text="60s" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddRest"
        style="@style/Widget.WayToFix.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="@string/add_rest_button" />

</LinearLayout>
