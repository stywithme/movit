<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="96dp">

        <LinearLayout
            style="@style/Widget.WayToFix.Header.MainTab">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_explore"
                    android:textAppearance="@style/TextAppearance.WayToFix.Headline2"
                    android:textColor="@color/text_primary" />

                <TextView
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/main_tab_header_explore_subtitle"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                style="@style/Widget.WayToFix.Avatar.Small"
                android:contentDescription="@string/cd_avatar"
                android:src="@drawable/ic_person" />

        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearch"
            style="@style/Widget.WayToFix.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="8dp"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="@color/text_tertiary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                style="@style/Widget.WayToFix.TextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/explore_search_hint"
                android:imeOptions="flagNoExtractUi|actionSearch"
                android:inputType="text"
                android:paddingVertical="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/screen_padding_horizontal"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPrimaryFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFilterAll"
                    style="@style/Widget.WayToFix.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFilterWorkouts"
                    style="@style/Widget.WayToFix.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/workouts" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFilterExercises"
                    style="@style/Widget.WayToFix.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/exercises" />
            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvResultsSummary"
            style="@style/TextAppearance.WayToFix.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_secondary"
            tools:text="18 workouts • 42 exercises" />

        <LinearLayout
            android:id="@+id/sectionWorkoutsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include
                android:id="@+id/headerWorkouts"
                layout="@layout/include_explore_section_header" />

            <HorizontalScrollView
                android:id="@+id/scrollWorkoutFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupWorkoutFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWorkoutAll"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/all" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWorkoutBeginner"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/explore_workout_filter_beginner" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWorkoutIntermediate"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/explore_workout_filter_intermediate" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWorkoutAdvanced"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/explore_workout_filter_advanced" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWorkoutShort"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/explore_workout_filter_short" />
                </com.google.android.material.chip.ChipGroup>

            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWorkouts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                tools:itemCount="4"
                tools:listitem="@layout/item_explore_workout_compact" />

            <TextView
                android:id="@+id/tvWorkoutsEmpty"
                style="@style/TextAppearance.WayToFix.Body2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="16dp"
                android:text="@string/explore_section_empty_workouts"
                android:textColor="@color/text_secondary"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionExercisesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include
                android:id="@+id/headerExercises"
                layout="@layout/include_explore_section_header" />

            <HorizontalScrollView
                android:id="@+id/scrollExerciseFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupExerciseFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="true"
                    app:singleSelection="true" />

            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvExercises"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                tools:itemCount="4"
                tools:listitem="@layout/item_explore_exercise_compact" />

            <TextView
                android:id="@+id/tvExercisesEmpty"
                style="@style/TextAppearance.WayToFix.Body2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="16dp"
                android:text="@string/explore_section_empty_exercises"
                android:textColor="@color/text_secondary"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="24dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_circle_surface">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/explore_empty_title"
                    android:src="@drawable/ic_search"
                    app:tint="@color/text_secondary" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvEmptyTitle"
                style="@style/TextAppearance.WayToFix.Headline3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/explore_empty_title" />

            <TextView
                android:id="@+id/tvEmptySubtitle"
                style="@style/TextAppearance.WayToFix.Body2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/explore_empty_subtitle"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

    </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>