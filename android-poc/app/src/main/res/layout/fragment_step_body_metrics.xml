<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.onboarding.steps.StepBodyMetricsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xl">

        <TextView
            style="@style/TextAppearance.WayToFix.Headline1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onb_metrics_title" />

        <TextView
            style="@style/TextAppearance.WayToFix.Body2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/onb_metrics_subtitle" />

        <!-- Weight -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextAppearance.WayToFix.Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/onb_weight_label" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleWeightUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKg"
                    style="@style/Widget.WayToFix.UnitToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onb_unit_kg" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLb"
                    style="@style/Widget.WayToFix.UnitToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onb_unit_lb" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>

        <TextView
            android:id="@+id/tvWeightValue"
            style="@style/TextAppearance.WayToFix.Display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:textColor="@color/primary"
            tools:text="70 kg" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:stepSize="0.5"
            android:valueFrom="30"
            android:valueTo="200"
            app:haloColor="@color/primary_light"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary"
            app:trackColorInactive="@color/surface_variant" />

        <!-- Height -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextAppearance.WayToFix.Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/onb_height_label" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleHeightUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCm"
                    style="@style/Widget.WayToFix.UnitToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onb_unit_cm" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFt"
                    style="@style/Widget.WayToFix.UnitToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onb_unit_ft" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>

        <TextView
            android:id="@+id/tvHeightValue"
            style="@style/TextAppearance.WayToFix.Display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:textColor="@color/primary"
            tools:text="170 cm" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderHeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:stepSize="1"
            android:valueFrom="120"
            android:valueTo="220"
            app:haloColor="@color/primary_light"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary"
            app:trackColorInactive="@color/surface_variant" />

    </LinearLayout>

</ScrollView>
