<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_3xl"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                android:paddingBottom="@dimen/spacing_sm">

                <TextView
                    style="@style/TextAppearance.WayToFix.Headline2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/exercise_library"
                    android:textColor="@color/text_primary" />

                <ImageButton
                    android:id="@+id/btnFilter"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_filter"
                    android:src="@drawable/ic_filter"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

            <!-- Search Bar -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSearch"
                style="@style/Widget.WayToFix.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_sm"
                app:boxCornerRadiusBottomEnd="@dimen/radius_lg"
                app:boxCornerRadiusBottomStart="@dimen/radius_lg"
                app:boxCornerRadiusTopEnd="@dimen/radius_lg"
                app:boxCornerRadiusTopStart="@dimen/radius_lg"
                app:startIconDrawable="@drawable/ic_search"
                app:startIconTint="@color/text_tertiary"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/search_exercise"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Category Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_base"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/screen_padding_horizontal">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/all"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLegs"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/legs" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipArms"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/arms" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCore"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/core" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBack"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/back_muscle" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipChest"
                        style="@style/Widget.WayToFix.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/chest" />

                </com.google.android.material.chip.ChipGroup>

            </HorizontalScrollView>

            <!-- Featured Program Section -->
            <TextView
                style="@style/TextAppearance.WayToFix.Headline3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/featured_program"
                android:textColor="@color/text_primary" />

            <!-- Featured Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFeatured"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Background image would go here -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_bottom" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_base">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_accent"
                            android:paddingHorizontal="@dimen/spacing_sm"
                            android:paddingVertical="@dimen/spacing_xs"
                            android:text="@string/ai_correction_enabled"
                            android:textColor="@color/on_primary"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Headline2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/featured_program_title"
                            android:textColor="@color/text_primary" />

                        <TextView
                            style="@style/TextAppearance.WayToFix.Body2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/featured_program_subtitle"
                            android:textColor="@color/text_secondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center_vertical">

                            <TextView
                                style="@style/TextAppearance.WayToFix.Caption"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/featured_program_meta"
                                android:textColor="@color/text_tertiary" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStartProgram"
                                style="@style/Widget.WayToFix.Button.Primary"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="@string/start"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <!-- Workouts Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_xl"
                android:gravity="center_vertical">

                <TextView
                    style="@style/TextAppearance.WayToFix.Headline3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/workouts"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvViewAllWorkouts"
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_xs"
                    android:text="@string/view_all"
                    android:textColor="@color/primary" />

            </LinearLayout>

            <!-- Workouts List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWorkouts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="@dimen/spacing_base"
                tools:itemCount="4"
                tools:listitem="@layout/item_workout_card_compact" />

            <!-- Workouts Empty State -->
            <LinearLayout
                android:id="@+id/layoutWorkoutsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_base"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_workouts_yet"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- Popular Exercises Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
                android:layout_marginTop="@dimen/spacing_xl"
                android:gravity="center_vertical">

                <TextView
                    style="@style/TextAppearance.WayToFix.Headline3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/popular_exercises"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvViewAll"
                    style="@style/TextAppearance.WayToFix.Body2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_xs"
                    android:text="@string/view_all"
                    android:textColor="@color/primary" />

            </LinearLayout>

            <!-- Exercise Grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvExercises"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="@dimen/spacing_base"
                tools:itemCount="4"
                tools:listitem="@layout/item_exercise_card" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_muscle"
                    app:tint="@color/text_tertiary"
                    android:contentDescription="@string/cd_no_exercises" />

                <TextView
                    android:id="@+id/tvEmpty"
                    style="@style/TextAppearance.WayToFix.Body1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_base"
                    android:text="@string/no_exercises_found"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
