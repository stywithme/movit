<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title=""
        app:titleTextColor="@color/text_primary"/>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomButtons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_base">

            <!-- Exercise Image Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="220dp">

                    <ImageView
                        android:id="@+id/ivExercisePreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/cd_exercise"
                        tools:background="@color/surface_variant"/>

                    <!-- Gradient Overlay -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_bottom"/>

                    <!-- Looping Preview Badge -->
                    <LinearLayout
                        android:id="@+id/badgeLoopingPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@drawable/glass_pill_background"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:paddingVertical="@dimen/spacing_xs"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_play"
                            app:tint="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_xs"
                            android:text="@string/looping_preview"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"/>

                    </LinearLayout>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Exercise Name -->
            <TextView
                android:id="@+id/tvExerciseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:textAppearance="@style/TextAppearance.WayToFix.Headline1"
                android:textColor="@color/text_primary"
                tools:text="القرفصاء"/>

            <!-- Muscles & Equipment Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Muscles -->
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_muscle"
                    app:tint="@color/primary"/>

                <TextView
                    android:id="@+id/tvMuscles"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    tools:text="عضلات الفخذ الأمامية &amp; عضلات المؤخرة"/>

            </LinearLayout>

            <!-- Equipment Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_equipment"
                    app:tint="@color/text_hint"/>

                <TextView
                    android:id="@+id/tvEquipment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="بدون معدات"/>

            </LinearLayout>

            <!-- Instructions Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/exercise_instructions"
                android:textAppearance="@style/TextAppearance.WayToFix.Headline3"
                android:textColor="@color/text_primary"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_base"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/tvInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_base"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"
                    tools:text="قف بشكل مستقيم، ثم انزل ببطء حتى تصل ركبتيك لزاوية 90 درجة"/>

            </androidx.cardview.widget.CardView>

            <!-- Camera Position Section -->
            <LinearLayout
                android:id="@+id/cameraPositionSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_xl"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/camera_position"
                    android:textAppearance="@style/TextAppearance.WayToFix.Headline3"
                    android:textColor="@color/text_primary"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/spacing_sm">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVariant1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        style="@style/Widget.WayToFix.Button.Secondary"
                        android:text="Front"
                        android:visibility="gone"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVariant2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_sm"
                        style="@style/Widget.WayToFix.Button.Secondary"
                        android:text="Side"
                        android:visibility="gone"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Hidden elements for compatibility -->
            <LinearLayout
                android:id="@+id/checklistContainer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                android:orientation="vertical"/>

            <TextView
                android:id="@+id/tvStepsCount"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/badgePro"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Buttons -->
    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_base"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Analyze Video Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnalyzeVideo"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            style="@style/Widget.WayToFix.Button.Secondary"
            android:text="@string/analyze_video"
            app:icon="@drawable/ic_video"
            app:iconGravity="start"
            app:iconTint="@color/text_primary"/>

        <!-- Start Camera Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartCamera"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            style="@style/Widget.WayToFix.Button.Primary"
            android:text="@string/start_camera"
            app:icon="@drawable/ic_camera"
            app:iconGravity="start"
            app:iconTint="@color/on_primary"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
