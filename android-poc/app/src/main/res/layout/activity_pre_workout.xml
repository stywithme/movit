<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- App Bar with Collapsing Image -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:fitsSystemWindows="true"
            app:contentScrim="@color/background"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:expandedTitleGravity="bottom"
            app:collapsedTitleGravity="center_vertical">

            <!-- Exercise Preview Image -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.7">

                <ImageView
                    android:id="@+id/ivExercisePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/cd_exercise"
                    tools:src="@drawable/gradient_report_hero"/>

                <!-- Gradient Overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_bottom"/>

                <!-- Looping Preview Badge -->
                <LinearLayout
                    android:id="@+id/badgeLoopingPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/glass_pill_background"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:paddingVertical="@dimen/spacing_xs"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_play"
                        app:tint="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:text="@string/looping_preview"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"/>

                </LinearLayout>

            </FrameLayout>

            <!-- Toolbar -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:title=""
                app:titleTextColor="@color/text_primary"/>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Exercise Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_base"
                android:layout_marginTop="-40dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <!-- Title Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvExerciseName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textAppearance="@style/TextAppearance.WayToFix.Headline1"
                            android:textColor="@color/text_primary"
                            tools:text="Squats"/>

                        <!-- PRO Badge -->
                        <TextView
                            android:id="@+id/badgePro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_accent"
                            android:paddingHorizontal="@dimen/spacing_sm"
                            android:paddingVertical="@dimen/spacing_xs"
                            android:text="⭐ PRO"
                            android:textColor="@color/on_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <!-- Meta Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Muscles -->
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_muscle"
                            app:tint="@color/primary"/>

                        <TextView
                            android:id="@+id/tvMuscles"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_xs"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            tools:text="Quads &amp; Glutes"/>

                        <View
                            android:layout_width="4dp"
                            android:layout_height="4dp"
                            android:layout_marginHorizontal="@dimen/spacing_sm"
                            android:background="@drawable/dot_inactive"/>

                        <!-- Equipment -->
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_equipment"
                            app:tint="@color/text_hint"/>

                        <TextView
                            android:id="@+id/tvEquipment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_xs"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            tools:text="No Equipment"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Form Checklist Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_xl"
                android:paddingHorizontal="@dimen/spacing_base">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/form_checklist"
                        android:textAppearance="@style/TextAppearance.WayToFix.Headline3"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvStepsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_hint"
                        android:textSize="14sp"
                        tools:text="4 steps"/>

                </LinearLayout>

                <!-- Checklist Items Container -->
                <LinearLayout
                    android:id="@+id/checklistContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="@dimen/spacing_md">

                    <!-- Checklist items will be added dynamically -->

                </LinearLayout>

            </LinearLayout>

            <!-- Camera Position Section (if multiple variants) -->
            <LinearLayout
                android:id="@+id/cameraPositionSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_xl"
                android:paddingHorizontal="@dimen/spacing_base"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/camera_position"
                    android:textAppearance="@style/TextAppearance.WayToFix.Headline3"
                    android:textColor="@color/text_primary"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/spacing_md">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVariant1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        style="@style/Widget.WayToFix.Button.Secondary"
                        android:text="Front"
                        android:visibility="gone"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVariant2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_sm"
                        style="@style/Widget.WayToFix.Button.Secondary"
                        android:text="Side"
                        android:visibility="gone"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/background"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_base"
        android:elevation="8dp">

        <!-- Analyze Video Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnalyzeVideo"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            style="@style/Widget.WayToFix.Button.Secondary"
            android:text="@string/analyze_video"
            app:icon="@drawable/ic_video"
            app:iconGravity="start"
            app:iconTint="@color/text_primary"/>

        <!-- Start Camera Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartCamera"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            style="@style/Widget.WayToFix.Button.Primary"
            android:text="@string/start_camera"
            app:icon="@drawable/ic_camera"
            app:iconGravity="start"
            app:iconTint="@color/on_primary"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
