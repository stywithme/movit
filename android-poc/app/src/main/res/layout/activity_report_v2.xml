<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/text_primary"
            app:title="@string/training_report"
            app:titleTextColor="@color/text_primary"
            app:menu="@menu/menu_report" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Hero Section -->
            <com.trainingvalidator.poc.ui.report.components.HeroSection
                android:id="@+id/heroSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Quick Insight -->
            <com.trainingvalidator.poc.ui.report.components.QuickInsightCard
                android:id="@+id/quickInsightCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />

            <!-- Section Title: Performance -->
            <TextView
                android:id="@+id/tvPerformanceTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:text="@string/your_performance"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Performance Cards (3 horizontal cards) -->
            <LinearLayout
                android:id="@+id/performanceCardsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:layout_marginTop="12dp">

                <!-- Form Card -->
                <com.trainingvalidator.poc.ui.report.components.PerformanceCard
                    android:id="@+id/formCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp" />

                <!-- Safety Card -->
                <com.trainingvalidator.poc.ui.report.components.PerformanceCard
                    android:id="@+id/safetyCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp" />

                <!-- Control Card -->
                <com.trainingvalidator.poc.ui.report.components.PerformanceCard
                    android:id="@+id/controlCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp" />

            </LinearLayout>

            <!-- Load Section (for weighted exercises) -->
            <LinearLayout
                android:id="@+id/loadSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_glass_card"
                    android:padding="12dp">

                    <!-- Weight -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvWeightLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏋️ Weight"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="20 kg" />

                    </LinearLayout>

                    <!-- Volume -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvVolumeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📦 Volume"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvVolume"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="240 kg" />

                    </LinearLayout>

                    <!-- Est 1RM -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvEst1RMLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💪 Est. 1RM"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvEst1RM"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/success"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="32 kg" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Section Title: Reps Journey -->
            <TextView
                android:id="@+id/tvRepsJourneyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:text="@string/reps_journey"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Reps Journey Chart -->
            <com.trainingvalidator.poc.ui.report.components.RepsJourneyChart
                android:id="@+id/repsJourneyChart"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_glass_card_subtle" />

            <!-- Reps Journey Summary -->
            <LinearLayout
                android:id="@+id/repsJourneySummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvRepsGood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/success"
                    android:textSize="13sp"
                    android:drawablePadding="8dp"
                    tools:text="🟢 العدات 1-8: أداء ثابت وممتاز" />

                <TextView
                    android:id="@+id/tvRepsFair"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/warning"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="🟡 العدات 9-10: تراجع طفيف" />

                <TextView
                    android:id="@+id/tvRepsBad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/error"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="🔴 العدات 11-12: تعب واضح" />

                <TextView
                    android:id="@+id/tvRepsTip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="💡 الجلسة القادمة: توقف عند 10 عدات للحفاظ على الجودة" />

            </LinearLayout>

            <!-- Key Moments Section -->
            <com.trainingvalidator.poc.ui.report.components.KeyMomentsSection
                android:id="@+id/keyMomentsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />

            <!-- Expandable Metrics Section -->
            <com.trainingvalidator.poc.ui.report.components.ExpandableMetricsSection
                android:id="@+id/expandableMetricsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <!-- Tips Section -->
            <LinearLayout
                android:id="@+id/tipsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Section Title -->
                <TextView
                    android:id="@+id/tvTipsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tips_for_you"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Tips Container (programmatically filled) -->
                <LinearLayout
                    android:id="@+id/tipsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Buttons -->
    <LinearLayout
        android:id="@+id/bottomButtonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@drawable/gradient_bottom_fade">

        <!-- Train Again Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTrainAgain"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/train_again"
            android:textColor="@color/primary"
            app:strokeColor="@color/primary"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_refresh"
            app:iconTint="@color/primary" />

        <!-- Done Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/done"
            android:textColor="@color/on_primary"
            android:backgroundTint="@color/primary"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_check"
            app:iconTint="@color/on_primary" />

    </LinearLayout>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primary" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
