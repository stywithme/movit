<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        WayToFix Design Tokens - Light mode
        Palette baseline: #8ECFE3, #C4D489, #282828, #E76D46, #D8DCDF.
        Keep existing resource names stable while screens migrate to shared components.
    -->

    <!-- Brand primitives -->
    <color name="brand_blue">#8ECFE3</color>
    <color name="brand_lime">#C4D489</color>
    <color name="brand_ink">#282828</color>
    <color name="brand_coral">#E76D46</color>
    <color name="brand_mist">#D8DCDF</color>

    <!-- Primary brand colors -->
    <color name="primary">@color/brand_blue</color>
    <color name="primary_variant">#6BBAD0</color>
    <color name="primary_light">#1A8ECFE3</color>
    <color name="on_primary">#282828</color>
    <color name="accent_soft">@color/brand_lime</color>
    <color name="accent_action">@color/brand_coral</color>
    <color name="on_accent_soft">@color/brand_ink</color>
