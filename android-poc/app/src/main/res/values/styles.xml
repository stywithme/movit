<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- BUTTONS -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="Widget.Movit.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:textAppearance">@style/TextAppearance.Movit.Button</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">@dimen/radius_xl</item>
        <item name="rippleColor">@color/primary_variant</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.Movit.Button.Primary.Small" parent="Widget.Movit.Button.Primary">
        <item name="android:layout_height">@dimen/button_height_small</item>
        <item name="android:minHeight">@dimen/button_height_small</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
    </style>

    <style name="Widget.Movit.Button.Tonal" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:textAppearance">@style/TextAppearance.Movit.Button</item>
        <item name="android:textColor">@color/on_accent_soft</item>
        <item name="backgroundTint">@color/accent_soft</item>
        <item name="cornerRadius">@dimen/radius_xl</item>
        <item name="rippleColor">@color/primary_light</item>
        <item name="elevation">0dp</item>
    </style>
    
    <style name="Widget.Movit.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:textAppearance">@style/TextAppearance.Movit.Button</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/surface_border</item>
        <item name="strokeWidth">@dimen/border_medium</item>
        <item name="cornerRadius">@dimen/radius_xl</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>
    
    <!-- Dialog Buttons -->
    <style name="Widget.Movit.Button.DialogPositive" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
    </style>
    
    <style name="Widget.Movit.Button.DialogNegative" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- INPUT FIELDS -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="Widget.Movit.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/surface_border</item>
        <item name="boxStrokeWidth">@dimen/border_medium</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_base</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_base</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_base</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_base</item>
        <item name="hintTextColor">@color/text_tertiary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>
    
    <style name="Widget.Movit.TextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textAppearance">@style/TextAppearance.Movit.Body1</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ONBOARDING -->
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- Forces NumberPicker text to render light on the dark surface (pre-API 29 has no textColor attr). -->
    <style name="ThemeOverlay.Movit.NumberPicker" parent="">
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="colorControlNormal">@color/text_secondary</item>
        <item name="colorAccent">@color/primary</item>
    </style>

    <!-- Selectable choice card (gender / goal / location). State driven via app:checkable. -->
    <style name="Widget.Movit.ChoiceCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/onboarding_card_bg</item>
        <item name="strokeColor">@color/onboarding_card_stroke</item>
        <item name="strokeWidth">@dimen/border_thick</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">0dp</item>
        <item name="android:checkable">true</item>
        <item name="checkedIcon">@null</item>
        <item name="rippleColor">@color/primary_light</item>
    </style>

    <!-- Segmented unit switch (kg/lb, cm/ft) inside a MaterialButtonToggleGroup. -->
    <style name="Widget.Movit.UnitToggle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/unit_toggle_text</item>
        <item name="android:textSize">@dimen/text_body_small</item>
        <item name="android:minWidth">52dp</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/unit_toggle_bg</item>
        <item name="strokeColor">@color/surface_border</item>
        <item name="rippleColor">@color/primary_light</item>
    </style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CARDS -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="Widget.Movit.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/radius_base</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">@dimen/spacing_base</item>
    </style>

    <style name="Widget.Movit.Card.Outlined" parent="Widget.Movit.Card">
        <item name="strokeColor">@color/surface_border</item>
        <item name="strokeWidth">@dimen/border_thin</item>
        <item name="rippleColor">@color/primary_light</item>
    </style>

    <style name="Widget.Movit.Card.List" parent="Widget.Movit.Card.Outlined">
        <item name="android:minHeight">@dimen/component_card_min_height</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Widget.Movit.Card.Stat" parent="Widget.Movit.Card.Outlined">
        <item name="android:minHeight">@dimen/component_stat_card_min_height</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
    </style>
    
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- SWITCHES -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="Widget.Movit.Switch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="thumbTint">@color/switch_thumb_tint</item>
        <item name="trackTint">@color/switch_track_tint</item>
    </style>
    
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- CHIPS -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="Widget.Movit.Chip.Filter" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_background_selector</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipStrokeColor">@color/surface_border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">@dimen/radius_xl</item>
        <item name="chipMinHeight">36dp</item>
        <item name="chipStartPadding">@dimen/spacing_md</item>
        <item name="chipEndPadding">@dimen/spacing_md</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- HEADERS & AVATARS -->
    <!-- Dot-separated style names imply a parent chain: each segment must exist. -->
    <!-- e.g. ShapeAppearanceOverlay.Movit.Circle needs ShapeAppearanceOverlay.Movit and ShapeAppearanceOverlay. -->
    <!-- e.g. Widget.Movit.Header needs Widget.Movit (Widget exists in the framework). -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="ShapeAppearanceOverlay" />
    <style name="ShapeAppearanceOverlay.Movit" />

    <style name="ShapeAppearanceOverlay.Movit.Circle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.Movit" parent="" />

    <style name="Widget.Movit.Header">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="Widget.Movit.Header.MainTab">
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">@dimen/screen_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/screen_padding_horizontal</item>
        <!-- Same top/bottom padding for all main-tab headers (title + optional subtitle + avatar) -->
        <item name="android:paddingTop">@dimen/spacing_3xl</item>
        <item name="android:paddingBottom">@dimen/spacing_3xl</item>
    </style>

    <!-- Ring matches legacy @drawable/bg_avatar_circle; stroke draws on top of the circular shape. -->
    <style name="Widget.Movit.Avatar">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.Movit.Circle</item>
        <item name="android:backgroundTint">@color/surface</item>
        <item name="strokeWidth">3dp</item>
        <item name="strokeColor">@color/surface_border</item>
        <item name="contentPadding">2dp</item>
        <item name="android:scaleType">centerCrop</item>
    </style>

    <style name="Widget.Movit.Avatar.Small">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
    </style>

    <style name="Widget.Movit.Avatar.Large">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">100dp</item>
    </style>
</resources>
