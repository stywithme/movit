<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- DISPLAY & HEADLINES -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="TextAppearance.WayToFix.Display" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:fontFamily">sans-serif-black</item> <!-- Fallback to sans-serif-black if Poppins not present -->
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>
    
    <style name="TextAppearance.WayToFix.Headline1" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">sans-serif-condensed-light</item>
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.WayToFix.Headline2" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_h2</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.WayToFix.Headline3" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_h3</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- BODY TEXT -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="TextAppearance.WayToFix.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.WayToFix.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/text_body_medium</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- LABELS & CAPTIONS -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="TextAppearance.WayToFix.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_body_small</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>
    
    <style name="TextAppearance.WayToFix.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/text_body_small</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>
    
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- BUTTON TEXT -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="TextAppearance.WayToFix.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:textAllCaps">false</item>
    </style>
    
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- NAVIGATION -->
    <!-- ═══════════════════════════════════════════════════ -->
    <style name="TextAppearance.WayToFix.NavLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">11sp</item>
    </style>
</resources>
