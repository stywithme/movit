<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera Permission -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-permission android:name="android.permission.CAMERA" />
    
    <!-- Network Permissions (for API sync and audio download) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Vibration Permission (for haptic feedback) -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- Video/Media Permissions for video analysis -->
    <!-- Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Android 12 and below -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" 
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WayToFix"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        android:localeConfig="@xml/locales_config"
        tools:targetApi="34">
        
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- AUTH FLOW -->
        <!-- ═══════════════════════════════════════════════════ -->
        
        <!-- Splash Screen - LAUNCHER -->
        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Onboarding -->
        <activity
            android:name=".ui.auth.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- Sign In -->
        <activity
            android:name=".ui.auth.SignInActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix"
            android:windowSoftInputMode="adjustResize" />
        
        <!-- Sign Up -->
        <activity
            android:name=".ui.auth.SignUpActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix"
            android:windowSoftInputMode="adjustResize" />
        
        <!-- Forgot Password -->
        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix"
            android:windowSoftInputMode="adjustResize" />
        
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- PROFILE -->
        <!-- ═══════════════════════════════════════════════════ -->
        
        <!-- Profile -->
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- MAIN CONTAINER (Bottom Navigation) -->
        <!-- ═══════════════════════════════════════════════════ -->
        
        <activity
            android:name=".ui.main.MainContainerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- EXERCISE & TRAINING FLOW -->
        <!-- ═══════════════════════════════════════════════════ -->
        
        <!-- Exercise List (Legacy - kept for compatibility) -->
        <activity
            android:name=".ui.ExerciseListActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- Exercise Detail -->
        <activity
            android:name=".ui.ExerciseDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- Pre-Workout Screen (New Design) -->
        <activity
            android:name=".ui.PreWorkoutActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- Post-Workout Report Screen (New Design) -->
        <activity
            android:name=".ui.PostWorkoutActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- Training Activity -->
        <activity
            android:name=".ui.TrainingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix.Training" />
        
        <!-- Main Activity (Camera Demo) -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix.Training" />
        
        <!-- Workout Detail Activity (Timeline before start) -->
        <activity
            android:name=".ui.WorkoutDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Workout List Activity -->
        <activity
            android:name=".ui.WorkoutListActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- Workout Activity (runs workout sessions) -->
        <activity
            android:name=".ui.WorkoutActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix.Training" />
        
        <!-- Post-Training Report Pager Activity (Full-screen swipeable) -->
        <activity
            android:name=".ui.report.ReportPagerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
    </application>

</manifest>
