<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera Permission -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-permission android:name="android.permission.CAMERA" />
    
    <!-- Network Permissions (for API sync and audio download) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Vibration Permission (for haptic feedback) -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- Video/Media Permissions for video analysis -->
    <!-- Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Android 12 and below -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" 
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TrainingValidatorPoC"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        
        <!-- Exercise List - LAUNCHER -->
        <activity
            android:name=".ui.ExerciseListActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.TrainingValidatorPoC">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Exercise Detail -->
        <activity
            android:name=".ui.ExerciseDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.TrainingValidatorPoC" />
        
        <!-- Training Activity -->
        <activity
            android:name=".ui.TrainingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.TrainingValidatorPoC" />
        
        <!-- Original MainActivity (Demo Mode) -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.TrainingValidatorPoC" />
        
        <!-- Workout List Activity -->
        <activity
            android:name=".ui.WorkoutListActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.TrainingValidatorPoC" />
        
        <!-- Workout Activity (runs workout sessions) -->
        <activity
            android:name=".ui.WorkoutActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.TrainingValidatorPoC" />
        
        <!-- Post-Training Report Activity -->
        <activity
            android:name=".ui.report.ReportActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.TrainingValidatorPoC" />
        
    </application>

</manifest>
