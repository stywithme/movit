<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera Permission -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-permission android:name="android.permission.CAMERA" />
    
    <!-- Network Permissions (for API sync and audio download) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Vibration Permission (for haptic feedback) -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- Video/Media Permissions for video analysis -->
    <!-- Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Android 12 and below -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" 
        android:maxSdkVersion="32" />

    <application
        android:name=".PoseApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WayToFix"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        android:localeConfig="@xml/locales_config"
        tools:targetApi="34">
        
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- AUTH FLOW -->
        <!-- ═══════════════════════════════════════════════════ -->
        
        <!-- Splash Screen - LAUNCHER -->
        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Onboarding -->
        <activity
            android:name=".ui.auth.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- Sign In -->
        <activity
            android:name=".ui.auth.SignInActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix"
            android:windowSoftInputMode="adjustResize" />
        
        <!-- Sign Up -->
        <activity
            android:name=".ui.auth.SignUpActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix"
            android:windowSoftInputMode="adjustResize" />
        
        <!-- Forgot Password -->
        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix"
            android:windowSoftInputMode="adjustResize" />
        
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- PROFILE -->
        <!-- ═══════════════════════════════════════════════════ -->
        
        <!-- Profile -->
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <activity
            android:name=".ui.subscription.SubscriptionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- MAIN CONTAINER (Bottom Navigation) -->
        <!-- ═══════════════════════════════════════════════════ -->
        
        <activity
            android:name=".ui.main.MainContainerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- EXERCISE & TRAINING FLOW -->
        <!-- ═══════════════════════════════════════════════════ -->
        
        <!-- Exercise List (Legacy - kept for compatibility) -->
        <activity
            android:name=".ui.exercises.ExerciseListActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- Exercise Detail -->
        <activity
            android:name=".ui.exercises.ExerciseDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- Pre-Workout Screen (New Design) -->
        <activity
            android:name=".ui.train.PreWorkoutActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- (Removed: PostWorkoutActivity — dead code) -->
        
        <!-- Training Activity -->
        <activity
            android:name=".ui.train.TrainingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix.Training" />
        
        <!-- Main Activity (Camera Demo) -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix.Training" />
        
        <!-- Debug Activity (Measurement Testing) -->
        <activity
            android:name=".ui.debug.DebugActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix.Training" />
        
        <!-- Workout Detail Activity (Timeline before start) -->
        <activity
            android:name=".ui.workouts.WorkoutDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Workout List Activity -->
        <activity
            android:name=".ui.workouts.WorkoutListActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Workout Session Activity — Explore mode multi-exercise sequencer -->
        <activity
            android:name=".ui.workouts.WorkoutSessionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Workout Customize Activity — Pre-training customization -->
        <activity
            android:name=".ui.workouts.WorkoutCustomizeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Quick Start Activity — Build a free session from the exercise library -->
        <activity
            android:name=".ui.workouts.QuickStartActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Program List Activity -->
        <activity
            android:name=".ui.programs.ProgramListActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Program Detail Activity -->
        <activity
            android:name=".ui.programs.ProgramDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Program Day Activity -->
        <activity
            android:name=".ui.programs.ProgramDayActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Program Session Activity -->
        <activity
            android:name=".ui.programs.ProgramSessionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <activity
            android:name=".ui.programs.ProgramSessionReportActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Weekly Report Activity -->
        <activity
            android:name=".ui.programs.WeeklyReportActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />
        
        <!-- Exercise History Activity -->
        <activity
            android:name=".ui.exercises.ExerciseHistoryActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <activity
            android:name=".ui.report.ReportPagerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <activity
            android:name=".ui.report.SessionReportActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- BODY SCAN / ASSESSMENT -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- PAR-Q+ Pre-Screening -->
        <activity
            android:name=".assessment.ui.PreScreeningActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Assessment Session (workout flow) -->
        <activity
            android:name=".assessment.ui.AssessmentSessionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Assessment Results -->
        <activity
            android:name=".assessment.ui.AssessmentResultActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LEVEL SYSTEM -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- Level Profile -->
        <activity
            android:name=".ui.level.LevelProfileActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- Plan Overview (Timeline) -->
        <activity
            android:name=".ui.programs.PlanOverviewActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.WayToFix" />

        <!-- FileProvider for screenshot sharing -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
