<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- USER: Enable In-App Purchase for App ID com.movit.iosApp in Apple Developer → Identifiers → Capabilities. -->
	<!-- Provisioning profiles must be regenerated after enabling the capability. -->
	<key>com.apple.developer.in-app-purchases</key>
	<true/>
</dict>
</plist>
