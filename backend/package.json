{
  "name": "fix-fit-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build -b swc",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx --env-file=.env prisma/seed.ts",
    "prisma:seed:full": "tsx --env-file=.env prisma/seed.ts --full",
    "export:exercises-json": "tsx --env-file=.env prisma/export-exercises-json-from-db.ts",
    "seed:permissions": "tsx --env-file=.env prisma/run-permissions-seed.ts",
    "seed:attributes": "tsx --env-file=.env prisma/run-attributes-only.ts",
    "seed:system-messages": "tsx --env-file=.env prisma/run-system-messages-seed.ts",
    "seed:pose-positions": "tsx --env-file=.env prisma/run-pose-positions-seed.ts",
    "seed:unified-refactor": "tsx --env-file=.env prisma/run-unified-refactor-seed.ts",
    "seed:exercise-json": "tsx --env-file=.env prisma/run-exercise-json-seed.ts",
    "seed:exercise-group3": "tsx --env-file=.env prisma/run-exercise-json-seed.ts --dir=prisma/Exercise-json/exercise-group-3/exercises-from-db",
    "seed:exercise-group3:dry": "tsx --env-file=.env prisma/run-exercise-json-seed.ts --dir=prisma/Exercise-json/exercise-group-3/exercises-from-db --dry-run",
    "build:missing-exercises-json": "tsx prisma/build-missing-exercises-json.ts",
    "seed:missing-exercises": "tsx --env-file=.env prisma/run-exercise-json-seed.ts --dir=prisma/Exercise-json/missing-exercises/exercises-from-db",
    "seed:missing-exercises:dry": "tsx --env-file=.env prisma/run-exercise-json-seed.ts --dir=prisma/Exercise-json/missing-exercises/exercises-from-db --dry-run",
    "migrate:remove-rest-days": "tsx --env-file=.env scripts/migrate-remove-program-rest-days.ts",
    "redis:up": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-redis-dev.ps1",
    "redis:down": "powershell -NoProfile -Command \"Get-Process redis-server -ErrorAction SilentlyContinue | Where-Object { $_.Path -like '*backend\\\\tools\\\\redis-win*' } | Stop-Process -Force\"",
    "redis:docker:up": "docker compose -f docker-compose.redis.yml up -d",
    "redis:docker:down": "docker compose -f docker-compose.redis.yml down",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^3.1.0",
    "@casl/ability": "^6.8.0",
    "@google-cloud/storage": "^7.19.0",
    "@google/genai": "^1.40.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.67.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "prisma": "^7.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.18",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "glob": "^13.0.6"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
