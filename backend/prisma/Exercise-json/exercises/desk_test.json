{
  "name": {
    "ar": "اختبار اليد (مكتب)",
    "en": "Desk Hand Test"
  },
  "description": {
    "ar": "تمرين سريع لاختبار صحة الوضعية باستخدام اليدين فقط",
    "en": "Quick hand exercise to test position validation"
  },
  "instructions": {
    "ar": "ارفع يديك بجانب رأسك (شكل حرف W). حافظ على تماثل اليدين.",
    "en": "Raise hands beside head (W shape). Keep hands symmetrical."
  },
  "category": {
    "code": "test",
    "name": {
      "ar": "اختبار",
      "en": "Test"
    }
  },
  "countingMethod": "hold",
  "muscles": ["shoulders"],
  "equipment": ["bodyweight"],
  "tags": ["test", "desk"],
  "repCountingConfig": {
    "duration": 20,
    "gracePeriodMs": 2000
  },
  "poseVariants": [
    {
      "name": {
        "ar": "أمام الكاميرا",
        "en": "Front View"
      },
      "cameraPosition": "sitting_front_upper",
      "expectedFacingDirection": "facing_camera",
      "positionChecks": [
        {
          "id": "wrist_symmetry",
          "type": "horizontal_alignment",
          "landmarks": {
            "primary": "left_wrist",
            "secondary": "right_wrist"
          },
          "condition": {
            "operator": "approximately_equal",
            "threshold": 0.10
          },
          "activePhases": ["all", "top"],
          "errorMessage": {
            "ar": "اجعل اليدين في مستوى واحد",
            "en": "Keep wrists level"
          },
          "severity": "warning",
          "cooldownMs": 500,
          "minErrorFrames": 2
        },
        {
          "id": "hands_high_enough",
          "type": "vertical_comparison",
          "landmarks": {
            "primary": "left_wrist",
            "secondary": "nose"
          },
          "condition": {
            "operator": "should_not_exceed", 
            "threshold": -0.05
          },
          "activePhases": ["all", "top"],
          "errorMessage": {
            "ar": "ارفع يديك أعلى من مستوى الأنف",
            "en": "Raise hands above nose level"
          },
          "severity": "error",
          "cooldownMs": 500,
          "minErrorFrames": 2
        },
        {
          "id": "elbow_alignment",
          "type": "vertical_alignment",
          "landmarks": {
            "primary": "right_elbow",
            "secondary": "right_shoulder"
          },
          "condition": {
            "operator": "approximately_equal",
            "threshold": 0.15
          },
          "activePhases": ["all", "top"],
          "errorMessage": {
            "ar": "حاول محاذاة الكوع مع الكتف رأسياً",
            "en": "Align elbow under shoulder"
          },
          "severity": "tip",
          "cooldownMs": 1000,
          "minErrorFrames": 2
        },
        {
          "id": "elbows_level_check",
          "type": "horizontal_alignment",
          "landmarks": {
            "primary": "left_elbow",
            "secondary": "right_elbow"
          },
          "condition": {
            "operator": "approximately_equal",
            "threshold": 0.10
          },
          "activePhases": ["all", "top"],
          "errorMessage": {
            "ar": "اجعل الكوعين في مستوى واحد",
            "en": "Keep both elbows at the same level"
          },
          "severity": "warning",
          "cooldownMs": 500,
          "minErrorFrames": 2
        }
      ],
      "trackedJoints": [
        {
          "joint": "right_elbow",
          "role": "primary",
          "startPose": { "min": 0, "max": 180 },
          "range": {
            "perfect": { "min": 75, "max": 105 },
            "normal": { "min": 65, "max": 118 },
            "pad": { "min": 55, "max": 128 },
            "warning": { "min": 45, "max": 65 },
            "danger": { "min": 0, "max": 45 }
          },
          "stateMessages": {
            "perfect": { "ar": "ممتاز! وضعية صحيحة", "en": "Perfect! Correct position" }
          }
        }
      ],
      "feedbackMessages": {
        "motivational": [],
        "tips": []
      }
    }
  ]
