{
  "name": {
    "ar": "راحة الساعد",
    "en": "Forearm rest"
  },
  "description": {
    "ar": "وضعية راحة للساعد والرسغ بعد الجهد",
    "en": "Rest position for forearm and wrist after effort"
  },
  "instructions": {
    "ar": "أرحِ الساعد على مسند بزاوية مريحة دون إجهاد",
    "en": "Rest the forearm on a support at a comfortable angle without strain"
  },
  "category": {
    "code": "arms",
    "name": {
      "ar": "تمارين الذراعين",
      "en": "Arms"
    }
  },
  "countingMethod": "up_down",
  "muscles": ["biceps", "forearms"],
  "equipment": ["bodyweight", "dumbbell"],
  "tags": [],
  "repCountingConfig": {
    "reps": 12,
    "minRepIntervalMs": 1200,
    "maxRepIntervalMs": 4500
  },
  "poseVariants": [
    {
      "name": {
        "ar": "زاوية جانبية",
        "en": "Side View"
      },
      "cameraPosition": "side_view",
      "trackedJoints": [
        {
          "joint": "right_elbow",
          "role": "primary",
          "invertIndicator": true,
          "_invertIndicator_comment": "Lower limb (forearm) moves UP towards shoulder, so invert indicator direction",
          "startPose": {
            "min": 50,
            "max": 180
          },
          "upRange": {
            "perfect": { "min": 168, "max": 180 },
            "normal": { "min": 165, "max": 180 },
            "pad": { "min": 166, "max": 180 }
          },
          "downRange": {
            "perfect": { "min": 125, "max": 158 },
            "normal": { "min": 115, "max": 162 },
            "pad": { "min": 105, "max": 164 },
            "warning": { "min": 90, "max": 120 }
          },
          "stateMessages": {
            "perfect": {
              "up": { "ar": "ممتاز! ذراعك مفرودة", "en": "Perfect! Arm extended" },
              "down": { "ar": "ممتاز! ثني مثالي", "en": "Perfect! Great curl" }
            },
            "normal": {
              "up": { "ar": "جيد، حاول فرد الذراع أكثر", "en": "Good, try extending more" },
              "down": { "ar": "جيد، حاول الثني أكثر", "en": "Good, try curling more" }
            },
            "pad": {
              "down": { "ar": "مقبول، اقترب من الكتف أكثر", "en": "Acceptable, get closer to shoulder" }
            },
            "warning": {
              "up": { "ar": "افرد ذراعك أكثر", "en": "Extend your arm more" },
              "down": { "ar": "اثنِ المرفق أكثر", "en": "Bend your elbow more" }
            }
          }
        },
        {
          "joint": "right_shoulder",
          "role": "secondary",
          "startPose": {
            "min": 0,
            "max": 100
          },
          "range": {
            "perfect": { "min": 0, "max": 50 },
            "normal": { "min": 0, "max": 60 },
            "pad": { "min": 0, "max": 70 },
            "warning": { "min": 70, "max": 100 }
          },
          "stateMessages": {
            "perfect": { "ar": "ممتاز - الذراع ثابتة", "en": "Great - arm is stable" },
            "warning": { "ar": "اجعل ذراعك بجانب جسمك", "en": "Keep your arm close to your body" }
          }
        }
      ],
      "feedbackMessages": {
        "motivational": [
          { "ar": "ممتاز! عضلات قوية!", "en": "Excellent! Strong muscles!" },
          { "ar": "أداء رائع!", "en": "Great performance!" },
          { "ar": "استمر! أنت تتحسن!", "en": "Keep it up! You're improving!" }
        ],
        "tips": [
          { "ar": "حافظ على ثبات مرفقك بجانب جسمك", "en": "Keep your elbow fixed at your side" },
          { "ar": "تنفس: زفير عند الرفع، شهيق عند الإنزال", "en": "Breathe: exhale lifting, inhale lowering" },
          { "ar": "ركز على انقباض العضلة في أعلى الحركة", "en": "Focus on squeezing at the top" },
          { "ar": "لا تحرك مرفقك - فقط الساعد", "en": "Don't move your elbow - only the forearm" }
        ]
      }
    }
