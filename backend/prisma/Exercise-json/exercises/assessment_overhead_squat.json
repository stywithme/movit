        "tips": [
          { "ar": "خذ وقتك، بإيقاع مريح", "en": "Take your time, comfortable pace" },
          { "ar": "ارفع ذراعيك فوق رأسك", "en": "Keep arms overhead" },
          { "ar": "انزل ببطء واصعد ببطء", "en": "Go down slowly and come up slowly" }
        ]
