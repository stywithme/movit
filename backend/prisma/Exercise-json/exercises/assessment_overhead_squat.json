              "down": { "ar": "عمق ممتاز", "en": "Great depth" }
            },
            "normal": {
              "down": { "ar": "جيد", "en": "Good" }
            }
          },
          "pairedWith": "left_knee"
        },
        {
          "joint": "left_hip",
          "role": "secondary",
          "startPose": { "min": 120, "max": 180 },
          "range": {
            "perfect": { "min": 150, "max": 175 },
