    "en": "Stand straight, bend left elbow to curl weight toward shoulder. Keep right arm still."
  },
  "category": {
    "code": "arms",
    "name": {
      "ar": "تمارين الذراعين",
      "en": "Arms"
    }
  },
  "countingMethod": "up_down",
  "muscles": ["biceps", "forearms"],
  "equipment": ["dumbbell"],
  "tags": ["isolation", "upper-body", "single-arm", "left"],
  "repCountingConfig": {
    "reps": 12,
    "minRepIntervalMs": 1200,
    "maxRepIntervalMs": 4000
  },
