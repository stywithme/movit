model Booking {
  id               String        @id @default(uuid())
  userId           String
  adminId          String
  startAt          DateTime
  endAt            DateTime
  status           BookingStatus @default(payment_pending)
  amount           Float         @default(0)
  isRescheduled    Boolean       @default(false)
  paymentStatus    String?
  paymentId        String?
  paymentGateway   String?
  cancelledBy      String?
  sessionUrl       String?
  sessionMeetingId String?
  sessionPlatform  String?
  notes            String?
  /// Who created this booking: 'doctor' | 'admin' | 'user'
  madeByType       String?
  /// ID of the creator (admin or user)
  madeById         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin   Admin           @relation("DoctorBookings", fields: [adminId], references: [id])
  reports BookingReport[]

  @@index([userId])
  @@index([adminId])
  @@index([status])
  @@index([startAt])
  @@index([madeByType])
  @@index([adminId, startAt, endAt])
  @@map("bookings")
}

model DoctorWorkTime {
  id        String @id @default(uuid())
  adminId   String
  day       String
  startTime String
  endTime   String

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([adminId, day])
  @@map("doctor_work_times")
}

model CloseTime {
  id       String   @id @default(uuid())
  adminId  String?
  fromDate DateTime
  toDate   DateTime
  fromTime String
  toTime   String

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([fromDate, toDate])
  @@map("close_times")
}

model BookingReport {
  id          String   @id @default(uuid())
  bookingId   String
  adminId     String
  content     Json
  attachments Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  admin   Admin   @relation(fields: [adminId], references: [id])

  @@index([bookingId])
  @@index([adminId])
  @@map("booking_reports")
}

enum BookingStatus {
  payment_pending
  pending
  confirmed
  completed
  canceled
}

model Plan {
  id                        String         @id @default(uuid())
  name                      Json
  description               Json?
  monthlyPrice              Decimal        @db.Decimal(10, 2)
  yearlyPrice               Decimal        @db.Decimal(10, 2)
  currency                  String         @default("EGP")
  discount                  Decimal?       @default(0) @db.Decimal(10, 2)
  maxExercisesLimit         Int            @default(0)
  maxWorkoutsLimit          Int            @default(0)
  freeDoctorSessionsLimit   Int            @default(0)
  monthlyGooglePlayProductId String?
  yearlyGooglePlayProductId  String?
  features                  Json?
  isActive                  Boolean        @default(true)
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  subscriptions             Subscription[]
  subscriptionCheckouts     SubscriptionCheckout[]

  @@map("plans")
}

model Subscription {
  id               String       @id @default(uuid())
  userId           String
  planId           String
  status           String       @default("active")
  billingPeriod    String       @default("monthly")
  gateway          String       @default("manual")
  amountPaid       Decimal      @db.Decimal(10, 2)
  startDate        DateTime     @default(now())
  endDate          DateTime
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  autoRenew       Boolean      @default(false)
  cancelAtPeriodEnd Boolean    @default(false)
  cancelledAt     DateTime?
  upgradedFromId  String?
  googlePlayPackageName String?
  googlePlayProductId   String?
  googlePlayPurchaseToken String? @unique
  googlePlayOrderId     String?
  myFatoorahInvoiceId   String?
  myFatoorahPaymentId   String?
  lastVerifiedAt  DateTime?
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             User         @relation(fields: [userId], references: [id])
  plan             Plan         @relation(fields: [planId], references: [id])
  checkouts        SubscriptionCheckout[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([userId, status])
  @@index([endDate])
  @@index([googlePlayProductId])
  @@index([myFatoorahInvoiceId])
  @@index([myFatoorahPaymentId])
  @@map("subscriptions")
}

model SubscriptionCheckout {
  id                    String        @id @default(uuid())
  userId                String
  planId                String
  subscriptionId        String?
  gateway               String        @default("myfatoorah")
  billingPeriod         String
  status                String        @default("pending")
  currency              String        @default("EGP")
  amount                Decimal       @db.Decimal(10, 2)
  paymentUrl            String?
  myFatoorahInvoiceId   String?
  myFatoorahPaymentId   String?
  googlePlayProductId   String?
  googlePlayPurchaseToken String?
  idempotencyKey        String?       @unique
  expiresAt             DateTime?
  paidAt                DateTime?
  cancelledAt           DateTime?
  failedAt              DateTime?
  lastError             String?
  rawPayload            Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                  Plan          @relation(fields: [planId], references: [id])
  subscription          Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([planId])
  @@index([subscriptionId])
  @@index([gateway])
  @@index([status])
  @@index([myFatoorahInvoiceId])
  @@index([myFatoorahPaymentId])
  @@index([googlePlayPurchaseToken])
  @@map("subscription_checkouts")
}
