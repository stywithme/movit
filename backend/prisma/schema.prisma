generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Attribute types (category, muscle, equipment, tag, counting_method, etc.)
model Attribute {
  id          String           @id @default(uuid())
  code        String           @unique
  name        Json
  description String?
  sortOrder   Int              @default(0)
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  values      AttributeValue[]

  @@map("attributes")
}

/// Attribute values (legs, chest, beginner, left_knee, etc.)
model AttributeValue {
  id                        String              @id @default(uuid())
  attributeId               String
  code                      String              @unique
  name                      Json
  description               Json?
  icon                      String?
  color                     String?
  sortOrder                 Int                 @default(0)
  isActive                  Boolean             @default(true)
  createdAt                 DateTime            @default(now())
  metadata                  Json?
  attribute                 Attribute           @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  difficultyLevelsAsType    DifficultyLevel[]   @relation("DifficultyLevelType")
  exerciseAttributes        ExerciseAttribute[]
  exercisesAsCategory       Exercise[]          @relation("ExerciseCategory")
  exercisesAsCountingMethod Exercise[]          @relation("ExerciseCountingMethod")
  posePositionJoints        PosePositionJoint[] @relation("PosePositionJoint")
  programAttributes         ProgramAttribute[]
  assessmentAttributes     AssessmentAttribute[]

  @@index([attributeId])
  @@map("attribute_values")
}

/// Main exercise entity
model Exercise {
  id                        String                       @id @default(uuid())
  categoryId                String
  countingMethodId          String
  name                      Json
  description               Json?
  instructions              Json?
  slug                      String                       @unique
  status                    ContentStatus                @default(draft)
  repCountingConfig         Json?
  supportsWeight            Boolean                      @default(false)
  minWeight                 Float?
  maxWeight                 Float?
  defaultWeight             Float?
  isBilateral               Boolean                      @default(false)
  bilateralConfig           Json?
  reportMetrics             Json?
  publishedAt               DateTime?
  createdBy                 String?
  updatedBy                 String?
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  deletedAt                 DateTime?
  isFeatured                Boolean                      @default(false)
  assessmentTemplateEntries AssessmentTemplateExercise[]
  attributes                ExerciseAttribute[]
  media                     ExerciseMedia[]
  category                  AttributeValue               @relation("ExerciseCategory", fields: [categoryId], references: [id])
  countingMethod            AttributeValue               @relation("ExerciseCountingMethod", fields: [countingMethodId], references: [id])
  poseVariants              PoseVariant[]
  archetype                 ExerciseArchetype?
  movementPattern           MovementPattern?
  loadCapability            LoadCapability?
  familyKey                 String?
  familyOrder               Int?
  programSessionItems       ProgramSessionItem[]
  trainingSessions          TrainingSession[]
  workoutExercises          WorkoutExercise[]
  progressionProfile        ExerciseProgressionProfile?
  progressionStates         UserProgramExerciseProgressionState[]
  userExercisePreferences   UserExercisePreference[]

  @@index([categoryId])
  @@index([countingMethodId])
  @@index([status])
  @@index([deletedAt])
  @@map("exercises")
}

/// Per-user overrides for standalone exercise targets (reps, hold duration, weight)
model UserExercisePreference {
  id                String   @id @default(uuid())
  userId            String
  exerciseId        String
  customReps        Int?
  customDurationSec Int?
  customWeightKg    Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
  @@map("user_exercise_preferences")
}

/// Exercise attributes (muscles, equipment, tags - many-to-many)
model ExerciseAttribute {
  id               String         @id @default(uuid())
  exerciseId       String
  attributeValueId String
  createdAt        DateTime       @default(now())
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)
  exercise         Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, attributeValueId])
  @@index([exerciseId])
  @@index([attributeValueId])
  @@map("exercise_attributes")
}

/// Exercise media (images, videos)
model ExerciseMedia {
  id         String   @id @default(uuid())
  exerciseId String
  type       String
  url        String
  altText    String?
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("exercise_media")
}

/// Pose positions (standing_front, prone_side, supine_front, etc.)
model PosePosition {
  id           String              @id @default(uuid())
  code         String              @unique
  name         Json
  description  Json?
  imageUrl     String?
  isActive     Boolean             @default(true)
  sortOrder    Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  postures     Json                @default("[\"any\"]")
  directions   Json                @default("[\"any\"]")
  regions      Json                @default("[\"any\"]")
  joints       PosePositionJoint[]
  poseVariants PoseVariant[]

  @@map("pose_positions")
}

/// Joints relevant for each pose position
model PosePositionJoint {
  id             String         @id @default(uuid())
  posePositionId String
  jointId        String
  createdAt      DateTime       @default(now())
  joint          AttributeValue @relation("PosePositionJoint", fields: [jointId], references: [id])
  posePosition   PosePosition   @relation(fields: [posePositionId], references: [id], onDelete: Cascade)

  @@unique([posePositionId, jointId])
  @@index([posePositionId])
  @@index([jointId])
  @@map("pose_position_joints")
}

/// Pose variants (different pose positions for an exercise)
model PoseVariant {
  id                  String                      @id @default(uuid())
  exerciseId          String
  posePositionId      String
  name                Json
  description         Json?
  trackedJointsConfig Json?
  sortOrder           Int                         @default(0)
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  difficultyLevels    DifficultyLevel[]
  messageAssignments  FeedbackMessageAssignment[]
  exercise            Exercise                    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  posePosition        PosePosition                @relation(fields: [posePositionId], references: [id])
  positionChecks      PositionCheck[]

  @@index([exerciseId])
  @@index([posePositionId])
  @@map("pose_variants")
}

/// Position-based validation checks (knee over toe, hip alignment, etc.)
model PositionCheck {
  id             String      @id @default(uuid())
  poseVariantId  String
  checkId        String
  type           String
  landmarks      Json
  condition      Json
  activePhases   Json
  errorMessage   Json
  severity       String      @default("warning")
  cooldownMs     Int         @default(2000)
  minErrorFrames Int         @default(3)
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  poseVariant    PoseVariant @relation(fields: [poseVariantId], references: [id], onDelete: Cascade)

  @@unique([poseVariantId, checkId])
  @@index([poseVariantId])
  @@map("position_checks")
}

/// Difficulty levels for each pose variant
model DifficultyLevel {
  id                String         @id @default(uuid())
  poseVariantId     String
  difficultyTypeId  String
  name              Json
  description       Json?
  repCountingConfig Json?
  phases            Json?
  romConfig         Json?
  sortOrder         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  difficultyType    AttributeValue @relation("DifficultyLevelType", fields: [difficultyTypeId], references: [id])
  poseVariant       PoseVariant    @relation(fields: [poseVariantId], references: [id], onDelete: Cascade)

  @@index([poseVariantId])
  @@index([difficultyTypeId])
  @@map("difficulty_levels")
}

/// Reusable feedback message templates (library)
model FeedbackMessageTemplate {
  id          String                      @id @default(uuid())
  code        String                      @unique
  category    String
  context     String?
  /// Where/why this message is used (system messages; shown read-only in dashboard)
  description String?
  content     Json
  tags        String[]
  isSystem    Boolean                     @default(false)
  isActive    Boolean                     @default(true)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  assignments FeedbackMessageAssignment[]

  @@index([category, context])
  @@index([isActive])
  @@map("feedback_message_templates")
}

/// Assign reusable messages to a specific pose variant context
model FeedbackMessageAssignment {
  id            String                  @id @default(uuid())
  poseVariantId String
  messageId     String
  target        String
  context       String?
  jointCode     String?
  zone          String?
  checkId       String?
  sortOrder     Int                     @default(0)
  createdAt     DateTime                @default(now())
  message       FeedbackMessageTemplate @relation(fields: [messageId], references: [id])
  poseVariant   PoseVariant             @relation(fields: [poseVariantId], references: [id], onDelete: Cascade)

  @@index([poseVariantId])
  @@index([messageId])
  @@index([target, context])
  @@map("feedback_message_assignments")
}

/// Workout - Super Set or Circuit training session
model Workout {
  id                   String               @id @default(uuid())
  name                 Json
  description          Json?
  slug                 String               @unique
  coverImageUrl        String?
  difficulty           Difficulty           @default(beginner)
  estimatedDurationMin Int?
  tags                 Json?
  status               ContentStatus        @default(draft)
  publishedAt          DateTime?
  createdBy            String?
  updatedBy            String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  isFeatured           Boolean              @default(false)
  programSessionItems  ProgramSessionItem[]
  exercises            WorkoutExercise[]

  @@index([status])
  @@index([deletedAt])
  @@map("workouts")
}

/// WorkoutExercise - Exercise within a workout with specific configuration
model WorkoutExercise {
  id                  String   @id @default(uuid())
  workoutId           String
  exerciseId          String
  variantIndex        Int      @default(0)
  difficulty          String   @default("beginner")
  targetReps          Int?
  targetDuration      Int?
  sets                Int      @default(1)
  restBetweenSetsMs   Int      @default(30000)
  restAfterExerciseMs Int      @default(60000)
  weightKg            Float?
  weightPerSet        Json?
  notes               Json?
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  exercise            Exercise @relation(fields: [exerciseId], references: [id])
  workout             Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId])
  @@index([exerciseId])
  @@map("workout_exercises")
}

model Program {
  id                    String                 @id @default(uuid())
  name                  Json
  description           Json?
  slug                  String                 @unique
  coverImageUrl         String?
  durationWeeks         Int
  /// @deprecated Derive from levelRangeMin/Max or remove; matching uses ProgramAttribute + level range.
  difficulty            Difficulty             @default(beginner)
  isDefault             Boolean                @default(false)
  isPublished           Boolean                @default(false)
  tags                  Json?
  createdBy             String?
  updatedBy             String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  /// @deprecated Use ProgramAttribute with attribute `body_region` and mode EXCLUDED.
  contraindications       String[]               @default([])
  entryRecommendations    Json?
  exitRecommendations     Json?
  levelRangeMax         Int                    @default(5)
  levelRangeMin         Int                    @default(1)
  nextProgramId         String?
  prerequisiteProgramId String?
  prescriptionPriority  Int                    @default(100)
  /// @deprecated Use ProgramAttribute with attribute `focus`.
  targetDomain          String?
  /// @deprecated Use ProgramAttribute with attribute `body_region`.
  targetRegions         String[]               @default([])
  /// @deprecated Use ProgramAttribute with attribute `equipment`.
  targetEquipment       Json?
  programType           ProgramType            @default(SYSTEM)
  /// @deprecated Use ProgramAttribute with attribute `domain`.
  programDomain         ProgramDomain          @default(TRAINING)
  /// @deprecated Use ProgramAttribute with attribute `goal`.
  trainingGoal          TrainingGoal?
  autoAssignable        Boolean                @default(false)
  version               Int                    @default(1)
  ownerId               String?
  forkedFromId          String?
  coachingNotes         Json?
  weeklySessionTarget   Int?
  estimatedSessionMinutes Int?
  isFeatured            Boolean                @default(false)
  programSessionReports ProgramSessionReport[]
  programAttributes     ProgramAttribute[]
  weeks                 ProgramWeek[]
  nextProgram           Program?               @relation("ProgramNext", fields: [nextProgramId], references: [id])
  previousPrograms      Program[]              @relation("ProgramNext")
  prerequisiteProgram   Program?               @relation("ProgramChain", fields: [prerequisiteProgramId], references: [id])
  dependentPrograms     Program[]              @relation("ProgramChain")
  forkedFrom            Program?               @relation("ProgramFork", fields: [forkedFromId], references: [id])
  forkedPrograms        Program[]              @relation("ProgramFork")
  progressionRules      ProgressionRule[]
  userPrograms          UserProgram[]

  @@index([deletedAt])
  @@index([isPublished])
  @@index([programType])
  @@index([programDomain])
  @@index([levelRangeMin, levelRangeMax])
  @@map("programs")
}

/// Program matching dimensions (domain, goal, equipment, etc.) — reuses AttributeValue catalog with Exercise.
model ProgramAttribute {
  id               String                @id @default(uuid())
  programId        String
  attributeValueId String
  mode             ProgramAttributeMode  @default(REQUIRED)
  createdAt        DateTime              @default(now())
  program          Program               @relation(fields: [programId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue        @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([programId, attributeValueId])
  @@index([programId])
  @@index([attributeValueId])
  @@map("program_attributes")
}

model ProgramWeek {
  id          String       @id @default(uuid())
  programId   String
  weekNumber  Int
  name        Json?
  description Json?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  weekType    WeekType     @default(NORMAL)
  days        ProgramDay[]
  program     Program      @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, weekNumber])
  @@index([programId])
  @@map("program_weeks")
}

model ProgramDay {
  id        String           @id @default(uuid())
  weekId    String
  dayNumber Int
  isRestDay Boolean          @default(false)
  name      Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  dayType   String           @default("training")
  dayFocus  String?
  week      ProgramWeek      @relation(fields: [weekId], references: [id], onDelete: Cascade)
  sessions  ProgramSession[]

  @@unique([weekId, dayNumber])
  @@index([weekId])
  @@map("program_days")
}

model ProgramSession {
  id                   String                 @id @default(uuid())
  dayId                String
  name                 Json
  sortOrder            Int                    @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  estimatedDurationMin Int?
  sessionCategory      String?
  items                ProgramSessionItem[]
  reports              ProgramSessionReport[]
  day                  ProgramDay             @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
  @@map("program_sessions")
}

model ProgramSessionItem {
  id                String           @id @default(uuid())
  sessionId         String
  sortOrder         Int              @default(0)
  type              String
  exerciseId        String?
  sets              Int?             @default(1)
  targetReps        Int?
  targetDuration    Int?
  restBetweenSetsMs Int?             @default(30000)
  weightKg          Float?
  weightPerSet      Json?
  notes             Json?
  restDurationMs    Int?
  sourceWorkoutId   String?
  isModified        Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  allowedSubstitutions String[]       @default([])
  role              SessionItemRole?
  intent            SessionItemIntent?
  coachingNotes     Json?
  difficultyCode    String?
  isPersonalized    Boolean          @default(false)
  levelOverride     Int?
  progressionRuleId String?
  targetFormScore   Float?
  targetROM         Float?
  exercise          Exercise?        @relation(fields: [exerciseId], references: [id])
  progressionRule   ProgressionRule? @relation(fields: [progressionRuleId], references: [id])
  session           ProgramSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceWorkout     Workout?         @relation(fields: [sourceWorkoutId], references: [id])
  userProgramOverrides UserProgramOverride[]

  @@index([sessionId])
  @@index([exerciseId])
  @@index([sourceWorkoutId])
  @@index([progressionRuleId])
  @@map("program_session_items")
}

model UserProgram {
  id              String                @id @default(uuid())
  userId          String
  programId       String?
  name            Json?
  startDate       DateTime              @default(now())
  isActive        Boolean               @default(true)
  customizations  Json?
  /// When set, calendar day index is frozen (pause duration subtracted until resume adds to totalPausedDays).
  pausedAt        DateTime?
  /// Cumulative calendar days excluded from program timeline (from completed pauses).
  totalPausedDays Int                   @default(0)
  /// Last time server-side customizations were changed (coach/admin); used for mobile sync conflict resolution.
  customizationsUpdatedAt DateTime?
  templateVersion Int                   @default(1)
  assignmentReason Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  activePlanSlots    ActivePlanProgram[]
  progress           UserProgramProgress[]
  progressionStates  UserProgramExerciseProgressionState[]
  overrides          UserProgramOverride[]
  program            Program?              @relation(fields: [programId], references: [id])
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([programId])
  @@map("user_programs")
}

/// User-specific overrides applied on top of program template (effective plan).
model UserProgramOverride {
  id             String             @id @default(uuid())
  userProgramId  String
  weekNumber     Int
  dayNumber      Int
  sessionItemId  String
  overrideType   OverrideType
  reasonCode     OverrideReason?
  data           Json?
  appliedBy      OverrideAppliedBy  @default(USER)
  createdAt      DateTime           @default(now())
  userProgram    UserProgram        @relation(fields: [userProgramId], references: [id], onDelete: Cascade)
  sessionItem    ProgramSessionItem @relation(fields: [sessionItemId], references: [id], onDelete: Cascade)

  @@index([userProgramId, weekNumber, dayNumber])
  @@index([sessionItemId])
  @@map("user_program_overrides")
}

model UserProgramProgress {
  id            String         @id @default(uuid())
  userProgramId String
  weekNumber    Int
  dayNumber     Int
  sessionId     String         @default("__day__")
  completedAt   DateTime?
  status        ProgressStatus @default(pending)
  userProgram   UserProgram    @relation(fields: [userProgramId], references: [id], onDelete: Cascade)

  @@unique([userProgramId, weekNumber, dayNumber, sessionId])
  @@index([userProgramId])
  @@index([userProgramId, weekNumber])
  @@map("user_program_progress")
}

model ProgramSessionReport {
  id               String         @id @default(uuid())
  userId           String
  programId        String?
  programSessionId String
  weekNumber       Int
  dayNumber        Int
  startedAt        DateTime       @default(now())
  completedAt      DateTime?
  status           ReportStatus   @default(in_progress)
  totalDurationMs  Int?
  totalExercises   Int?
  totalSets        Int?
  completedSets    Int?
  totalReps        Int?
  avgAccuracy      Float?
  avgFormScore     Float?
  /// User-reported perceived exertion (1–10) after session completion.
  rpe              Int?
  report           Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  program          Program?       @relation(fields: [programId], references: [id])
  programSession   ProgramSession @relation(fields: [programSessionId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([programId])
  @@index([programSessionId])
  @@index([userId, programId])
  @@index([userId, programSessionId, status])
  @@index([userId, weekNumber, dayNumber])
  @@map("program_session_reports")
}

model System {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system")
}

model Role {
  id            String           @id @default(uuid())
  name          String           @unique
  displayName   Json
  description   Json?
  isSystem      Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  modelHasRoles ModelHasRole[]
  permissions   RolePermission[]

  @@map("roles")
}

model ModelHasRole {
  roleId    String
  modelId   String
  modelType String
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, modelId, modelType])
  @@index([modelId, modelType])
  @@index([roleId])
  @@map("model_has_roles")
}

model Permission {
  id        String           @id @default(uuid())
  subject   String
  action    String
  createdAt DateTime         @default(now())
  roles     RolePermission[]

  @@unique([subject, action])
  @@index([subject])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// Admin users for the dashboard
model Admin {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  name             String
  isActive         Boolean   @default(true)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  isSuperAdmin     Boolean   @default(false)
  isDoctor         Boolean   @default(false)

  bookingsAsDoctor Booking[]        @relation("DoctorBookings")
  workTimes        DoctorWorkTime[]
  closeTimes       CloseTime[]
  bookingReports   BookingReport[]

  @@index([isSuperAdmin])
  @@map("admins")
}

/// Mobile app users
model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  password              String?
  name                  String
  avatarUrl             String?
  googleId              String?                @unique
  provider              String                 @default("email")
  preferredLanguage     String                 @default("en")
  voiceFeedback         Boolean                @default(true)
  notifications         Boolean                @default(true)
  isPro                 Boolean                @default(false)
  subscriptionExpiry    DateTime?
  totalWorkouts         Int                    @default(0)
  totalMinutes          Int                    @default(0)
  resetToken            String?
  resetTokenExpiry      DateTime?
  isActive              Boolean                @default(true)
  emailVerified         Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  activePlan            ActivePlan?
  bodyScanResults       BodyScanResult[]
  programSessionReports ProgramSessionReport[]
  progressionHistory    ProgressionHistory[]
  reassessmentSchedules ReassessmentSchedule[]
  refreshTokens         RefreshToken[]
  trainingSessions      TrainingSession[]
  levelProfiles         UserLevelProfile[]
  userPrograms          UserProgram[]
  userExercisePreferences UserExercisePreference[]
  bookings              Booking[]
  subscriptions         Subscription[]
  subscriptionCheckouts SubscriptionCheckout[]
  trainingGoal          TrainingGoal           @default(GENERAL_HEALTH)
  trainingProfile       TrainingProfile?

  @@index([email])
  @@index([googleId])
  @@map("users")
}

/// Training profile collected from user (onboarding); 1:1 with User.
model TrainingProfile {
  id                       String    @id @default(uuid())
  userId                   String    @unique
  heightCm                 Float?
  weightKg                 Float?
  dateOfBirth              DateTime?
  biologicalSex            String?
  currentActivityLevel     String?
  trainingExperienceMonths Int?
  resistanceExperience     String?
  availableDaysPerWeek     Int?
  maxSessionMinutes        Int?
  availableEquipment       Json?
  trainingLocation         String?
  knownInjuries            Json?
  healthDisclaimerAccepted Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("training_profiles")
}

/// Refresh tokens for JWT authentication
model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  deviceInfo String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Level - Named training stage (1-5). Defines difficulty tier and default training parameters.
model Level {
  id                       String               @id @default(uuid())
  number                   Int                  @unique
  code                     String               @unique
  name                     Json
  description              Json?
  icon                     String?
  color                    String?
  entryThreshold           Float
  defaultSetsMin           Int                  @default(2)
  defaultSetsMax           Int                  @default(3)
  defaultRepsMin           Int                  @default(8)
  defaultRepsMax           Int                  @default(12)
  defaultIntensityGuide    String               @default("bodyweight_only")
  defaultRestBetweenSetsMs Int                  @default(60000)
  defaultSessionDurMin     Int                  @default(20)
  defaultSessionDurMax     Int                  @default(30)
  defaultWeeklyFreqMin     Int                  @default(2)
  defaultWeeklyFreqMax     Int                  @default(3)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  maxThreshold             Float?
  assessmentTemplates      AssessmentTemplate[]

  @@map("levels")
}

/// UserLevelProfile - Snapshot of user's current level across all dimensions.
/// Updated after each assessment.
model UserLevelProfile {
  id              String         @id @default(uuid())
  userId          String
  overallLevel    Int
  bodyScore       Float
  domainLevels    Json
  regionLevels    Json
  limitingFactors Json
  assessmentId    String         @unique
  classifiedAt    DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  assessment      BodyScanResult @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, classifiedAt])
  @@map("user_level_profiles")
}

/// ActivePlan — User's current training schedule with ordered programs.
model ActivePlan {
  id        String              @id @default(uuid())
  userId    String              @unique
  status    String              @default("active")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  programs  ActivePlanProgram[]
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("active_plans")
}

/// ActivePlanProgram — A program slot within the active plan.
model ActivePlanProgram {
  id                 String      @id @default(uuid())
  activePlanId       String
  userProgramId      String
  sortOrder          Int         @default(0)
  status             String      @default("upcoming")
  scheduledStartDate DateTime?
  actualStartDate    DateTime?
  completedAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  activePlan         ActivePlan  @relation(fields: [activePlanId], references: [id], onDelete: Cascade)
  userProgram        UserProgram @relation(fields: [userProgramId], references: [id], onDelete: Cascade)

  @@index([activePlanId])
  @@index([userProgramId])
  @@map("active_plan_programs")
}

/// ProgressionRule — Defines how training parameters change based on performance.
model ProgressionRule {
  id           String               @id @default(uuid())
  name         String
  scope        String
  programId    String?
  exerciseSlug String?
  trigger      String
  conditions   Json
  action       Json
  priority     Int                  @default(0)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  items        ProgramSessionItem[]
  history      ProgressionHistory[]
  program      Program?             @relation(fields: [programId], references: [id])

  @@index([scope])
  @@index([programId])
  @@index([isActive])
  @@map("progression_rules")
}

/// ExerciseProgressionProfile — Scientific progression template per exercise.
/// Single source of truth for how an exercise should progress.
model ExerciseProgressionProfile {
  id              String            @id @default(uuid())
  exerciseId      String            @unique
  archetype       ExerciseArchetype
  allowedAxes     Json
  priorityOrder   Json
  repAxis         Json?
  loadAxis        Json?
  durationAxis    Json?
  setAxis         Json?
  difficultyLadder Json?
  qualityGate     Json
  promotionPolicy Json
  regressionPolicy Json
  isAutoGenerated Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([archetype])
  @@map("exercise_progression_profiles")
}

/// UserProgramExerciseProgressionState — Dynamic progression state per user+program+exercise.
/// Tracks where the user currently is in their progression journey.
model UserProgramExerciseProgressionState {
  id                    String    @id @default(uuid())
  userProgramId         String
  exerciseId            String
  currentAxis           String
  currentDifficultyCode String?
  currentWeightKg       Float?
  currentTargetReps     Int?
  currentTargetDuration Int?
  currentTargetSets     Int?
  successStreak         Int       @default(0)
  regressionStreak      Int       @default(0)
  lastProgressedAt      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userProgram UserProgram @relation(fields: [userProgramId], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userProgramId, exerciseId])
  @@index([userProgramId])
  @@index([exerciseId])
  @@map("user_program_exercise_progression_state")
}

/// ProgressionHistory — Audit log of every change made by the Progression Engine.
model ProgressionHistory {
  id            String   @id @default(uuid())
  userId        String
  ruleId        String?
  sessionId     String?
  field         String
  previousValue Float
  newValue      Float
  reason        String
  appliedAt     DateTime @default(now())

  decisionType        String?
  axis                String?
  eligibilitySnapshot Json?
  stateBefore         Json?
  stateAfter          Json?

  seen   Boolean   @default(false)
  seenAt DateTime?

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule ProgressionRule? @relation(fields: [ruleId], references: [id])

  @@index([userId])
  @@index([ruleId])
  @@index([userId, appliedAt])
  @@index([userId, seen])
  @@map("progression_history")
}

/// ReassessmentSchedule — Tracks when users should be reassessed.
model ReassessmentSchedule {
  id            String          @id @default(uuid())
  userId        String
  reason        String
  scheduledDate DateTime
  status        String          @default("pending")
  assessmentId  String?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  assessment    BodyScanResult? @relation(fields: [assessmentId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([scheduledDate])
  @@map("reassessment_schedules")
}

model AssessmentTemplate {
  id            String                       @id @default(uuid())
  name          Json
  description   Json?
  type          String                       @default("initial")
  targetLevelId String?
  levelRangeMin Int                          @default(1)
  levelRangeMax Int                          @default(5)
  domainWeights Json                         @default("{\"safety\": 0.20, \"control\": 0.25, \"mobility\": 0.35, \"symmetry\": 0.20}")
  isDefault     Boolean                      @default(false)
  isPublished   Boolean                      @default(false)
  sortOrder     Int                          @default(0)
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  deletedAt     DateTime?
  exercises              AssessmentTemplateExercise[]
  assessmentAttributes   AssessmentAttribute[]
  targetLevel            Level?                       @relation(fields: [targetLevelId], references: [id])
  assessments            BodyScanResult[]

  @@index([type])
  @@index([targetLevelId])
  @@index([isPublished])
  @@map("assessment_templates")
}

/// Assessment template matching dimensions (same pattern as ProgramAttribute).
model AssessmentAttribute {
  id               String                @id @default(uuid())
  templateId       String
  attributeValueId String
  mode             ProgramAttributeMode  @default(REQUIRED)
  createdAt        DateTime              @default(now())
  template         AssessmentTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue        @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([templateId, attributeValueId])
  @@index([templateId])
  @@index([attributeValueId])
  @@map("assessment_attributes")
}

model AssessmentTemplateExercise {
  id                   String             @id @default(uuid())
  templateId           String
  exerciseId           String
  sortOrder            Int                @default(0)
  targetRegion         String
  side                 String             @default("center")
  entryType            String             @default("core")
  activationCondition  Json?
  referenceNormDegrees Float?
  thresholds           Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  exercise             Exercise           @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  template             AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, exerciseId])
  @@index([templateId])
  @@index([exerciseId])
  @@map("assessment_template_exercises")
}

/// Body Scan result - Complete assessment snapshot
model BodyScanResult {
  id                    String                 @id @default(uuid())
  userId                String
  type                  String                 @default("initial")
  bodyScore             Float
  mobilityScore         Float
  controlScore          Float
  symmetryScore         Float?
  safetyScore           Float
  fitnessLevel          String
  regions               Json
  symmetryData          Json?
  hypotheses            Json?
  recommendations       Json?
  rawReportIds          Json?
  previousId            String?
  durationMs            Int?
  movementCount         Int                    @default(3)
  completedAt           DateTime               @default(now())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  templateId            String?
  previous              BodyScanResult?        @relation("AssessmentProgress", fields: [previousId], references: [id])
  nextAssessments       BodyScanResult[]       @relation("AssessmentProgress")
  template              AssessmentTemplate?    @relation(fields: [templateId], references: [id])
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reassessmentSchedules ReassessmentSchedule[]
  levelProfiles         UserLevelProfile?

  @@index([userId])
  @@index([userId, type])
  @@index([userId, completedAt])
  @@index([templateId])
  @@map("body_scan_results")
}

/// Training session - A completed exercise session
model TrainingSession {
  id String @id @default(uuid())

  // Foreign keys
  userId     String
  exerciseId String

  // Session info
  timestamp  DateTime // When session started
  durationMs Int // Total duration in milliseconds

  // Rep counts
  totalReps   Int
  countedReps Int // Reps with PERFECT/NORMAL/PAD state
  invalidReps Int // Reps with DANGER state

  // Weight info (optional - for weighted exercises)
  weightKg   Float?
  weightUnit String @default("kg") // kg or lbs

  // Session context — tracks the source/mode of the session
  context   String @default("free") // free | program | assessment | explore_workout | quick_start

  // Grouping — links sessions done together in Explore/Quick Start mode
  groupId   String? // Shared ID for sessions performed in the same multi-exercise free session

  // Source workout — if session was started from a Workout template
  workoutId String?

  // Legacy report data (images, danger alerts, etc.)
  legacyReport Json? // PostTrainingReport for backward compatibility

  // Sync status
  deviceId String? // Device that uploaded this session

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise       Exercise        @relation(fields: [exerciseId], references: [id])
  sessionMetrics SessionMetrics?
  repMetrics     RepMetrics[]

  @@index([userId])
  @@index([exerciseId])
  @@index([timestamp])
  @@index([userId, exerciseId])
  @@index([groupId])
  @@index([context])
  @@map("training_sessions")
}

/// Session-level aggregated metrics
model SessionMetrics {
  id                   String          @id @default(uuid())
  sessionId            String          @unique
  avgRom               Int
  avgSymmetry          Int?
  avgStability         Int
  avgVelocity          Int?
  avgFormScore         Int
  avgAlignmentAccuracy Int
  avgTempo             Json
  totalTUT             Int
  totalVolume          Float?
  maxWeight            Float?
  est1RM               Float?
  relativeStrength     Float?
  intensityPercentage  Float?
  formConsistency      Int?
  fatigueIndex         Int?
  createdAt            DateTime        @default(now())
  session              TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_metrics")
}

/// Individual rep metrics
model RepMetrics {
  id                String          @id @default(uuid())
  sessionId         String
  repNumber         Int
  durationMs        Int
  worstState        Int
  score             Int
  weightKg          Float?
  rom               Int
  symmetry          Int?
  stability         Int
  velocity          Int?
  formScore         Int
  alignmentAccuracy Int
  tempo             Json
  createdAt         DateTime        @default(now())
  session           TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, repNumber])
  @@map("rep_metrics")
}

