generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Attribute types (category, muscle, equipment, tag, counting_method, etc.)
model Attribute {
  id          String           @id @default(uuid())
  code        String           @unique
  name        Json
  description String?
  sortOrder   Int              @default(0)
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  values      AttributeValue[]

  @@map("attributes")
}

/// Attribute values (legs, chest, beginner, left_knee, etc.)
model AttributeValue {
  id                        String                @id @default(uuid())
  attributeId               String
  code                      String                @unique
  name                      Json
  description               Json?
  icon                      String?
  color                     String?
  sortOrder                 Int                   @default(0)
  isActive                  Boolean               @default(true)
  createdAt                 DateTime              @default(now())
  metadata                  Json?
  attribute                 Attribute             @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  difficultyLevelsAsType    DifficultyLevel[]     @relation("DifficultyLevelType")
  exerciseAttributes        ExerciseAttribute[]
  exercisesAsCategory       Exercise[]            @relation("ExerciseCategory")
  exercisesAsCountingMethod Exercise[]            @relation("ExerciseCountingMethod")
  posePositionJoints        PosePositionJoint[]   @relation("PosePositionJoint")
  programAttributes         ProgramAttribute[]
  programDayAttributes      ProgramDayAttribute[]
  assessmentAttributes      AssessmentAttribute[]

  @@index([attributeId])
  @@map("attribute_values")
}

/// Main exercise entity
model Exercise {
  id                        String                                @id @default(uuid())
  categoryId                String
  countingMethodId          String
  name                      Json
  description               Json?
  instructions              Json?
  slug                      String                                @unique
  status                    ContentStatus                         @default(draft)
  repCountingConfig         Json?
  supportsWeight            Boolean                               @default(false)
  minWeight                 Float?
  maxWeight                 Float?
  defaultWeight             Float?
  isBilateral               Boolean                               @default(false)
  bilateralConfig           Json?
  reportMetrics             Json?
  publishedAt               DateTime?
  createdBy                 String?
  updatedBy                 String?
  createdAt                 DateTime                              @default(now())
  updatedAt                 DateTime                              @updatedAt
  deletedAt                 DateTime?
  levelId                   String?
  isFeatured                Boolean                               @default(false)
  assessmentTemplateEntries AssessmentTemplateExercise[]
  attributes                ExerciseAttribute[]
  media                     ExerciseMedia[]
  category                  AttributeValue                        @relation("ExerciseCategory", fields: [categoryId], references: [id])
  countingMethod            AttributeValue                        @relation("ExerciseCountingMethod", fields: [countingMethodId], references: [id])
  level                     Level?                                @relation(fields: [levelId], references: [id])
  poseVariants              PoseVariant[]
  archetype                 ExerciseArchetype?
  movementPattern           MovementPattern?
  loadCapability            LoadCapability?
  familyKey                 String?
  familyOrder               Int?
  intent                    WorkoutItemIntent?
  coachingNotes             Json?
  plannedWorkoutItems       PlannedWorkoutItem[]
  workoutExecutions         WorkoutExecution[]
  workoutTemplateExercises  WorkoutTemplateExercise[]
  progressionRules          ProgressionRule[]
  progressionProfile        ExerciseProgressionProfile?
  progressionStates         UserProgramExerciseProgressionState[]
  userExercisePreferences   UserExercisePreference[]

  @@index([categoryId])
  @@index([countingMethodId])
  @@index([levelId])
  @@index([status])
  @@index([deletedAt])
  @@map("exercises")
}

/// Per-user overrides for standalone exercise targets (reps, hold duration, weight)
model UserExercisePreference {
  id                String   @id @default(uuid())
  userId            String
  exerciseId        String
  customReps        Int?
  customDurationSec Int?
  customWeightKg    Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
  @@map("user_exercise_preferences")
}

/// Exercise attributes (muscles, equipment, tags - many-to-many)
model ExerciseAttribute {
  id               String         @id @default(uuid())
  exerciseId       String
  attributeValueId String
  createdAt        DateTime       @default(now())
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)
  exercise         Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, attributeValueId])
  @@index([exerciseId])
  @@index([attributeValueId])
  @@map("exercise_attributes")
}

/// Exercise media (images, videos)
model ExerciseMedia {
  id         String   @id @default(uuid())
  exerciseId String
  type       String
  url        String
  altText    String?
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("exercise_media")
}

/// Pose positions (standing_front, prone_side, supine_front, etc.)
model PosePosition {
  id           String              @id @default(uuid())
  code         String              @unique
  name         Json
  description  Json?
  imageUrl     String?
  isActive     Boolean             @default(true)
  sortOrder    Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  postures     Json                @default("[\"any\"]")
  directions   Json                @default("[\"any\"]")
  regions      Json                @default("[\"any\"]")
  joints       PosePositionJoint[]
  poseVariants PoseVariant[]

  @@map("pose_positions")
}

/// Joints relevant for each pose position
model PosePositionJoint {
  id             String         @id @default(uuid())
  posePositionId String
  jointId        String
  createdAt      DateTime       @default(now())
  joint          AttributeValue @relation("PosePositionJoint", fields: [jointId], references: [id])
  posePosition   PosePosition   @relation(fields: [posePositionId], references: [id], onDelete: Cascade)

  @@unique([posePositionId, jointId])
  @@index([posePositionId])
  @@index([jointId])
  @@map("pose_position_joints")
}

/// Pose variants (different pose positions for an exercise)
model PoseVariant {
  id                  String                      @id @default(uuid())
  exerciseId          String
  posePositionId      String
  name                Json
  description         Json?
  trackedJointsConfig Json?
  sortOrder           Int                         @default(0)
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  difficultyLevels    DifficultyLevel[]
  messageAssignments  FeedbackMessageAssignment[]
  exercise            Exercise                    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  posePosition        PosePosition                @relation(fields: [posePositionId], references: [id])
  positionChecks      PositionCheck[]

  @@index([exerciseId])
  @@index([posePositionId])
  @@map("pose_variants")
}

/// Position-based validation checks (knee over toe, hip alignment, etc.)
model PositionCheck {
  id             String      @id @default(uuid())
  poseVariantId  String
  checkId        String
  type           String
  landmarks      Json
  condition      Json
  activePhases   Json
  errorMessage   Json
  severity       String      @default("warning")
  cooldownMs     Int         @default(2000)
  minErrorFrames Int         @default(3)
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  poseVariant    PoseVariant @relation(fields: [poseVariantId], references: [id], onDelete: Cascade)

  @@unique([poseVariantId, checkId])
  @@index([poseVariantId])
  @@map("position_checks")
}

/// Difficulty levels for each pose variant
model DifficultyLevel {
  id                String         @id @default(uuid())
  poseVariantId     String
  difficultyTypeId  String
  name              Json
  description       Json?
  repCountingConfig Json?
  phases            Json?
  romConfig         Json?
  sortOrder         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  difficultyType    AttributeValue @relation("DifficultyLevelType", fields: [difficultyTypeId], references: [id])
  poseVariant       PoseVariant    @relation(fields: [poseVariantId], references: [id], onDelete: Cascade)

  @@index([poseVariantId])
  @@index([difficultyTypeId])
  @@map("difficulty_levels")
}

/// Reusable feedback message templates (library)
model FeedbackMessageTemplate {
  id          String                      @id @default(uuid())
  code        String                      @unique
  category    String
  context     String?
  /// Where/why this message is used (system messages; shown read-only in dashboard)
  description String?
  content     Json
  tags        String[]
  isSystem    Boolean                     @default(false)
  isActive    Boolean                     @default(true)
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  assignments FeedbackMessageAssignment[]

  @@index([category, context])
  @@index([isActive])
  @@map("feedback_message_templates")
}

/// Assign reusable messages to a specific pose variant context
model FeedbackMessageAssignment {
  id            String                  @id @default(uuid())
  poseVariantId String
  messageId     String
  target        String
  context       String?
  jointCode     String?
  zone          String?
  checkId       String?
  sortOrder     Int                     @default(0)
  createdAt     DateTime                @default(now())
  message       FeedbackMessageTemplate @relation(fields: [messageId], references: [id])
  poseVariant   PoseVariant             @relation(fields: [poseVariantId], references: [id], onDelete: Cascade)

  @@index([poseVariantId])
  @@index([messageId])
  @@index([target, context])
  @@map("feedback_message_assignments")
}

/// WorkoutTemplate - Super Set or Circuit catalog template
model WorkoutTemplate {
  id                   String                    @id @default(uuid())
  name                 Json
  description          Json?
  slug                 String                    @unique
  coverImageUrl        String?
  levelId              String?
  estimatedDurationMin Int?
  tags                 Json?
  status               ContentStatus             @default(draft)
  publishedAt          DateTime?
  createdBy            String?
  updatedBy            String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  deletedAt            DateTime?
  isFeatured           Boolean                   @default(false)
  origin               WorkoutTemplateOrigin     @default(STANDALONE)
  programId            String?
  plannedWorkoutItems  PlannedWorkoutItem[]
  plannedWorkouts      PlannedWorkout[]
  workoutExecutions    WorkoutExecution[]
  phases               WorkoutTemplatePhase[]
  exercises            WorkoutTemplateExercise[]
  program              Program?                  @relation(fields: [programId], references: [id], onDelete: SetNull)
  level                Level?                    @relation(fields: [levelId], references: [id])

  @@index([status])
  @@index([deletedAt])
  @@index([levelId])
  @@index([origin])
  @@index([programId])
  @@map("workout_templates")
}

/// WorkoutPhase - reusable phase definition (Warm-up / Main / Cool-down).
model WorkoutPhase {
  id                String                 @id @default(uuid())
  slug              String                 @unique
  name              Json
  description       Json?
  role              WorkoutBlockRole       @default(MAIN)
  canSkip           Boolean                @default(false)
  canContinue       Boolean                @default(true)
  maxContinueTimeMs Int?
  color             String?
  icon              String?
  isActive          Boolean                @default(true)
  sortOrder         Int                    @default(0)
  createdBy         String?
  updatedBy         String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  deletedAt         DateTime?
  templatePhases    WorkoutTemplatePhase[]

  @@index([role])
  @@index([deletedAt])
  @@map("workout_phases")
}

/// WorkoutTemplatePhase - an ordered phase instance inside a workout template.
model WorkoutTemplatePhase {
  id                        String                    @id @default(uuid())
  workoutTemplateId         String
  phaseId                   String
  sortOrder                 Int                       @default(0)
  nameOverride              Json?
  canSkipOverride           Boolean?
  canContinueOverride       Boolean?
  maxContinueTimeMsOverride Int?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  workoutTemplate           WorkoutTemplate           @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)
  phase                     WorkoutPhase              @relation(fields: [phaseId], references: [id])
  exercises                 WorkoutTemplateExercise[]

  @@unique([id, workoutTemplateId])
  @@index([workoutTemplateId])
  @@index([phaseId])
  @@map("workout_template_phases")
}

/// WorkoutTemplateExercise - Exercise within a template with specific configuration
model WorkoutTemplateExercise {
  id                      String                @id @default(uuid())
  workoutTemplateId       String
  workoutTemplatePhaseId  String
  exerciseId              String
  variantIndex            Int                   @default(0)
  targetReps              Int?
  targetRepsPerSet        Json?
  targetDuration          Int?
  sets                    Int                   @default(1)
  restBetweenSetsMs       Int                   @default(30000)
  restBetweenSetsPerSetMs Json?
  restAfterExerciseMs     Int                   @default(60000)
  weightKg                Float?
  weightPerSet            Json?
  notes                   Json?
  sortOrder               Int                   @default(0)
  createdAt               DateTime              @default(now())
  exercise                Exercise              @relation(fields: [exerciseId], references: [id])
  workoutTemplate         WorkoutTemplate       @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)
  workoutTemplatePhase    WorkoutTemplatePhase  @relation(fields: [workoutTemplatePhaseId, workoutTemplateId], references: [id, workoutTemplateId], onDelete: Cascade)
  userProgramOverrides    UserProgramOverride[]

  @@index([workoutTemplateId])
  @@index([workoutTemplatePhaseId])
  @@index([exerciseId])
  @@map("workout_template_exercises")
}

model Program {
  id                       String                 @id @default(uuid())
  name                     Json
  description              Json?
  slug                     String                 @unique
  coverImageUrl            String?
  durationWeeks            Int
  isDefault                Boolean                @default(false)
  isPublished              Boolean                @default(false)
  tags                     Json?
  createdBy                String?
  updatedBy                String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  deletedAt                DateTime?
  levelMinId               String?
  levelMaxId               String?
  nextProgramId            String?
  prerequisiteProgramId    String?
  prescriptionPriority     Int                    @default(100)
  programType              ProgramType            @default(SYSTEM)
  autoAssignable           Boolean                @default(false)
  version                  Int                    @default(1)
  ownerId                  String?
  forkedFromId             String?
  coachingNotes            Json?
  weeklyWorkoutTarget      Int?
  estimatedWorkoutMinutes  Int?
  isFeatured               Boolean                @default(false)
  plannedWorkoutReports    PlannedWorkoutReport[]
  programAttributes        ProgramAttribute[]
  weeks                    ProgramWeek[]
  nextProgram              Program?               @relation("ProgramNext", fields: [nextProgramId], references: [id])
  previousPrograms         Program[]              @relation("ProgramNext")
  prerequisiteProgram      Program?               @relation("ProgramChain", fields: [prerequisiteProgramId], references: [id])
  dependentPrograms        Program[]              @relation("ProgramChain")
  forkedFrom               Program?               @relation("ProgramFork", fields: [forkedFromId], references: [id])
  forkedPrograms           Program[]              @relation("ProgramFork")
  levelMin                 Level?                 @relation("ProgramMinLevel", fields: [levelMinId], references: [id])
  levelMax                 Level?                 @relation("ProgramMaxLevel", fields: [levelMaxId], references: [id])
  progressionRules         ProgressionRule[]
  userPrograms             UserProgram[]
  embeddedWorkoutTemplates WorkoutTemplate[]

  @@index([deletedAt])
  @@index([isPublished])
  @@index([programType])
  @@index([levelMinId])
  @@index([levelMaxId])
  @@map("programs")
}

/// Program matching dimensions (domain, goal, equipment, etc.) — reuses AttributeValue catalog with Exercise.
model ProgramAttribute {
  id               String               @id @default(uuid())
  programId        String
  attributeValueId String
  mode             ProgramAttributeMode @default(REQUIRED)
  createdAt        DateTime             @default(now())
  program          Program              @relation(fields: [programId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue       @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([programId, attributeValueId])
  @@index([programId])
  @@index([attributeValueId])
  @@map("program_attributes")
}

model ProgramWeek {
  id          String       @id @default(uuid())
  programId   String
  weekNumber  Int
  target      Json?
  description Json?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  days        ProgramDay[]
  program     Program      @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, weekNumber])
  @@index([programId])
  @@map("program_weeks")
}

model ProgramDay {
  id              String                @id @default(uuid())
  weekId          String
  dayNumber       Int
  dayType         String                @default("training")
  isRestDay       Boolean               @default(false)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  week            ProgramWeek           @relation(fields: [weekId], references: [id], onDelete: Cascade)
  plannedWorkouts PlannedWorkout[]
  targetMuscles   ProgramDayAttribute[]

  @@unique([weekId, dayNumber])
  @@index([weekId])
  @@map("program_days")
}

model ProgramDayAttribute {
  id               String         @id @default(uuid())
  dayId            String
  attributeValueId String
  createdAt        DateTime       @default(now())
  day              ProgramDay     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([dayId, attributeValueId])
  @@index([dayId])
  @@index([attributeValueId])
  @@map("program_day_attributes")
}

model PlannedWorkout {
  id                   String                 @id @default(uuid())
  dayId                String
  workoutTemplateId    String
  name                 Json
  sortOrder            Int                    @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  estimatedDurationMin Int?
  items                PlannedWorkoutItem[]
  reports              PlannedWorkoutReport[]
  progressionHistory   ProgressionHistory[]
  day                  ProgramDay             @relation(fields: [dayId], references: [id], onDelete: Cascade)
  workoutTemplate      WorkoutTemplate        @relation(fields: [workoutTemplateId], references: [id], onDelete: Restrict)

  @@index([dayId])
  @@index([workoutTemplateId])
  @@map("planned_workouts")
}

model PlannedWorkoutItem {
  id                      String                 @id @default(uuid())
  plannedWorkoutId        String
  sortOrder               Int                    @default(0)
  type                    PlannedWorkoutItemType
  exerciseId              String?
  sets                    Int?                   @default(1)
  targetReps              Int?
  targetDuration          Int?
  restBetweenSetsMs       Int?                   @default(30000)
  weightKg                Float?
  weightPerSet            Json?
  notes                   Json?
  restDurationMs          Int?
  sourceWorkoutTemplateId String?
  isModified              Boolean                @default(false)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  exercise                Exercise?              @relation(fields: [exerciseId], references: [id])
  plannedWorkout          PlannedWorkout         @relation(fields: [plannedWorkoutId], references: [id], onDelete: Cascade)
  sourceWorkoutTemplate   WorkoutTemplate?       @relation(fields: [sourceWorkoutTemplateId], references: [id])
  userProgramOverrides    UserProgramOverride[]

  @@index([plannedWorkoutId])
  @@index([exerciseId])
  @@index([sourceWorkoutTemplateId])
  @@map("planned_workout_items")
}

model UserProgram {
  id                      String                                @id @default(uuid())
  userId                  String
  programId               String?
  name                    Json?
  startDate               DateTime                              @default(now())
  isActive                Boolean                               @default(true)
  customizations          Json?
  /// Last time server-side customizations were changed (coach/admin); used for mobile sync conflict resolution.
  customizationsUpdatedAt DateTime?
  templateVersion         Int                                   @default(1)
  assignmentReason        Json?
  createdAt               DateTime                              @default(now())
  updatedAt               DateTime                              @updatedAt
  activePlanSlots         ActivePlanProgram[]
  progress                UserProgramProgress[]
  progressionStates       UserProgramExerciseProgressionState[]
  overrides               UserProgramOverride[]
  program                 Program?                              @relation(fields: [programId], references: [id])
  user                    User                                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([programId])
  @@map("user_programs")
}

/// User-specific overrides applied on top of program template (effective plan).
/// Target XOR (DB CHECK): exactly one of plannedWorkoutItemId (legacy) or workoutTemplateExerciseId (template).
model UserProgramOverride {
  id                        String                   @id @default(uuid())
  userProgramId             String
  weekNumber                Int
  dayNumber                 Int
  plannedWorkoutItemId      String?
  workoutTemplateExerciseId String?
  overrideType              OverrideType
  reasonCode                OverrideReason?
  data                      Json?
  appliedBy                 OverrideAppliedBy        @default(USER)
  /// Client outbox operationId — unique per userProgram when set (P1.3).
  idempotencyKey            String?
  createdAt                 DateTime                 @default(now())
  userProgram               UserProgram              @relation(fields: [userProgramId], references: [id], onDelete: Cascade)
  plannedWorkoutItem        PlannedWorkoutItem?      @relation(fields: [plannedWorkoutItemId], references: [id], onDelete: Cascade)
  workoutTemplateExercise   WorkoutTemplateExercise? @relation(fields: [workoutTemplateExerciseId], references: [id], onDelete: Cascade)

  @@unique([userProgramId, idempotencyKey])
  @@index([userProgramId, weekNumber, dayNumber])
  @@index([plannedWorkoutItemId])
  @@index([workoutTemplateExerciseId])
  @@map("user_program_overrides")
}

model UserProgramProgress {
  id               String         @id @default(uuid())
  userProgramId    String
  weekNumber       Int
  dayNumber        Int
  plannedWorkoutId String         @default("__day__")
  completedAt      DateTime?
  status           ProgressStatus @default(pending)
  userProgram      UserProgram    @relation(fields: [userProgramId], references: [id], onDelete: Cascade)

  @@unique([userProgramId, weekNumber, dayNumber, plannedWorkoutId])
  @@index([userProgramId])
  @@index([userProgramId, weekNumber])
  @@map("user_program_progress")
}

model PlannedWorkoutReport {
  id               String         @id @default(uuid())
  userId           String
  programId        String?
  plannedWorkoutId String
  weekNumber       Int
  dayNumber        Int
  startedAt        DateTime       @default(now())
  completedAt      DateTime?
  status           ReportStatus   @default(in_progress)
  totalDurationMs  Int?
  totalExercises   Int?
  totalSets        Int?
  completedSets    Int?
  totalReps        Int?
  avgAccuracy      Float?
  avgFormScore     Float?
  /// User-reported perceived exertion (1–10) after workout completion.
  rpe              Int?
  report           Json?
  /// Client outbox operationId — unique per user when set (P1.3).
  idempotencyKey   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  program          Program?       @relation(fields: [programId], references: [id])
  plannedWorkout   PlannedWorkout @relation(fields: [plannedWorkoutId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey])
  @@index([userId])
  @@index([programId])
  @@index([plannedWorkoutId])
  @@index([userId, programId])
  @@index([userId, plannedWorkoutId, status])
  @@index([userId, weekNumber, dayNumber])
  @@map("planned_workout_reports")
}

model System {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system")
}

model Role {
  id            String           @id @default(uuid())
  name          String           @unique
  displayName   Json
  description   Json?
  isSystem      Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  modelHasRoles ModelHasRole[]
  permissions   RolePermission[]

  @@map("roles")
}

model ModelHasRole {
  roleId    String
  modelId   String
  modelType String
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, modelId, modelType])
  @@index([modelId, modelType])
  @@index([roleId])
  @@map("model_has_roles")
}

model Permission {
  id        String           @id @default(uuid())
  subject   String
  action    String
  createdAt DateTime         @default(now())
  roles     RolePermission[]

  @@unique([subject, action])
  @@index([subject])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// Admin users for the dashboard
model Admin {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  name             String
  isActive         Boolean   @default(true)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  isSuperAdmin     Boolean   @default(false)

  @@index([isSuperAdmin])
  @@map("admins")
}

/// Mobile app users
model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  password                String?
  name                    String
  avatarUrl               String?
  googleId                String?                  @unique
  provider                String                   @default("email")
  preferredLanguage       String                   @default("en")
  voiceFeedback           Boolean                  @default(true)
  notifications           Boolean                  @default(true)
  isPro                   Boolean                  @default(false)
  subscriptionExpiry      DateTime?
  totalWorkoutExecutions  Int                      @default(0)
  totalMinutes            Int                      @default(0)
  resetToken              String?
  resetTokenExpiry        DateTime?
  isActive                Boolean                  @default(true)
  emailVerified           Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  activePlan              ActivePlan?
  bodyScanResults         BodyScanResult[]
  plannedWorkoutReports   PlannedWorkoutReport[]
  progressionHistory      ProgressionHistory[]
  reassessmentSchedules   ReassessmentSchedule[]
  refreshTokens           RefreshToken[]
  workoutExecutions       WorkoutExecution[]
  levelProfiles           UserLevelProfile[]
  userPrograms            UserProgram[]
  userExercisePreferences UserExercisePreference[]
  subscriptions           Subscription[]
  subscriptionCheckouts   SubscriptionCheckout[]
  trainingGoal            TrainingGoal             @default(GENERAL_HEALTH)
  trainingProfile         TrainingProfile?

  @@index([email])
  @@index([googleId])
  @@map("users")
}

/// Training profile collected from user (onboarding); 1:1 with User.
model TrainingProfile {
  id                       String    @id @default(uuid())
  userId                   String    @unique
  heightCm                 Float?
  weightKg                 Float?
  dateOfBirth              DateTime?
  biologicalSex            String?
  currentActivityLevel     String?
  trainingExperienceMonths Int?
  resistanceExperience     String?
  availableDaysPerWeek     Int?
  /// 0=Sun … 6=Sat — which weekdays the user trains; length should match program weeklyWorkoutTarget when enrolling.
  trainingWeekdays         Int[]     @default([])
  maxWorkoutMinutes        Int?
  availableEquipment       Json?
  trainingLocation         String?
  knownInjuries            Json?
  healthDisclaimerAccepted Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("training_profiles")
}

/// Refresh tokens for JWT authentication
model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  deviceInfo String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Level - Named training stage (1-5). Defines difficulty tier and default training parameters.
model Level {
  id                       String               @id @default(uuid())
  number                   Int                  @unique
  code                     String               @unique
  name                     Json
  description              Json?
  icon                     String?
  color                    String?
  entryThreshold           Float
  defaultSetsMin           Int                  @default(2)
  defaultSetsMax           Int                  @default(3)
  defaultRepsMin           Int                  @default(8)
  defaultRepsMax           Int                  @default(12)
  defaultIntensityGuide    String               @default("bodyweight_only")
  defaultRestBetweenSetsMs Int                  @default(60000)
  defaultWorkoutDurMin     Int                  @default(20)
  defaultWorkoutDurMax     Int                  @default(30)
  defaultWeeklyFreqMin     Int                  @default(2)
  defaultWeeklyFreqMax     Int                  @default(3)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  maxThreshold             Float?
  assessmentTemplates      AssessmentTemplate[]
  exercises                Exercise[]
  workoutTemplates         WorkoutTemplate[]
  programsAsMinLevel       Program[]            @relation("ProgramMinLevel")
  programsAsMaxLevel       Program[]            @relation("ProgramMaxLevel")
  bodyScanResults          BodyScanResult[]

  @@map("levels")
}

/// UserLevelProfile - Snapshot of user's current level across all dimensions.
/// Updated after each assessment.
model UserLevelProfile {
  id              String         @id @default(uuid())
  userId          String
  overallLevel    Int
  bodyScore       Float
  domainLevels    Json
  regionLevels    Json
  limitingFactors Json
  assessmentId    String         @unique
  classifiedAt    DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  assessment      BodyScanResult @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, classifiedAt])
  @@map("user_level_profiles")
}

/// ActivePlan — User's current training schedule with ordered programs.
model ActivePlan {
  id        String              @id @default(uuid())
  userId    String              @unique
  status    String              @default("active")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  programs  ActivePlanProgram[]
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("active_plans")
}

/// ActivePlanProgram — A program slot within the active plan.
model ActivePlanProgram {
  id                 String      @id @default(uuid())
  activePlanId       String
  userProgramId      String
  sortOrder          Int         @default(0)
  status             String      @default("upcoming")
  scheduledStartDate DateTime?
  actualStartDate    DateTime?
  completedAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  activePlan         ActivePlan  @relation(fields: [activePlanId], references: [id], onDelete: Cascade)
  userProgram        UserProgram @relation(fields: [userProgramId], references: [id], onDelete: Cascade)

  @@index([activePlanId])
  @@index([userProgramId])
  @@map("active_plan_programs")
}

/// ProgressionRule — Defines how training parameters change based on performance.
model ProgressionRule {
  id           String               @id @default(uuid())
  name         String
  scope        String
  programId    String?
  exerciseSlug String?
  trigger      String
  conditions   Json
  action       Json
  priority     Int                  @default(0)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  history      ProgressionHistory[]
  program      Program?             @relation(fields: [programId], references: [id])
  exercise     Exercise?            @relation(fields: [exerciseSlug], references: [slug], onDelete: SetNull, onUpdate: Cascade)

  @@index([scope])
  @@index([programId])
  @@index([exerciseSlug])
  @@index([isActive])
  @@map("progression_rules")
}

/// ExerciseProgressionProfile — Scientific progression template per exercise.
/// Single source of truth for how an exercise should progress.
model ExerciseProgressionProfile {
  id               String            @id @default(uuid())
  exerciseId       String            @unique
  archetype        ExerciseArchetype
  allowedAxes      Json
  priorityOrder    Json
  repAxis          Json?
  loadAxis         Json?
  durationAxis     Json?
  setAxis          Json?
  difficultyLadder Json?
  qualityGate      Json
  promotionPolicy  Json
  regressionPolicy Json
  isAutoGenerated  Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([archetype])
  @@map("exercise_progression_profiles")
}

/// UserProgramExerciseProgressionState — Dynamic progression state per user+program+exercise.
/// Tracks where the user currently is in their progression journey.
model UserProgramExerciseProgressionState {
  id                    String    @id @default(uuid())
  userProgramId         String
  exerciseId            String
  currentAxis           String
  currentDifficultyCode String?
  currentWeightKg       Float?
  currentTargetReps     Int?
  currentTargetDuration Int?
  currentTargetSets     Int?
  successStreak         Int       @default(0)
  regressionStreak      Int       @default(0)
  lastProgressedAt      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userProgram UserProgram @relation(fields: [userProgramId], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userProgramId, exerciseId])
  @@index([userProgramId])
  @@index([exerciseId])
  @@map("user_program_exercise_progression_state")
}

/// ProgressionHistory — Audit log of every change made by the Progression Engine.
model ProgressionHistory {
  id               String   @id @default(uuid())
  userId           String
  ruleId           String?
  plannedWorkoutId String?
  field            String
  previousValue    Float
  newValue         Float
  reason           String
  appliedAt        DateTime @default(now())

  decisionType        String?
  axis                String?
  eligibilitySnapshot Json?
  stateBefore         Json?
  stateAfter          Json?

  seen   Boolean   @default(false)
  seenAt DateTime?

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule           ProgressionRule? @relation(fields: [ruleId], references: [id])
  plannedWorkout PlannedWorkout?  @relation(fields: [plannedWorkoutId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ruleId])
  @@index([plannedWorkoutId])
  @@index([userId, appliedAt])
  @@index([userId, seen])
  @@map("progression_history")
}

/// ReassessmentSchedule — Tracks when users should be reassessed.
model ReassessmentSchedule {
  id            String          @id @default(uuid())
  userId        String
  reason        String
  scheduledDate DateTime
  status        String          @default("pending")
  assessmentId  String?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  assessment    BodyScanResult? @relation(fields: [assessmentId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([scheduledDate])
  @@map("reassessment_schedules")
}

model AssessmentTemplate {
  id                   String                       @id @default(uuid())
  name                 Json
  description          Json?
  type                 String                       @default("initial")
  targetLevelId        String?
  domainWeights        Json                         @default("{\"safety\": 0.20, \"control\": 0.25, \"mobility\": 0.35, \"symmetry\": 0.20}")
  isDefault            Boolean                      @default(false)
  isPublished          Boolean                      @default(false)
  sortOrder            Int                          @default(0)
  createdBy            String?
  updatedBy            String?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  deletedAt            DateTime?
  exercises            AssessmentTemplateExercise[]
  assessmentAttributes AssessmentAttribute[]
  targetLevel          Level?                       @relation(fields: [targetLevelId], references: [id])
  assessments          BodyScanResult[]

  @@index([type])
  @@index([targetLevelId])
  @@index([isPublished])
  @@map("assessment_templates")
}

/// Assessment template matching dimensions (same pattern as ProgramAttribute).
model AssessmentAttribute {
  id               String               @id @default(uuid())
  templateId       String
  attributeValueId String
  mode             ProgramAttributeMode @default(REQUIRED)
  createdAt        DateTime             @default(now())
  template         AssessmentTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  attributeValue   AttributeValue       @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([templateId, attributeValueId])
  @@index([templateId])
  @@index([attributeValueId])
  @@map("assessment_attributes")
}

model AssessmentTemplateExercise {
  id                   String             @id @default(uuid())
  templateId           String
  exerciseId           String
  sortOrder            Int                @default(0)
  targetRegion         String
  side                 String             @default("center")
  entryType            String             @default("core")
  activationCondition  Json?
  referenceNormDegrees Float?
  thresholds           Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  exercise             Exercise           @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  template             AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, exerciseId])
  @@index([templateId])
  @@index([exerciseId])
  @@map("assessment_template_exercises")
}

/// Body Scan result - Complete assessment snapshot
model BodyScanResult {
  id                    String                 @id @default(uuid())
  userId                String
  type                  String                 @default("initial")
  bodyScore             Float
  mobilityScore         Float
  controlScore          Float
  symmetryScore         Float?
  safetyScore           Float
  levelId               String?
  regions               Json
  symmetryData          Json?
  hypotheses            Json?
  recommendations       Json?
  rawReportIds          Json?
  previousId            String?
  durationMs            Int?
  movementCount         Int                    @default(3)
  completedAt           DateTime               @default(now())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  templateId            String?
  previous              BodyScanResult?        @relation("AssessmentProgress", fields: [previousId], references: [id])
  nextAssessments       BodyScanResult[]       @relation("AssessmentProgress")
  template              AssessmentTemplate?    @relation(fields: [templateId], references: [id])
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  level                 Level?                 @relation(fields: [levelId], references: [id])
  reassessmentSchedules ReassessmentSchedule[]
  levelProfiles         UserLevelProfile?

  @@index([userId])
  @@index([userId, type])
  @@index([userId, completedAt])
  @@index([templateId])
  @@index([levelId])
  @@map("body_scan_results")
}

/// WorkoutExecution - A completed single-exercise workout run
model WorkoutExecution {
  id String @id @default(uuid())

  userId     String
  exerciseId String

  timestamp  DateTime
  durationMs Int

  totalReps   Int
  countedReps Int
  invalidReps Int

  weightKg   Float?
  weightUnit String @default("kg")

  context WorkoutExecutionContext @default(free)

  workoutGroupId String?

  workoutTemplateId String?

  legacyReport Json?

  deviceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise         Exercise                 @relation(fields: [exerciseId], references: [id])
  workoutTemplate  WorkoutTemplate?         @relation(fields: [workoutTemplateId], references: [id], onDelete: SetNull)
  executionMetrics WorkoutExecutionMetrics?
  repMetrics       RepMetrics[]

  @@index([userId])
  @@index([exerciseId])
  @@index([timestamp])
  @@index([userId, exerciseId])
  @@index([workoutGroupId])
  @@index([workoutTemplateId])
  @@index([context])
  @@map("workout_executions")
}

/// Workout-level aggregated metrics for a single exercise execution
model WorkoutExecutionMetrics {
  id                   String           @id @default(uuid())
  workoutExecutionId   String           @unique
  avgRom               Int
  avgSymmetry          Int?
  avgStability         Int?
  avgVelocity          Int?
  avgFormScore         Int
  avgAlignmentAccuracy Int?
  avgTempo             Json
  totalTUT             Int
  totalVolume          Float?
  maxWeight            Float?
  est1RM               Float?
  relativeStrength     Float?
  intensityPercentage  Float?
  formConsistency      Int?
  fatigueIndex         Int?
  createdAt            DateTime         @default(now())
  workoutExecution     WorkoutExecution @relation(fields: [workoutExecutionId], references: [id], onDelete: Cascade)

  @@map("workout_execution_metrics")
}

/// Individual rep metrics
model RepMetrics {
  id                 String           @id @default(uuid())
  workoutExecutionId String
  repNumber          Int
  durationMs         Int
  worstState         Int
  score              Int
  weightKg           Float?
  side               String?
  rom                Int
  symmetry           Int?
  stability          Int?
  velocity           Int?
  formScore          Int
  alignmentAccuracy  Int?
  tempo              Json
  createdAt          DateTime         @default(now())
  workoutExecution   WorkoutExecution @relation(fields: [workoutExecutionId], references: [id], onDelete: Cascade)

  @@index([workoutExecutionId])
  @@index([workoutExecutionId, repNumber])
  @@map("rep_metrics")
}

enum ContentStatus {
  draft
  published
}

enum ProgramType {
  SYSTEM
  COACH
  CUSTOM
}

enum ProgramDomain {
  TRAINING
  MOBILITY
  THERAPEUTIC
}

enum TrainingGoal {
  STRENGTH
  HYPERTROPHY
  POWER
  GENERAL_HEALTH
}

enum ProgramAttributeMode {
  REQUIRED
  OPTIONAL
  EXCLUDED
}

enum WorkoutTemplateOrigin {
  STANDALONE
  PROGRAM_EMBEDDED
}

enum WorkoutBlockRole {
  WARMUP
  ACTIVATION
  MAIN
  ACCESSORY
  CORRECTIVE
  COOLDOWN
  TEST
}

enum PlannedWorkoutItemType {
  exercise
  rest
}

enum WorkoutExecutionContext {
  free
  program
  assessment
  explore_workout
  quick_start
}

enum WorkoutItemIntent {
  STANDARD
  POWER
  ECCENTRIC
  VELOCITY_BASED
}

enum MovementPattern {
  SQUAT
  HINGE
  LUNGE
  PUSH_HORIZONTAL
  PUSH_VERTICAL
  PULL_HORIZONTAL
  PULL_VERTICAL
  CARRY
  ROTATION
  GAIT
  JUMP_LAND
  CORE_BRACE
  MOBILITY_DRILL
  OTHER
}

enum LoadCapability {
  BODYWEIGHT_ONLY
  EXTERNAL_LOAD_OPTIONAL
  EXTERNAL_LOAD_REQUIRED
}

enum OverrideType {
  REPLACE_EXERCISE
  ADJUST_PRESCRIPTION
  SKIP_ITEM
  ADD_ITEM
}

enum OverrideReason {
  PAIN_AVOIDANCE
  EQUIPMENT_UNAVAILABLE
  TIME_CONSTRAINT
  PREFERENCE
  COACH_RECOMMENDATION
  OTHER
}

enum OverrideAppliedBy {
  USER
  COACH
}

enum ReportStatus {
  in_progress
  completed
  abandoned
}

enum ProgressStatus {
  pending
  in_progress
  completed
  skipped
}

enum ExerciseArchetype {
  weighted_strength
  bodyweight_dynamic
  isometric_hold
  mobility_rom
  motor_control
}

model Plan {
  id                         String   @id @default(uuid())
  name                       Json
  description                Json?
  monthlyPrice               Decimal  @db.Decimal(10, 2)
  yearlyPrice                Decimal  @db.Decimal(10, 2)
  currency                   String   @default("SAR")
  discount                   Decimal? @default(0) @db.Decimal(10, 2)
  maxExercisesLimit          Int      @default(0)
  maxWorkoutTemplatesLimit   Int      @default(0)
  monthlyGooglePlayProductId String?
  yearlyGooglePlayProductId  String?
  monthlyAppStoreProductId   String?
  yearlyAppStoreProductId    String?
  features                   Json?
  isActive                   Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  subscriptions         Subscription[]
  subscriptionCheckouts SubscriptionCheckout[]

  @@map("plans")
}

model Subscription {
  id                            String    @id @default(uuid())
  userId                        String
  planId                        String
  status                        String    @default("active")
  billingPeriod                 String    @default("monthly")
  gateway                       String    @default("manual")
  amountPaid                    Decimal   @db.Decimal(10, 2)
  startDate                     DateTime  @default(now())
  endDate                       DateTime
  currentPeriodStart            DateTime?
  currentPeriodEnd              DateTime?
  autoRenew                     Boolean   @default(false)
  cancelAtPeriodEnd             Boolean   @default(false)
  cancelledAt                   DateTime?
  upgradedFromId                String?
  googlePlayPackageName         String?
  googlePlayProductId           String?
  googlePlayPurchaseToken       String?   @unique
  googlePlayOrderId             String?
  appStoreProductId             String?
  appStoreTransactionId         String?   @unique
  appStoreOriginalTransactionId String?
  myFatoorahInvoiceId           String?
  myFatoorahPaymentId           String?
  lastVerifiedAt                DateTime?
  metadata                      Json?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  user      User                   @relation(fields: [userId], references: [id])
  plan      Plan                   @relation(fields: [planId], references: [id])
  checkouts SubscriptionCheckout[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([userId, status])
  @@index([endDate])
  @@index([googlePlayProductId])
  @@index([appStoreProductId])
  @@index([appStoreOriginalTransactionId])
  @@index([myFatoorahInvoiceId])
  @@index([myFatoorahPaymentId])
  @@map("subscriptions")
}

model SubscriptionCheckout {
  id                      String    @id @default(uuid())
  userId                  String
  planId                  String
  subscriptionId          String?
  gateway                 String    @default("myfatoorah")
  billingPeriod           String
  status                  String    @default("pending")
  currency                String    @default("SAR")
  amount                  Decimal   @db.Decimal(10, 2)
  paymentUrl              String?
  myFatoorahInvoiceId     String?
  myFatoorahPaymentId     String?
  googlePlayProductId     String?
  googlePlayPurchaseToken String?
  idempotencyKey          String?   @unique
  expiresAt               DateTime?
  paidAt                  DateTime?
  cancelledAt             DateTime?
  failedAt                DateTime?
  lastError               String?
  rawPayload              Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan          @relation(fields: [planId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([planId])
  @@index([subscriptionId])
  @@index([gateway])
  @@index([status])
  @@index([myFatoorahInvoiceId])
  @@index([myFatoorahPaymentId])
  @@index([googlePlayPurchaseToken])
  @@map("subscription_checkouts")
}
