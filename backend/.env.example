PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pose_db"
ADMIN_JWT_SECRET=change-me
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me

# Mobile billing / store verification (production values required on server)
APP_STORE_BUNDLE_ID=com.example.ios
APP_STORE_ENV=Sandbox
# Required when APP_STORE_ENV=Production (numeric App Store Connect app id)
APP_STORE_APPLE_ID=
GOOGLE_PLAY_PACKAGE_NAME=com.movit.androidApp
# Inline JSON or path to Google Play service account key (Android Publisher API)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# Allow verify endpoints to accept products not mapped on subscription plans (dev/staging only)
ALLOW_UNMAPPED_APP_STORE_PRODUCTS=false
ALLOW_UNMAPPED_GOOGLE_PLAY_PRODUCTS=false

# Google Sign-In (Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# BullMQ requires Redis >= 6.2. Laragon/Windows Redis 5.x on 6379 is too old.
# Run: npm run redis:up   (downloads Redis 7 portable to tools/redis-win, port 6380)
# Or with Docker: npm run redis:docker:up
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

ADMIN_APP_ORIGIN=http://localhost:3000


# Gemini AI Configuration
GEMINI_API_KEY=

# Text generation model (for translation)
GEMINI_TEXT_MODEL="gemini-3-flash-preview"

# TTS model
GEMINI_TTS_MODEL="gemini-2.5-flash-preview-tts"

# Voice configurations
GEMINI_VOICE_AR="Fenrir"
GEMINI_VOICE_EN="Fenrir"

GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket
GCS_CREDENTIALS_JSON=
GCS_PUBLIC_READ=true  # optional, default true

# MyFatoorah (subscriptions) — same client reads one of these for the API key:
# MYFATOORAH_API_KEY=<key from portal, e.g. SK_...>   (common name in existing .env)
# MYFATOORAH_API_TOKEN=<same value>                     (alias)
# MYFATOORAH_TOKEN=<same value>                        (alias)
# Test mode: MYFATOORAH_ENV=sandbox  → default base https://apitest.myfatoorah.com unless overridden:
# MYFATOORAH_API_BASE_URL=https://apitest.myfatoorah.com
# MYFATOORAH_EXPIRY_TIMEZONE=Asia/Riyadh
# MYFATOORAH_WEBHOOK_SECRET=<secret for POST .../payments/myfatoorah/subscriptions/webhook>
# MyFatoorah Local webhook tester may omit the signature header. Never enable in production:
# MYFATOORAH_WEBHOOK_ALLOW_UNSIGNED=true
# Public URL of this API (MyFatoorah subscription callbacks / webhooks). Any one of:
# BACKEND_PUBLIC_URL=https://back.mongz.online
# API_BASE_URL=https://back.mongz.online   (alias used on some servers)
# Optional app deep link opened after MyFatoorah result page:
# MOBILE_APP_DEEP_LINK_SCHEME=movit
# MOBILE_APP_SCHEME=movit