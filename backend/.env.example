GCS_BUCKET_NAME=waytofix
GCS_CREDENTIALS_JSON=
GCS_PUBLIC_READ=true  # optional, default true

# MyFatoorah (subscriptions + bookings) — same client reads one of these for the API key:
# MYFATOORAH_API_KEY=<key from portal, e.g. SK_...>   (common name in existing .env)
# MYFATOORAH_API_TOKEN=<same value>                     (alias)
# MYFATOORAH_TOKEN=<same value>                        (alias)
# Test mode: MYFATOORAH_ENV=sandbox  → default base https://apitest.myfatoorah.com unless overridden:
# MYFATOORAH_API_BASE_URL=https://apitest.myfatoorah.com
# MYFATOORAH_EXPIRY_TIMEZONE=Asia/Riyadh
# MYFATOORAH_WEBHOOK_SECRET=<secret for POST .../payments/myfatoorah/subscriptions/webhook>
# MyFatoorah Local webhook tester may omit the signature header. Never enable in production:
# MYFATOORAH_WEBHOOK_ALLOW_UNSIGNED=true
# Public URL of this API (MyFatoorah subscription callbacks / webhooks). Any one of:
# BACKEND_PUBLIC_URL=https://back.mongz.online
# API_BASE_URL=https://back.mongz.online   (alias used on some servers)
# Optional app deep link opened after MyFatoorah result page:
# MOBILE_APP_DEEP_LINK_SCHEME=waytofix